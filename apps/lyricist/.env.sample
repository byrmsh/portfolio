REDIS_URL="redis://localhost:6379/0"
REDIS_EVENTS_STREAM="events"
YTMUSIC_PLAYLIST_ID=""
WEB_ORIGIN="http://localhost:4321"
LYRICIST_MODE="all"
# Ignore the Redis cursor and rescan the playlist in sync mode.
LYRICIST_IGNORE_CURSOR="false"
# Queue analysis limits (free-tier friendly defaults).
LYRICIST_ANALYSIS_MAX_PER_RUN="3"
LYRICIST_ANALYSIS_MIN_INTERVAL_SECONDS="10"
LYRICIST_ANALYSIS_BACKOFF_BASE_SECONDS="60"
LYRICIST_ANALYSIS_BACKOFF_MAX_SECONDS="3600"
LYRICIST_ANALYSIS_MAX_ATTEMPTS="5"

# LLM provider: auto|gemini|openai|none
LYRICIST_LLM_PROVIDER="auto"

# Gemini (native API) - preferred when configured
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
# Enable Google Search grounding (model support varies; may return 400 on unsupported models)
GEMINI_USE_SEARCH="false"

# OpenAI (optional)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5"
