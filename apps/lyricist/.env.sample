REDIS_URL="redis://localhost:6379/0"
REDIS_EVENTS_STREAM="events"
YTMUSIC_PLAYLIST_ID=""
WEB_ORIGIN="http://localhost:4321"

# LLM provider: auto|gemini|openai|none
LYRICIST_LLM_PROVIDER="auto"
# Force regenerating analysis even if one already exists in Redis
LYRICIST_REGENERATE_ANALYSIS="false"
# Retry recently-saved notes whose analysis is missing or marked as an LLM failure
LYRICIST_RETRY_FAILED_ANALYSIS="true"
LYRICIST_RETRY_FAILED_LIMIT="3"

# Gemini (native API) - preferred when configured
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
# Enable Google Search grounding (model support varies; may return 400 on unsupported models)
GEMINI_USE_SEARCH="false"

# OpenAI (optional)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5"
