---
import Menu from '@lucide/astro/icons/menu';
import X from '@lucide/astro/icons/x';
import { SITE } from '../config/site';
import { localizedPath, type SupportedLocale } from '../i18n';

interface Props {
  locale: SupportedLocale;
  t: (path: string, vars?: Record<string, string | number>) => string;
}

const { locale, t } = Astro.props;
// Don't carry query params like `?before=...` across unrelated pages via nav links.
const baseSearch = '';

function normalizePathname(pathname: string): string {
  if (pathname.length > 1 && pathname.endsWith('/')) return pathname.slice(0, -1);
  return pathname;
}

const currentPath = normalizePathname(Astro.url.pathname);
const homeHref = localizedPath(locale, '/', baseSearch);

function hrefPathname(href: string): string {
  return normalizePathname(new URL(href, Astro.url).pathname);
}

function isActiveExact(href: string): boolean {
  return hrefPathname(href) === currentPath;
}

function isActiveSection(href: string): boolean {
  const p = hrefPathname(href);
  return currentPath === p || currentPath.startsWith(`${p}/`);
}

const links = [
  { key: 'home', label: t('nav.home'), href: homeHref, match: 'exact' as const },
  {
    key: 'blog',
    label: t('nav.blog'),
    href: localizedPath(locale, '/blog', baseSearch),
    match: 'section' as const,
  },
  {
    key: 'lyrics',
    label: t('nav.lyrics'),
    href: localizedPath(locale, '/lyrics', baseSearch),
    match: 'section' as const,
  },
  {
    key: 'projects',
    label: t('nav.projects'),
    href: localizedPath(locale, '/projects', baseSearch),
    match: 'section' as const,
  },
  {
    key: 'contact',
    label: t('nav.contact'),
    href: localizedPath(locale, '/contact', baseSearch),
    match: 'exact' as const,
  },
];
---

<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--border-subtle)] glass-header"
>
  <div
    id="mobile-nav-shell"
    class="max-w-5xl mx-auto px-4 sm:px-6 overflow-hidden max-h-14 transition-[max-height] duration-300 ease-out"
  >
    <div class="h-14 flex items-center justify-between gap-4">
      <a
        href={localizedPath(locale, '/', baseSearch)}
        class="font-mono text-sm font-semibold tracking-tight hover:opacity-70 transition-opacity"
      >
        {SITE.domain}
      </a>
      <div class="flex items-center gap-3">
        <div class="hidden sm:flex items-center gap-6 text-sm font-medium text-[var(--text-body)]">
          {
            links.map((link) => {
              // Home should only be active at the locale root (e.g. "/" or "/es"), not on subpages.
              const active =
                link.match === 'exact'
                  ? isActiveExact(link.href)
                  : link.href === homeHref
                    ? isActiveExact(link.href)
                    : isActiveSection(link.href);
              return (
                <a
                  href={link.href}
                  aria-current={active ? 'page' : undefined}
                  class={
                    active
                      ? 'text-[var(--text-primary)]'
                      : 'hover:text-[var(--text-primary)] transition-colors'
                  }
                >
                  {link.label}
                </a>
              );
            })
          }
        </div>
        <button
          id="mobile-menu-toggle"
          class="sm:hidden p-1"
          type="button"
          aria-label={t('nav.openMenu')}
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <Menu id="mobile-menu-open-icon" class="w-5 h-5 text-[var(--text-body)]" />
          <X id="mobile-menu-close-icon" class="hidden w-5 h-5 text-[var(--text-body)]" />
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="sm:hidden pb-3 opacity-0 transition-opacity duration-200 ease-out">
      <div
        class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm font-medium text-[var(--text-body)]"
      >
        {
          links.map((link) => {
            const active =
              link.match === 'exact'
                ? isActiveExact(link.href)
                : link.href === homeHref
                  ? isActiveExact(link.href)
                  : isActiveSection(link.href);
            return (
              <a
                href={link.href}
                aria-current={active ? 'page' : undefined}
                class={
                  active
                    ? 'text-[var(--text-primary)]'
                    : 'hover:text-[var(--text-primary)] transition-colors'
                }
              >
                {link.label}
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</nav>

<script>
  const shell = document.getElementById('mobile-nav-shell');
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('mobile-menu-open-icon');
  const closeIcon = document.getElementById('mobile-menu-close-icon');
  const mediaQuery = window.matchMedia('(min-width: 640px)');

  if (shell && toggle && menu && openIcon && closeIcon) {
    const menuLinks = menu.querySelectorAll('a');

    const setExpanded = (expanded: boolean) => {
      toggle.setAttribute('aria-expanded', expanded.toString());
      shell.classList.toggle('max-h-14', !expanded);
      shell.classList.toggle('max-h-40', expanded);
      menu.classList.toggle('opacity-0', !expanded);
      menu.classList.toggle('opacity-100', expanded);
      openIcon.classList.toggle('hidden', expanded);
      closeIcon.classList.toggle('hidden', !expanded);
    };

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      setExpanded(!expanded);
    });

    window.addEventListener(
      'scroll',
      () => {
        if (toggle.getAttribute('aria-expanded') === 'true') setExpanded(false);
      },
      { passive: true },
    );

    window.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true')
        setExpanded(false);
    });

    mediaQuery.addEventListener('change', (event: MediaQueryListEvent) => {
      if (event.matches) setExpanded(false);
    });

    for (const link of menuLinks) {
      link.addEventListener('click', () => setExpanded(false));
    }
  }
</script>
