---
import type { SupportedLocale } from '../i18n';

type Primitive = string | number;
type Translator = (path: string, vars?: Record<string, Primitive>) => string;

type JobFactsJob = {
  companyName?: string;
  location?: string;
  remote?: boolean;
  jobTypes?: string[];
};

interface Props {
  job: JobFactsJob;
  locale: SupportedLocale;
  t: Translator;
}

const { job, t } = Astro.props;

const PLACEHOLDER = '--';

const leftFacts = [
  { label: t('jobs.factCompany'), value: job.companyName ?? PLACEHOLDER },
  { label: t('jobs.factLocation'), value: job.location ?? PLACEHOLDER },
];

const rightFacts = [
  { label: t('jobs.factRemote'), value: typeof job.remote === 'boolean' ? (job.remote ? 'Yes' : 'No') : PLACEHOLDER },
  { label: t('jobs.factTypes'), value: Array.isArray(job.jobTypes) && job.jobTypes.length ? job.jobTypes.join(', ') : PLACEHOLDER },
];
---

<div class="mb-6 rounded-lg border border-neutral-200 bg-neutral-50 p-4">
  <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">{t('jobs.facts')}</h2>

  <div class="mt-3 grid grid-cols-1 gap-4 text-xs text-neutral-700 sm:grid-cols-2 sm:gap-0">
    <div class="flex flex-col gap-2 sm:pr-6">
      {
        leftFacts.map((fact) => (
          <div class="flex items-center justify-between gap-3">
            <span class="font-mono text-neutral-500">{fact.label}</span>
            <span class="truncate">{fact.value}</span>
          </div>
        ))
      }
    </div>

    <div class="flex flex-col gap-2 sm:border-l sm:border-neutral-200 sm:pl-6">
      {
        rightFacts.map((fact) => (
          <div class="flex items-center justify-between gap-3">
            <span class="font-mono text-neutral-500">{fact.label}</span>
            <span class="truncate">{fact.value}</span>
          </div>
        ))
      }
    </div>
  </div>
</div>
