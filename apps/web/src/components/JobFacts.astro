---
import type { SupportedLocale } from '../i18n';

type Primitive = string | number;
type Translator = (path: string, vars?: Record<string, Primitive>) => string;

type JobFactsJob = {
  jobType?: 'FIXED' | 'HOURLY';
  contractorTier?: string;
  hourlyBudgetMin?: number | null;
  hourlyBudgetMax?: number | null;
  fixedPriceAmount?: { isoCurrencyCode?: string | null; amount: string } | null;
  client?: {
    country?: string | null;
    paymentVerificationStatus?: string | null;
    totalSpent?: { isoCurrencyCode?: string | null; amount: string } | null;
  };
};

interface Props {
  job: JobFactsJob;
  locale: SupportedLocale;
  t: Translator;
}

const { job, locale, t } = Astro.props;

const PLACEHOLDER = '--';
const moneyFmt = new Intl.NumberFormat(locale, { maximumFractionDigits: 0 });

function parseAmountString(raw: string | null | undefined): number | null {
  if (!raw) return null;
  const n = Number(String(raw).trim());
  return Number.isFinite(n) ? n : null;
}

function formatMoney(
  amount: number | null | undefined,
  currency: string | null | undefined,
): string | null {
  if (typeof amount !== 'number' || !Number.isFinite(amount)) return null;
  const cur = typeof currency === 'string' && currency.trim().length ? currency.trim() : null;
  return cur ? `${cur} ${moneyFmt.format(amount)}` : moneyFmt.format(amount);
}

function formatMoneyFromRawAmount(
  rawAmount: string | null | undefined,
  currency: string | null | undefined,
): string | null {
  const amt = parseAmountString(rawAmount);
  return amt === null ? null : formatMoney(amt, currency);
}

function formatSpentValue(): string {
  const raw = job.client?.totalSpent?.amount ?? null;
  if (!raw) return PLACEHOLDER;
  const cur = job.client?.totalSpent?.isoCurrencyCode ?? null;
  return formatMoneyFromRawAmount(raw, cur) ?? raw;
}

function formatBudgetValue(): string {
  if (job.jobType === 'HOURLY') {
    const min = formatMoney(job.hourlyBudgetMin ?? null, null);
    const max = formatMoney(job.hourlyBudgetMax ?? null, null);
    const combined = [min, max].filter(Boolean).join(' - ');
    return combined || PLACEHOLDER;
  }

  const raw = job.fixedPriceAmount?.amount ?? null;
  if (!raw) return PLACEHOLDER;
  const cur = job.fixedPriceAmount?.isoCurrencyCode ?? null;
  return formatMoneyFromRawAmount(raw, cur) ?? raw;
}

const leftFacts = [
  { label: t('jobs.factType'), value: job.jobType ?? PLACEHOLDER },
  { label: t('jobs.factTier'), value: job.contractorTier ?? PLACEHOLDER },
  { label: t('jobs.factCountry'), value: job.client?.country ?? PLACEHOLDER },
];

const rightFacts = [
  { label: t('jobs.factPayment'), value: job.client?.paymentVerificationStatus ?? PLACEHOLDER },
  { label: t('jobs.factSpent'), value: formatSpentValue() },
  { label: t('jobs.factBudget'), value: formatBudgetValue() },
];
---

<div class="mb-6 rounded-lg border border-neutral-200 bg-neutral-50 p-4">
  <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">{t('jobs.facts')}</h2>

  <div class="mt-3 grid grid-cols-1 gap-4 text-xs text-neutral-700 sm:grid-cols-2 sm:gap-0">
    <div class="flex flex-col gap-2 sm:pr-6">
      {
        leftFacts.map((fact) => (
          <div class="flex items-center justify-between gap-3">
            <span class="font-mono text-neutral-500">{fact.label}</span>
            <span class="truncate">{fact.value}</span>
          </div>
        ))
      }
    </div>

    <div class="flex flex-col gap-2 sm:border-l sm:border-neutral-200 sm:pl-6">
      {
        rightFacts.map((fact) => (
          <div class="flex items-center justify-between gap-3">
            <span class="font-mono text-neutral-500">{fact.label}</span>
            <span class="truncate">{fact.value}</span>
          </div>
        ))
      }
    </div>
  </div>
</div>
