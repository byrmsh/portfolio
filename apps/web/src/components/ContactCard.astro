---
import SocialLink from './SocialLink.svelte';

interface Props {
  title?: string;
}

const { title = 'Contact' }: Props = Astro.props;
---

<div class="rounded-xl border border-neutral-200 bg-white p-5">
  <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">{title}</p>
  <div class="mt-4 grid gap-3">
    <SocialLink label="GitHub" href="https://github.com/byrmsh" />
    <SocialLink label="Email" href="mailto:hello@bayram.sh" />
    <SocialLink label="PGP" href="#" />
  </div>
</div>
