---
import type { YtMusicAnalysis } from '@portfolio/schema/dashboard';
import LyricFlashcardDeck from './LyricFlashcardDeck.svelte';

interface Props {
  locale: string;
  labels: {
    couldNotLoadNote: string;
    openTrack: string;
    readLyrics: string;
    updatedAt: string;
    background: string;
    flashcards: string;
    flipHint: string;
    tapHint: string;
    rateHint: string;
    knownHint: string;
    reviewHint: string;
    round: string;
    completed: string;
    completedSub: string;
    remaining: string;
    reset: string;
    noScript: string;
  };
  analysis: YtMusicAnalysis | null;
  error: string | null;
}

const { locale, labels, analysis, error } = Astro.props;

const format = (template: string, vars: Record<string, string | number>): string =>
  template.replaceAll(/\{(\w+)\}/g, (_, key: string) => String(vars[key] ?? `{${key}}`));

function toIntlLocale(localeCode: string): string {
  if (localeCode === 'eng') return 'en';
  if (localeCode === 'dev') return 'en-x-dev';
  return localeCode;
}

const updatedAtFormatter = new Intl.DateTimeFormat(toIntlLocale(locale), {
  dateStyle: 'medium',
  timeStyle: 'short',
});
---

{
  error ? (
    <section class="rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6">
      <h2 class="text-sm font-semibold text-[var(--text-primary)]">{labels.couldNotLoadNote}</h2>
      <p class="mt-2 text-sm text-[var(--text-body)]">{error}</p>
    </section>
  ) : analysis ? (
    <>
      <header class="flex items-start gap-5">
        <div class="w-20 h-20 rounded-xl bg-[var(--surface-inverse)] shrink-0 overflow-hidden">
          {analysis.albumArtUrl ? (
            <img src={analysis.albumArtUrl} alt="" class="w-20 h-20 object-cover" loading="lazy" />
          ) : null}
        </div>
        <div class="min-w-0">
          <h1 class="text-2xl font-semibold text-[var(--text-primary)]">{analysis.title}</h1>
          <div class="mt-2 text-sm text-[var(--text-body)]">{analysis.artist}</div>
          <div class="mt-3 flex flex-wrap gap-2">
            {analysis.trackUrl ? (
              <a
                class="text-xxs font-mono rounded-full border border-[var(--border-subtle)] px-3 py-1 hover:bg-[var(--surface-2)]"
                href={analysis.trackUrl}
                target="_blank"
              >
                {labels.openTrack}
              </a>
            ) : null}
            {analysis.lyricsUrl ? (
              <a
                class="text-xxs font-mono rounded-full border border-[var(--border-subtle)] px-3 py-1 hover:bg-[var(--surface-2)]"
                href={analysis.lyricsUrl}
                target="_blank"
              >
                {labels.readLyrics}
              </a>
            ) : null}
          </div>
          <div class="mt-2 text-xxs font-mono text-[var(--text-muted)]">
            {format(labels.updatedAt, {
              date: updatedAtFormatter.format(new Date(analysis.updatedAt)),
            })}
          </div>
        </div>
      </header>

      <section class="rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6">
        <h2 class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">
          {labels.background}
        </h2>
        <p class="mt-3 text-sm text-[var(--text-primary)] leading-relaxed">
          {analysis.background.tldr}
        </p>

        {analysis.background.notes?.length ? (
          <div class="mt-5 grid gap-4">
            {analysis.background.notes.map((n: { title: string; body: string }) => (
              <div class="rounded-lg border border-[var(--border-subtle)] p-4">
                <div class="text-sm font-semibold text-[var(--text-primary)]">{n.title}</div>
                <p class="mt-2 text-sm text-[var(--text-body)] leading-relaxed">{n.body}</p>
              </div>
            ))}
          </div>
        ) : null}
      </section>

      {analysis.vocabulary?.length ? (
        <>
          <div class="flashcard-deck-interactive">
            <LyricFlashcardDeck
              client:load
              trackId={analysis.id}
              items={analysis.vocabulary}
              labels={{
                title: labels.flashcards,
                flipHint: labels.flipHint,
                tapHint: labels.tapHint,
                rateHint: labels.rateHint,
                knownHint: labels.knownHint,
                reviewHint: labels.reviewHint,
                round: labels.round,
                completed: labels.completed,
                completedSub: labels.completedSub,
                remaining: labels.remaining,
                reset: labels.reset,
              }}
            />
          </div>
          <noscript>
            <section class="min-h-[34rem] sm:min-h-[38rem] rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6 pb-12">
              <h2 class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">
                {labels.flashcards}
              </h2>
              <div class="mt-3 flex min-h-[28rem] sm:min-h-[31rem] items-center justify-center">
                <div class="flex items-start gap-3 rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-2)] p-4">
                  <svg
                    aria-hidden="true"
                    viewBox="0 0 24 24"
                    class="mt-0.5 h-5 w-5 shrink-0 text-[var(--text-subtle)]"
                  >
                    <path
                      d="M12 3 2.5 20h19L12 3Zm0 5v6m0 3h.01"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <p class="text-sm text-[var(--text-body)]">{labels.noScript}</p>
                </div>
              </div>
            </section>
          </noscript>
        </>
      ) : null}
    </>
  ) : null
}

<style is:global>
  html:not(.js) .flashcard-deck-interactive {
    display: none;
  }
</style>
