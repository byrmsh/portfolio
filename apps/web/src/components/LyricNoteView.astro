---
import type { YtMusicAnalysis } from '@portfolio/schema/dashboard';
import LyricFlashcardDeck from './LyricFlashcardDeck.svelte';

interface Props {
  locale: string;
  labels: {
    couldNotLoadNote: string;
    noteLabel: string;
    openTrack: string;
    readLyrics: string;
    updatedAt: string;
    background: string;
    flashcards: string;
    flipHint: string;
    tapHint: string;
    rateHint: string;
    knownHint: string;
    reviewHint: string;
    round: string;
    completed: string;
    completedSub: string;
    remaining: string;
    reset: string;
  };
  analysis: YtMusicAnalysis | null;
  error: string | null;
}

const { locale, labels, analysis, error } = Astro.props;

const format = (template: string, vars: Record<string, string | number>): string =>
  template.replaceAll(/\{(\w+)\}/g, (_, key: string) => String(vars[key] ?? `{${key}}`));
---

{
  error ? (
    <section class="rounded-xl border border-neutral-200 bg-white p-6">
      <h2 class="text-sm font-semibold text-neutral-900">{labels.couldNotLoadNote}</h2>
      <p class="mt-2 text-sm text-neutral-700">{error}</p>
    </section>
  ) : analysis ? (
    <>
      <header class="flex items-start gap-5">
        <div class="w-20 h-20 rounded-xl bg-neutral-900 shrink-0 overflow-hidden">
          {analysis.albumArtUrl ? (
            <img src={analysis.albumArtUrl} alt="" class="w-20 h-20 object-cover" loading="lazy" />
          ) : null}
        </div>
        <div class="min-w-0">
          <div class="text-xs font-bold uppercase tracking-widest text-neutral-400">
            {labels.noteLabel}
          </div>
          <h1 class="mt-2 text-2xl font-semibold text-neutral-900">{analysis.title}</h1>
          <div class="mt-1 text-sm text-neutral-600">{analysis.artist}</div>
          <div class="mt-3 flex flex-wrap gap-2">
            {analysis.trackUrl ? (
              <a
                class="text-xxs font-mono rounded-full border border-neutral-200 px-3 py-1 hover:bg-neutral-50"
                href={analysis.trackUrl}
              >
                {labels.openTrack}
              </a>
            ) : null}
            {analysis.lyricsUrl ? (
              <a
                class="text-xxs font-mono rounded-full border border-neutral-200 px-3 py-1 hover:bg-neutral-50"
                href={analysis.lyricsUrl}
              >
                {labels.readLyrics}
              </a>
            ) : null}
          </div>
          <div class="mt-2 text-xxs font-mono text-neutral-400">
            {format(labels.updatedAt, {
              date: new Date(analysis.updatedAt).toLocaleString(locale),
            })}
          </div>
        </div>
      </header>

      <section class="rounded-xl border border-neutral-200 bg-white p-6">
        <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">
          {labels.background}
        </h2>
        <p class="mt-3 text-sm text-neutral-800 leading-relaxed">{analysis.background.tldr}</p>

        {analysis.background.notes?.length ? (
          <div class="mt-5 grid gap-4">
            {analysis.background.notes.map((n: { title: string; body: string }) => (
              <div class="rounded-lg border border-neutral-200 p-4">
                <div class="text-sm font-semibold text-neutral-900">{n.title}</div>
                <p class="mt-2 text-sm text-neutral-700 leading-relaxed">{n.body}</p>
              </div>
            ))}
          </div>
        ) : null}
      </section>

      {analysis.vocabulary?.length ? (
        <LyricFlashcardDeck
          client:load
          trackId={analysis.id}
          items={analysis.vocabulary}
          labels={{
            title: labels.flashcards,
            flipHint: labels.flipHint,
            tapHint: labels.tapHint,
            rateHint: labels.rateHint,
            knownHint: labels.knownHint,
            reviewHint: labels.reviewHint,
            round: labels.round,
            completed: labels.completed,
            completedSub: labels.completedSub,
            remaining: labels.remaining,
            reset: labels.reset,
          }}
        />
      ) : null}
    </>
  ) : null
}
