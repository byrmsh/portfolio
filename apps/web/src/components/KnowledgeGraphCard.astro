---
import WidgetHeader from './WidgetHeader.astro';

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
}

const { t } = Astro.props;
---

<section
  class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-neutral-200 bg-neutral-900 text-white p-6 relative overflow-hidden"
>
  <div class="relative z-10 flex flex-col h-full justify-between">
    <WidgetHeader title={t('knowledgeGraph.title')} titleClass="text-neutral-500" class="items-start">
      <span
        class="text-xxs font-mono text-neutral-500 border border-neutral-700 px-1.5 py-0.5 rounded"
      >
        {t('knowledgeGraph.source')}
      </span>
    </WidgetHeader>
    <div class="mt-4">
      <div class="text-2xl font-light">{t('knowledgeGraph.nodes', { count: 142 })}</div>
      <p class="text-xs text-neutral-400 mt-1">
        {t('knowledgeGraph.description')}
      </p>
    </div>
  </div>

  <div class="absolute inset-0 opacity-20 pointer-events-none">
    <svg width="100%" height="100%">
      <circle cx="80%" cy="20%" r="3" fill="white"></circle>
      <circle cx="20%" cy="80%" r="3" fill="white"></circle>
      <circle cx="50%" cy="50%" r="2" fill="white"></circle>
      <line x1="20%" y1="80%" x2="50%" y2="50%" stroke="white" stroke-width="0.5"></line>
      <line x1="80%" y1="20%" x2="50%" y2="50%" stroke="white" stroke-width="0.5"></line>
    </svg>
  </div>
</section>
