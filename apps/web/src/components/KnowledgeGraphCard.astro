---
import KnowledgeGraph from './KnowledgeGraph.svelte';
import { buildGraphData } from '../lib/graph-data';
import { getLocaleFromUrl } from '../i18n';

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
  url?: URL;
}

const { t, url } = Astro.props;
const locale = url ? getLocaleFromUrl(url) : 'eng';
const graphData = await buildGraphData(locale);
---

<section
  class="col-span-1 md:col-span-6 lg:col-span-4 min-h-[280px] lg:min-h-[240px] rounded-xl border border-[var(--border-hero)] bg-[var(--surface-hero)] text-[var(--text-hero)] relative overflow-hidden"
>
  <KnowledgeGraph
    client:visible
    graphData={graphData}
    labels={{
      title: t('knowledgeGraph.title'),
      stats: t('knowledgeGraph.stats'),
      fullscreen: t('knowledgeGraph.fullscreen'),
      exitFullscreen: t('knowledgeGraph.exitFullscreen'),
    }}
  />
</section>
