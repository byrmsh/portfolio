---
import KnowledgeGraph from './KnowledgeGraph.svelte';
import { buildGraphData } from '../lib/graph-data';
import { getLocaleFromUrl } from '../i18n';

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
  url?: URL;
}

const { t, url } = Astro.props;
const locale = url ? getLocaleFromUrl(url) : 'eng';
const graphData = await buildGraphData(locale);
---

<section
  class="col-span-1 md:col-span-6 lg:col-span-4 min-h-[280px] lg:min-h-[240px] rounded-xl border border-[var(--border-hero)] bg-[var(--surface-hero)] text-[var(--text-hero)] relative overflow-hidden"
>
  <div class="knowledge-graph-interactive">
    <KnowledgeGraph
      client:visible
      graphData={graphData}
      labels={{
        title: t('knowledge_graph.title'),
        stats: t('knowledge_graph.stats'),
        fullscreen: t('knowledge_graph.fullscreen'),
        exitFullscreen: t('knowledge_graph.exit_fullscreen'),
      }}
    />
  </div>
  <noscript>
    <style>
      .knowledge-graph-interactive {
        display: none;
      }
    </style>
    <div class="absolute inset-0 flex h-full flex-col">
      <div
        class="flex items-center justify-between gap-3 min-h-14 px-6 pt-6 pb-3 bg-[var(--surface)] border-b border-[var(--border-subtle)]"
      >
        <h3 class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">
          {t('knowledge_graph.title')}
        </h3>
      </div>
      <div class="flex flex-1 items-center justify-center p-6">
        <div
          class="w-full max-w-md rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-2)] p-4"
        >
          <div class="flex items-start gap-3">
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              class="mt-0.5 h-5 w-5 shrink-0 text-[var(--text-subtle)]"
            >
              <path
                d="M12 3 2.5 20h19L12 3Zm0 5v6m0 3h.01"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <p class="text-sm text-[var(--text-body)]">{t('knowledge_graph.no_script')}</p>
          </div>
        </div>
      </div>
    </div>
  </noscript>
</section>
