---
import {
  DEFAULT_DATA,
  detailFor,
  dotClass,
  formatCheckedValue,
  labelFor,
  metricClass,
  metricFor,
  normalizePayload,
  serviceNames,
  serviceOrder,
  type SystemHealthStrings,
  type NormalizedPayload,
} from '../lib/system-health';
import WidgetHeader from './WidgetHeader.astro';

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
}

const { t } = Astro.props;
const webOrigin =
  process.env.WEB_ORIGIN ??
  import.meta.env.WEB_ORIGIN ??
  import.meta.env.PUBLIC_WEB_ORIGIN ??
  new URL(Astro.request.url).origin;
const endpoint = import.meta.env.SSR
  ? `${webOrigin.replace(/\/$/, '')}/system-status.json`
  : '/system-status.json';
const strings = {
  notAvailable: t('health.notAvailable'),
  runSingular: t('health.runs.one'),
  runPlural: t('health.runs.other'),
  latencyLabel: t('health.latencyLabel'),
  recencyLabel: t('health.recencyLabel'),
} satisfies SystemHealthStrings;
const servicePills = {
  web: ['Astro', 'Svelte'],
  api: ['Hono'],
  collector: ['Python'],
  lyricist: ['Python', 'LLM'],
  dragonfly: ['Redis API'],
  argocd: ['Kubernetes'],
} as const;

async function loadInitialStatus(): Promise<NormalizedPayload> {
  try {
    const response = await fetch(endpoint, {
      method: 'GET',
      cache: 'no-store',
      headers: { accept: 'application/json' },
    });
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    return normalizePayload((await response.json()) as unknown);
  } catch (e) {
    console.error('SSR Fetch Failed:', e);
    return { data: DEFAULT_DATA, checkedAt: null };
  }
}

const initial = await loadInitialStatus();
---

<section
  data-system-health
  data-client-endpoint="/system-status.json"
  data-initial-checked-at={initial.checkedAt ?? ''}
  data-label-checked-prefix={t('health.checkedPrefix')}
  data-not-available={strings.notAvailable}
  data-run-singular={strings.runSingular}
  data-run-plural={strings.runPlural}
  data-label-latency={strings.latencyLabel}
  data-label-recency={strings.recencyLabel}
  class="col-span-1 rounded-xl border border-neutral-200 bg-white p-6 md:col-span-6 lg:col-span-12"
>
  <WidgetHeader
    title={t('health.title')}
    class="mb-5 flex-wrap gap-y-1"
    titleClass="whitespace-nowrap"
  >
    <span
      data-last-check
      class="ml-auto whitespace-nowrap text-right text-[11px] font-mono tabular-nums uppercase tracking-wide text-neutral-400"
      >{`${t('health.checkedPrefix')}: ${formatCheckedValue(initial.checkedAt)}`}</span
    >
  </WidgetHeader>

  <div class="grid grid-cols-2 gap-6 md:grid-cols-3 xl:grid-cols-6">
    {
      serviceOrder.map((key) => {
        const node = initial.data[key];
        const metric = metricFor(key, node, strings);
        const detail = detailFor(key, node, strings);
        return (
          <article data-service-row={key} class="service-cell min-w-0">
            <h3 class="mb-1 flex items-center gap-1.5 text-[11px] font-mono tracking-wide text-neutral-500">
              <span data-service-dot class:list={['h-2 w-2 rounded-full', dotClass(node.status)]} />
              <span class="truncate">{serviceNames[key]}</span>
            </h3>
            <div class="mb-2 mt-1 flex flex-wrap gap-1">
              {servicePills[key].map((pill) => (
                <span class="rounded-full border border-neutral-200 bg-neutral-50 px-2 py-0.5 text-[10px] font-sans text-neutral-500">
                  {pill}
                </span>
              ))}
            </div>
            <p class:list={['mb-1', metricClass(metric)]} data-service-metric>
              {metric}
            </p>
            <p
              class="text-[11px] font-mono uppercase tracking-wide text-neutral-400"
              data-service-label
            >
              {labelFor(key, strings)}
            </p>
            <p
              class:list={[
                'text-[11px] font-sans text-neutral-500',
                { hidden: detail.length === 0 },
              ]}
              data-service-detail
            >
              {detail}
            </p>
          </article>
        );
      })
    }
  </div>
</section>

<script>
  import {
    asIso,
    detailFor,
    dotClass,
    formatCheckedValue,
    labelFor,
    metricClass,
    metricFor,
    normalizePayload,
    serviceOrder,
    type ServiceKey,
    type StatusNode,
  } from '../lib/system-health';

  const root = document.querySelector<HTMLElement>('[data-system-health]');
  if (!root) throw new Error('System health root not found');

  const endpoint = root.dataset.clientEndpoint ?? '/system-status.json';
  const checkedPrefix = root.dataset.labelCheckedPrefix ?? 'CHECKED';
  const strings = {
    notAvailable: root.dataset.notAvailable ?? '',
    runSingular: root.dataset.runSingular ?? '',
    runPlural: root.dataset.runPlural ?? '',
    latencyLabel: root.dataset.labelLatency ?? '',
    recencyLabel: root.dataset.labelRecency ?? '',
  };

  let lastCheckedAt = asIso(root.dataset.initialCheckedAt ?? null);

  const setCheckedAt = (iso: string | null) => {
    const el = root.querySelector<HTMLElement>('[data-last-check]');
    if (!el) return;
    el.textContent = `${checkedPrefix}: ${formatCheckedValue(iso)}`;
  };

  const setServiceState = (key: ServiceKey, node: StatusNode) => {
    const row = root.querySelector<HTMLElement>(`[data-service-row="${key}"]`);
    if (!row) return;

    const dot = row.querySelector<HTMLElement>('[data-service-dot]');
    if (dot) dot.className = `h-2 w-2 rounded-full ${dotClass(node.status)}`;

    const metric = row.querySelector<HTMLElement>('[data-service-metric]');
    if (metric) {
      const metricValue = metricFor(key, node, strings);
      metric.textContent = metricValue;
      metric.className = `mb-1 ${metricClass(metricValue)}`;
    }

    const label = row.querySelector<HTMLElement>('[data-service-label]');
    if (label) label.textContent = labelFor(key, strings);

    const detail = row.querySelector<HTMLElement>('[data-service-detail]');
    if (detail) {
      const detailValue = detailFor(key, node, strings);
      detail.textContent = detailValue;
      detail.classList.toggle('hidden', detailValue.length === 0);
    }
  };

  const applyPayload = (payload: unknown) => {
    const normalized = normalizePayload(payload);
    for (const key of serviceOrder) {
      setServiceState(key, normalized.data[key]);
    }
    if (normalized.checkedAt) lastCheckedAt = normalized.checkedAt;
    setCheckedAt(lastCheckedAt);
  };

  const refresh = async () => {
    try {
      const response = await fetch(endpoint, {
        method: 'GET',
        cache: 'no-store',
        headers: { accept: 'application/json' },
      });
      if (!response.ok) throw new Error(String(response.status));
      applyPayload((await response.json()) as unknown);
    } catch {
      setCheckedAt(lastCheckedAt);
    }
  };

  if (!lastCheckedAt) refresh();
  window.setInterval(refresh, 30000);
</script>
