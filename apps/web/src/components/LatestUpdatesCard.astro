---
import ArrowUpRight from '@lucide/astro/icons/arrow-up-right';
import { execFileSync } from 'node:child_process';
import { readFileSync } from 'node:fs';
import type { SupportedLocale } from '../i18n';
import WidgetHeader from './WidgetHeader.astro';

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
  locale: SupportedLocale;
  pathFilters?: string[];
  title?: string;
}

type Commit = {
  hash: string;
  shortHash: string;
  author: string;
  authoredAt: string;
  subject: string;
};

type ParsedCommit = {
  type: string;
  scope: string | null;
  description: string;
  breaking: boolean;
};

type GitMetadata = {
  commits: Commit[];
  totalChanges: number;
  repoUrl: string | null;
  pathMetadata?: Record<string, Pick<GitMetadata, 'commits' | 'totalChanges'>>;
};

const { t, locale, pathFilters = [], title } = Astro.props;
const RECENT_LIMIT = 3;
const GIT_METADATA_FILE = process.env.GIT_METADATA_FILE ?? './apps/web/dist/git-meta.json';
const hasPathFilters = pathFilters.length > 0;

function getGitRoot(): string | null {
  try {
    const root = execFileSync('git', ['rev-parse', '--show-toplevel'], { encoding: 'utf8' }).trim();
    return root || null;
  } catch {
    return null;
  }
}

const GIT_ROOT = getGitRoot();

function runGit(args: string[]): string {
  // `pnpm -C apps/web dev` runs the server from `apps/web/`, but the path filters
  // we generate are repo-root relative (e.g. `apps/web/src/...`). Force git to
  // run from the repo root so `git log -- <paths>` resolves consistently.
  const finalArgs = GIT_ROOT ? ['-C', GIT_ROOT, ...args] : args;
  return execFileSync('git', finalArgs, { encoding: 'utf8' }).trim();
}

function getRecentCommits(limit = RECENT_LIMIT, paths: string[] = []): Commit[] {
  try {
    const args = [
      'log',
      '-n',
      String(limit),
      '--date=iso-strict',
      '--pretty=format:%H%x1f%h%x1f%aN%x1f%aI%x1f%s',
    ];
    if (paths.length) args.push('--', ...paths);
    const output = runGit(args);

    if (!output) return [];

    return output
      .split('\n')
      .map((line) => {
        const [hash, shortHash, author, authoredAt, subject] = line.split('\x1f');
        if (!hash || !shortHash || !author || !authoredAt || !subject) return null;
        return { hash, shortHash, author, authoredAt, subject } satisfies Commit;
      })
      .filter((commit): commit is Commit => Boolean(commit));
  } catch {
    return [];
  }
}

function getTotalCommitCount(paths: string[] = []): number {
  try {
    const args = ['rev-list', '--count', 'HEAD'];
    if (paths.length) args.push('--', ...paths);
    const raw = runGit(args);
    const value = Number(raw);
    return Number.isFinite(value) && value >= 0 ? value : 0;
  } catch {
    return 0;
  }
}

function getGitMetadataFromFile(): GitMetadata | null {
  try {
    const raw = readFileSync(GIT_METADATA_FILE, 'utf8');
    const parsed = JSON.parse(raw) as Partial<GitMetadata>;
    const commits = Array.isArray(parsed.commits) ? parsed.commits : [];
    const totalChanges =
      typeof parsed.totalChanges === 'number' && parsed.totalChanges >= 0 ? parsed.totalChanges : 0;
    const repoUrl = typeof parsed.repoUrl === 'string' ? parsed.repoUrl : null;
    const pathMetadata =
      parsed.pathMetadata && typeof parsed.pathMetadata === 'object'
        ? parsed.pathMetadata
        : undefined;
    return { commits, totalChanges, repoUrl, pathMetadata };
  } catch {
    return null;
  }
}

function getPathFilteredMetadata(
  metadata: GitMetadata | null,
  paths: string[],
): Pick<GitMetadata, 'commits' | 'totalChanges'> | null {
  if (!metadata?.pathMetadata || paths.length === 0) return null;
  for (const candidate of paths) {
    const entry = metadata.pathMetadata[candidate];
    if (!entry) continue;
    return entry;
  }
  return null;
}

function normalizeGitHubRepoUrl(remote: string): string | null {
  const trimmed = remote.trim().replace(/\.git$/, '');
  if (!trimmed) return null;

  if (trimmed.startsWith('https://github.com/')) return trimmed;

  if (trimmed.startsWith('git@github.com:')) {
    const path = trimmed.slice('git@github.com:'.length);
    return path ? `https://github.com/${path}` : null;
  }

  if (trimmed.startsWith('ssh://git@github.com/')) {
    const path = trimmed.slice('ssh://git@github.com/'.length);
    return path ? `https://github.com/${path}` : null;
  }

  return null;
}

function getRepoUrlFromOrigin(): string | null {
  try {
    const remote = runGit(['config', '--get', 'remote.origin.url']);
    return normalizeGitHubRepoUrl(remote);
  } catch {
    return null;
  }
}

function parseConventionalSubject(subject: string): ParsedCommit {
  const normalizedSubject = normalizeSubjectForDisplay(subject);
  const match = /^([a-z]+)(\(([^)]+)\))?(!)?:\s*(.+)$/i.exec(normalizedSubject.trim());
  if (!match) {
    return {
      type: 'update',
      scope: null,
      description: capitalizeMessage(normalizedSubject.trim()),
      breaking: false,
    };
  }

  const [, rawType, , scope, bang, rawDescription] = match;
  return {
    type: String(rawType).toLowerCase(),
    scope: scope ?? null,
    description: capitalizeMessage(String(rawDescription).trim()),
    breaking: bang === '!',
  };
}

function normalizeSubjectForDisplay(subject: string): string {
  let normalized = subject.trim().replace(/\b([0-9a-f]{40})\b/gi, (hash) => hash.slice(0, 7));

  const mergeRemoteTrackingMatch = /^Merge remote-tracking branch '([^']+)' into (.+)$/i.exec(
    normalized,
  );
  if (mergeRemoteTrackingMatch) {
    const [, sourceBranch, targetBranch] = mergeRemoteTrackingMatch;
    return `Merge ${sourceBranch.trim()} into ${targetBranch.trim()}`;
  }

  const mergeWithRemoteMatch = /^Merge branch '([^']+)' of \S+ into (.+)$/i.exec(normalized);
  if (mergeWithRemoteMatch) {
    const [, sourceBranch, targetBranch] = mergeWithRemoteMatch;
    return `Merge ${sourceBranch.trim()} into ${targetBranch.trim()}`;
  }

  const mergeBranchMatch = /^Merge branch '([^']+)' into (.+)$/i.exec(normalized);
  if (mergeBranchMatch) {
    const [, sourceBranch, targetBranch] = mergeBranchMatch;
    return `Merge ${sourceBranch.trim()} into ${targetBranch.trim()}`;
  }

  return normalized;
}

function capitalizeMessage(value: string): string {
  if (!value) return value;
  return value.charAt(0).toUpperCase() + value.slice(1);
}

function commitTypeClass(type: string): string {
  const map: Record<string, string> = {
    feat: 'bg-emerald-100 text-emerald-700 border-emerald-300',
    fix: 'bg-amber-100 text-amber-700 border-amber-300',
    docs: 'bg-sky-100 text-sky-700 border-sky-300',
    chore: 'bg-[var(--surface-3)] text-[var(--text-body)] border-[var(--border-strong)]',
    refactor: 'bg-cyan-100 text-cyan-700 border-cyan-300',
    perf: 'bg-lime-100 text-lime-700 border-lime-300',
    test: 'bg-orange-100 text-orange-700 border-orange-300',
    ci: 'bg-indigo-100 text-indigo-700 border-indigo-300',
    build: 'bg-teal-100 text-teal-700 border-teal-300',
    style: 'bg-[var(--surface-3)] text-[var(--text-body)] border-[var(--border-strong)]',
  };

  return map[type] ?? 'bg-[var(--surface-3)] text-[var(--text-body)] border-[var(--border-strong)]';
}

function labelForType(type: string): string {
  const labels: Record<string, string> = {
    feat: t('git_commits.type_feat'),
    fix: t('git_commits.type_fix'),
    docs: t('git_commits.type_docs'),
    chore: t('git_commits.type_chore'),
    refactor: t('git_commits.type_refactor'),
    test: t('git_commits.type_test'),
    perf: t('git_commits.type_perf'),
  };
  return labels[type] ?? type.toUpperCase();
}

const metadata = getGitMetadataFromFile();
const scopedMetadata = hasPathFilters ? getPathFilteredMetadata(metadata, pathFilters) : metadata;
const commits = scopedMetadata?.commits.length
  ? scopedMetadata.commits
  : getRecentCommits(RECENT_LIMIT, pathFilters);
const totalChanges = scopedMetadata
  ? scopedMetadata.totalChanges
  : getTotalCommitCount(pathFilters);
const repoUrl = metadata?.repoUrl ?? getRepoUrlFromOrigin();
const dateFormatter = new Intl.DateTimeFormat(locale, {
  month: 'short',
  day: '2-digit',
  year: 'numeric',
});
---

<section
  class="col-span-1 md:col-span-6 lg:col-span-12 rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6"
>
  <WidgetHeader title={title ?? t('git_commits.title')} class="mb-5">
    <span class="text-xxs font-mono text-[var(--text-muted)] whitespace-nowrap">
      {t('git_commits.total_changes', { value: totalChanges })}
    </span>
  </WidgetHeader>

  {
    commits.length === 0 ? (
      <p class="text-sm text-[var(--text-subtle)]">{t('git_commits.empty')}</p>
    ) : (
      /* PARENT GRID:
      Mobile: 5 Columns (Hash, Bullet, Author, Bullet, Date).
      Desktop: 4 Columns (Hash, Author, Date, Badges).
    */
      <div class="grid grid-cols-[auto_auto_auto_auto_1fr] gap-x-1.5 gap-y-4 md:grid-cols-[auto_auto_1fr_auto] md:gap-x-4 md:gap-y-0">
        {commits.map((commit) => {
          const parsed = parseConventionalSubject(commit.subject);
          return (
            <article class="col-span-full grid grid-cols-subgrid items-baseline gap-y-2 py-1.5 transition-colors hover:bg-[var(--surface-2)] md:gap-y-1 md:px-2">
              {/* BADGES */}
              <div class="col-span-full row-start-1 flex flex-wrap items-center gap-1.5 md:col-span-1 md:col-start-4 md:justify-end">
                <span
                  class:list={[
                    'inline-flex shrink-0 items-center rounded-md border px-1.5 py-0.5 text-[10px] font-bold tracking-wide whitespace-nowrap',
                    commitTypeClass(parsed.type),
                  ]}
                >
                  {labelForType(parsed.type)}
                </span>
                {parsed.scope && (
                  <span class="inline-flex shrink-0 items-center rounded-md border border-[var(--border-strong)] bg-[var(--surface)] px-1.5 py-0.5 text-[10px] font-mono text-[var(--text-body)] whitespace-nowrap">
                    {parsed.scope}
                  </span>
                )}
                {parsed.breaking && (
                  <span class="inline-flex shrink-0 items-center rounded-md border border-rose-300 bg-rose-100 px-1.5 py-0.5 text-[10px] font-bold text-rose-800 whitespace-nowrap">
                    {t('git_commits.breaking')}
                  </span>
                )}
              </div>

              {/* DESCRIPTION */}
              <p class="col-span-full row-start-2 mb-0 break-words font-sans text-sm font-medium leading-snug text-[var(--text-body)] md:col-span-3 md:col-start-1 md:row-start-1 md:mb-0">
                {parsed.description}
              </p>

              {/* METADATA: HASH */}
              <div class="col-start-1 row-start-3 flex items-baseline gap-1.5 md:col-start-1 md:row-start-2">
                <span class="hidden font-mono text-[11px] uppercase tracking-wide text-[var(--text-muted)] md:inline">
                  {t('git_commits.hash')}:
                </span>
                <code
                  class="text-xs font-mono text-[var(--text-primary)] md:text-[11px] md:text-[var(--text-body)]"
                  title={commit.hash}
                >
                  {commit.shortHash}
                </code>
                {repoUrl && (
                  <a
                    href={`${repoUrl}/commit/${commit.hash}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="self-center inline-flex text-[var(--text-muted)] transition-colors hover:text-[var(--text-body)]"
                    aria-label={t('git_commits.open_commit', { hash: commit.shortHash })}
                    title={t('git_commits.open_commit', { hash: commit.shortHash })}
                  >
                    <ArrowUpRight class="w-3.5 h-3.5" />
                  </a>
                )}
              </div>

              {/* MOBILE BULLET 1 */}
              <span
                class="col-start-2 row-start-3 px-0.5 text-xs text-[var(--text-muted)] md:hidden"
                aria-hidden="true"
              >
                •
              </span>

              {/* METADATA: AUTHOR */}
              <div class="col-start-3 row-start-3 flex items-baseline gap-1.5 min-w-0 md:col-start-2 md:row-start-2">
                <span class="hidden font-mono text-[11px] uppercase tracking-wide text-[var(--text-muted)] md:inline">
                  {t('git_commits.author')}:
                </span>
                <span class="truncate text-xs font-mono text-[var(--text-primary)] md:overflow-visible md:font-sans md:text-[var(--text-body)]">
                  {commit.author}
                </span>
              </div>

              {/* MOBILE BULLET 2 */}
              <span
                class="col-start-4 row-start-3 px-0.5 text-xs text-[var(--text-muted)] md:hidden"
                aria-hidden="true"
              >
                •
              </span>

              {/* METADATA: DATE */}
              <div class="col-start-5 row-start-3 flex items-baseline gap-1.5 md:col-start-3 md:row-start-2">
                <span class="hidden font-mono text-[11px] uppercase tracking-wide text-[var(--text-muted)] md:inline">
                  {t('git_commits.date')}:
                </span>
                <time
                  class="whitespace-nowrap text-xs font-mono text-[var(--text-primary)] md:font-sans md:text-[var(--text-body)]"
                  datetime={commit.authoredAt}
                >
                  {dateFormatter.format(new Date(commit.authoredAt))}
                </time>
              </div>
            </article>
          );
        })}
      </div>
    )
  }
</section>
