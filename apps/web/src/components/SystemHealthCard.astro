---
interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
}

type ServiceStatus = 'healthy' | 'partial' | 'degraded' | 'unknown';
type ServiceKey = 'web' | 'api' | 'dragonfly' | 'collector' | 'upworker';

type StatusNode = {
  status: ServiceStatus;
  latency?: number;
  runs?: number;
  message: string;
  meta?: string;
};

type ApiStatusResponse = {
  web: StatusNode;
  api: StatusNode;
  dragonfly: StatusNode;
  collector: StatusNode;
  upworker: StatusNode;
};

type NormalizedPayload = {
  checkedAt: string | null;
  data: ApiStatusResponse;
};

const { t } = Astro.props;

const endpoint = new URL('/system-status.json', Astro.url).toString();

const serviceNames: Record<ServiceKey, string> = {
  web: 'apps/web',
  api: 'apps/api',
  dragonfly: 'dragonfly',
  collector: 'apps/collector',
  upworker: 'apps/upworker',
};
const serviceTech: Record<ServiceKey, string> = {
  web: 'Portfolio frontend (Astro)',
  api: 'Portfolio backend API (Hono)',
  collector: 'Personal data collectors',
  upworker: 'Upwork ingestion worker',
  dragonfly: 'Redis-compatible KV store',
};

const serviceOrder: ServiceKey[] = ['web', 'api', 'collector', 'upworker', 'dragonfly'];

const DEFAULT_DATA: ApiStatusResponse = {
  web: { status: 'unknown', message: '' },
  api: { status: 'unknown', message: '' },
  dragonfly: { status: 'unknown', message: '' },
  collector: { status: 'unknown', message: '', runs: 0, meta: '' },
  upworker: { status: 'unknown', message: '', runs: 0, meta: '' },
};

function asStatus(value: unknown): ServiceStatus {
  return value === 'healthy' || value === 'partial' || value === 'degraded' ? value : 'unknown';
}

function asCount(value: unknown): number {
  if (typeof value !== 'number' || !Number.isFinite(value)) return 0;
  return Math.max(0, Math.floor(value));
}

function asText(value: unknown, fallback: string): string {
  return typeof value === 'string' && value.trim().length > 0 ? value : fallback;
}

function asIso(value: unknown): string | null {
  if (typeof value !== 'string') return null;
  return Number.isNaN(Date.parse(value)) ? null : value;
}

function extractSourceFromMeta(meta: string, source: 'github' | 'anki'): string {
  const pattern = source === 'github' ? /github\s+([^•]+)/i : /anki\s+([^•]+)/i;
  const match = pattern.exec(meta);
  if (!match) return '--';
  return match[1].replace(/ago/gi, '').trim() || '--';
}

function collectorMetric(meta: string): string {
  const github = extractSourceFromMeta(meta, 'github');
  const anki = extractSourceFromMeta(meta, 'anki');
  if (github !== '--') return github;
  if (anki !== '--') return anki;
  return 'N/A';
}

function parseCheckedAt(payload: unknown): string | null {
  if (!payload || typeof payload !== 'object') return null;
  const direct = payload as { checkedAt?: unknown; data?: { checkedAt?: unknown; timestamp?: unknown }; meta?: { ts?: unknown } };
  return (
    asIso(direct.checkedAt) ??
    asIso(direct.data?.checkedAt) ??
    asIso(direct.data?.timestamp) ??
    asIso(direct.meta?.ts) ??
    null
  );
}

function latestUpdatedAtFromChecks(service: Record<string, unknown> | undefined): string | null {
  const checks = service?.checks;
  if (!Array.isArray(checks)) return null;
  for (const check of checks) {
    if (!check || typeof check !== 'object') continue;
    const updatedAt = (check as { updatedAt?: unknown }).updatedAt;
    if (typeof updatedAt === 'string' && updatedAt.length > 0) return updatedAt;
  }
  return null;
}

function updatedAtForCheck(service: Record<string, unknown> | undefined, checkId: string): string | null {
  const checks = service?.checks;
  if (!Array.isArray(checks)) return null;
  for (const check of checks) {
    if (!check || typeof check !== 'object') continue;
    const id = (check as { id?: unknown }).id;
    const updatedAt = (check as { updatedAt?: unknown }).updatedAt;
    if (id === checkId && typeof updatedAt === 'string' && updatedAt.length > 0) return updatedAt;
  }
  return null;
}

function ageMetricFromIso(value: string | null): string {
  if (!value) return 'N/A';
  const ts = Date.parse(value);
  if (Number.isNaN(ts)) return 'N/A';
  const ageMs = Math.max(0, Date.now() - ts);
  const minutes = Math.floor(ageMs / 60000);
  if (minutes < 60) return `${Math.max(1, minutes)}m`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h`;
  return `${Math.floor(hours / 24)}d`;
}

function collectorMetaFromChecks(service: Record<string, unknown> | undefined): string {
  const githubAge = ageMetricFromIso(updatedAtForCheck(service, 'github'));
  const ankiAge = ageMetricFromIso(updatedAtForCheck(service, 'anki'));
  return `GitHub ${githubAge === 'N/A' ? '--' : githubAge} • Anki ${ankiAge === 'N/A' ? '--' : ankiAge}`;
}

function sourceFromPayload(payload: unknown): Partial<Record<ServiceKey, Partial<StatusNode>>> {
  if (!payload || typeof payload !== 'object') return {};
  const direct = payload as Partial<Record<ServiceKey, Partial<StatusNode>>> & {
    upworker?: Partial<StatusNode> & { lastFetchedAt?: unknown };
  };
  if (direct.web || direct.api || direct.dragonfly || direct.collector || direct.upworker) {
    const upworkerLastFetchedAt = asIso(direct.upworker?.lastFetchedAt);
    if (upworkerLastFetchedAt) {
      direct.upworker = {
        ...direct.upworker,
        meta: ageMetricFromIso(upworkerLastFetchedAt),
      };
    }
    return direct;
  }

  const services = (payload as { data?: { services?: Array<Record<string, unknown>> } })?.data?.services;
  if (!Array.isArray(services)) return {};

  const byId = Object.fromEntries(
    services
      .filter((service) => typeof service?.id === 'string')
      .map((service) => [String(service.id), service]),
  ) as Record<string, Record<string, unknown>>;

  const runsFromChecks = (service: Record<string, unknown> | undefined): number => {
    const checks = service?.checks;
    if (!Array.isArray(checks)) return 0;
    return checks.filter((check) => {
      if (!check || typeof check !== 'object') return false;
      const updatedAt = (check as { updatedAt?: unknown }).updatedAt;
      return typeof updatedAt === 'string' && updatedAt.length > 0;
    }).length;
  };

  return {
    web: {
      status: asStatus(byId.web?.status),
      latency: asCount(byId.web?.latencyMs),
      message: asText(byId.web?.detail, ''),
    },
    api: {
      status: asStatus(byId.api?.status),
      latency: asCount(byId.api?.latencyMs),
      message: asText(byId.api?.detail, ''),
    },
    dragonfly: {
      status: asStatus(byId.db?.status),
      latency: asCount(byId.db?.latencyMs),
      message: asText(byId.db?.detail, ''),
    },
    collector: {
      status: asStatus(byId.collector?.status),
      runs: runsFromChecks(byId.collector),
      message: asText(byId.collector?.detail, ''),
      meta: collectorMetaFromChecks(byId.collector),
    },
    upworker: {
      status: asStatus(byId.upworker?.status),
      runs: runsFromChecks(byId.upworker),
      message: asText(byId.upworker?.detail, ''),
      meta: ageMetricFromIso(latestUpdatedAtFromChecks(byId.upworker)),
    },
  };
}

function normalizeStatus(source: Partial<Record<ServiceKey, Partial<StatusNode>>>): ApiStatusResponse {
  const pick = (key: ServiceKey): StatusNode => {
    const fallback = DEFAULT_DATA[key];
    const raw = source[key] ?? {};
    return {
      status: asStatus(raw.status ?? fallback.status),
      latency: asCount(raw.latency ?? fallback.latency ?? 0),
      runs: asCount(raw.runs ?? fallback.runs ?? 0),
      message: asText(raw.message, fallback.message),
      meta: asText(raw.meta, fallback.meta ?? ''),
    };
  };

  return {
    web: pick('web'),
    api: pick('api'),
    dragonfly: pick('dragonfly'),
    collector: pick('collector'),
    upworker: pick('upworker'),
  };
}

function normalizePayload(payload: unknown): NormalizedPayload {
  return {
    checkedAt: parseCheckedAt(payload),
    data: normalizeStatus(sourceFromPayload(payload)),
  };
}

function dotClass(status: ServiceStatus): string {
  return status === 'healthy' ? 'bg-emerald-500' : 'bg-rose-500';
}

function metricFor(key: ServiceKey, node: StatusNode): string {
  if (key === 'collector') return collectorMetric(asText(node.meta, ''));
  if (key === 'upworker') {
    const freshness = asText(node.meta, 'N/A');
    if (freshness !== 'N/A') return freshness;
    const runs = asCount(node.runs);
    return runs > 0 ? `${runs} run${runs === 1 ? '' : 's'}` : 'N/A';
  }
  const latency = asCount(node.latency);
  return latency > 0 ? `${latency}ms` : 'N/A';
}

function metricClass(value: string): string {
  const base = 'min-h-[2.25rem] flex items-end';
  return /\d/.test(value)
    ? `${base} text-3xl font-mono font-medium text-neutral-900`
    : `${base} text-xl font-mono font-medium uppercase tracking-wide text-neutral-300`;
}

function labelFor(key: ServiceKey): string {
  if (key === 'collector' || key === 'upworker') return 'RECENCY';
  return 'LATENCY';
}

function detailFor(key: ServiceKey, node: StatusNode): string {
  if (key === 'upworker') return /active/i.test(node.message) ? 'Jobs stream active' : '';
  return '';
}

function formatCheckedValue(checkedAt: string | null): string {
  if (!checkedAt) return '--:--:--';
  const date = new Date(checkedAt);
  if (Number.isNaN(date.getTime())) return '--:--:--';
  return new Intl.DateTimeFormat('en-GB', {
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: false,
  }).format(date);
}

async function loadInitialStatus(): Promise<NormalizedPayload> {
  try {
    const response = await fetch(endpoint, {
      method: 'GET',
      cache: 'no-store',
      headers: { accept: 'application/json' },
    });
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    const payload = normalizePayload((await response.json()) as unknown);
    return { data: payload.data, checkedAt: payload.checkedAt };
  } catch (e) {
    console.error('SSR Fetch Failed:', e);
    return { data: DEFAULT_DATA, checkedAt: null };
  }
}

const initial = await loadInitialStatus();
---

<section
  data-system-health
  data-client-endpoint="/system-status.json"
  data-initial-checked-at={initial.checkedAt ?? ''}
  data-label-checked-prefix={t('health.checkedPrefix')}
  class="col-span-1 rounded-xl border border-neutral-200 bg-white p-6 md:col-span-6 lg:col-span-12"
>
  <div class="mb-5 flex items-center justify-between gap-3">
    <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-neutral-500">Live Infrastructure</h2>
    <span
      data-last-check
      class="w-[18ch] text-right text-[11px] font-mono tabular-nums uppercase tracking-wide text-neutral-400"
      >{`${t('health.checkedPrefix')}: ${formatCheckedValue(initial.checkedAt)}`}</span
    >
  </div>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-5">
    {
      serviceOrder.map((key) => {
        const node = initial.data[key];
        const metric = metricFor(key, node);
        const detail = detailFor(key, node);
        return (
          <article data-service-row={key} class="min-w-0">
            <h3 class="mb-1 flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-[0.12em] text-neutral-500">
              <span data-service-dot class:list={['h-2 w-2 rounded-full', dotClass(node.status)]}></span>
              <span class="truncate">{serviceNames[key]}</span>
            </h3>
            <p class="mb-2 min-h-[1rem] text-[11px] font-sans text-neutral-500">{serviceTech[key]}</p>
            <p class:list={['mb-1', metricClass(metric)]} data-service-metric>
              {metric}
            </p>
            <p class="text-[11px] font-mono uppercase tracking-wide text-neutral-400" data-service-label>
              {labelFor(key)}
            </p>
            <p class:list={['text-[11px] font-sans text-neutral-500', { hidden: detail.length === 0 }]} data-service-detail>
              {detail}
            </p>
          </article>
        );
      })
    }
  </div>
</section>

<script is:inline type="module">
  const root = document.querySelector('[data-system-health]');
  if (!root) throw new Error('System health root not found');

  const endpoint = root.dataset.clientEndpoint ?? '/api/status';
  const checkedPrefix = root.dataset.labelCheckedPrefix ?? 'CHECKED';

  const dotClass = (status) => (status === 'healthy' ? 'bg-emerald-500' : 'bg-rose-500');

  const asStatus = (value) =>
    value === 'healthy' || value === 'partial' || value === 'degraded' ? value : 'unknown';

  const asCount = (value) => {
    if (typeof value !== 'number' || !Number.isFinite(value)) return 0;
    return Math.max(0, Math.floor(value));
  };

  const asText = (value, fallback) =>
    typeof value === 'string' && value.trim().length > 0 ? value : fallback;

  const asIso = (value) => {
    if (typeof value !== 'string') return null;
    return Number.isNaN(Date.parse(value)) ? null : value;
  };

  const extractSourceFromMeta = (meta, source) => {
    const pattern = source === 'github' ? /github\s+([^•]+)/i : /anki\s+([^•]+)/i;
    const match = pattern.exec(meta);
    if (!match) return '--';
    return String(match[1] ?? '').replace(/ago/gi, '').trim() || '--';
  };

  const collectorMetric = (meta) => {
    const github = extractSourceFromMeta(meta, 'github');
    const anki = extractSourceFromMeta(meta, 'anki');
    if (github !== '--') return github;
    if (anki !== '--') return anki;
    return 'N/A';
  };

  const parseCheckedAt = (payload) =>
    asIso(payload?.checkedAt) ?? asIso(payload?.data?.checkedAt) ?? asIso(payload?.data?.timestamp) ?? asIso(payload?.meta?.ts) ?? null;

  const latestUpdatedAtFromChecks = (service) => {
    const checks = service?.checks;
    if (!Array.isArray(checks)) return null;
    for (const check of checks) {
      if (typeof check?.updatedAt === 'string' && check.updatedAt.length > 0) return check.updatedAt;
    }
    return null;
  };

  const updatedAtForCheck = (service, checkId) => {
    const checks = service?.checks;
    if (!Array.isArray(checks)) return null;
    for (const check of checks) {
      if (check?.id === checkId && typeof check?.updatedAt === 'string' && check.updatedAt.length > 0) {
        return check.updatedAt;
      }
    }
    return null;
  };

  const ageMetricFromIso = (value) => {
    if (!value) return 'N/A';
    const ts = Date.parse(value);
    if (Number.isNaN(ts)) return 'N/A';
    const ageMs = Math.max(0, Date.now() - ts);
    const minutes = Math.floor(ageMs / 60000);
    if (minutes < 60) return `${Math.max(1, minutes)}m`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h`;
    return `${Math.floor(hours / 24)}d`;
  };

  const collectorMetaFromChecks = (service) => {
    const githubAge = ageMetricFromIso(updatedAtForCheck(service, 'github'));
    const ankiAge = ageMetricFromIso(updatedAtForCheck(service, 'anki'));
    return `GitHub ${githubAge === 'N/A' ? '--' : githubAge} • Anki ${ankiAge === 'N/A' ? '--' : ankiAge}`;
  };

  let lastCheckedAt = asIso(root.dataset.initialCheckedAt ?? null);
  const defaultData = {
    web: { status: 'unknown', message: '' },
    api: { status: 'unknown', message: '' },
    dragonfly: { status: 'unknown', message: '' },
    collector: { status: 'unknown', message: '', runs: 0, meta: '' },
    upworker: { status: 'unknown', message: '', runs: 0, meta: '' },
  };

  const sourceFromPayload = (payload) => {
    if (!payload || typeof payload !== 'object') return {};
    if (payload.web || payload.api || payload.dragonfly || payload.collector || payload.upworker) {
      const upworkerLastFetchedAt = asIso(payload?.upworker?.lastFetchedAt);
      if (upworkerLastFetchedAt) {
        payload.upworker = {
          ...payload.upworker,
          meta: ageMetricFromIso(upworkerLastFetchedAt),
        };
      }
      return payload;
    }

    const services = payload?.data?.services;
    if (!Array.isArray(services)) return {};

    const byId = Object.fromEntries(
      services
        .filter((service) => service && typeof service.id === 'string')
        .map((service) => [String(service.id), service]),
    );

    const runsFromChecks = (service) => {
      const checks = service?.checks;
      if (!Array.isArray(checks)) return 0;
      return checks.filter((check) => typeof check?.updatedAt === 'string' && check.updatedAt.length > 0)
        .length;
    };

    return {
      web: { status: byId.web?.status, latency: byId.web?.latencyMs, message: byId.web?.detail },
      api: { status: byId.api?.status, latency: byId.api?.latencyMs, message: byId.api?.detail },
      dragonfly: { status: byId.db?.status, latency: byId.db?.latencyMs, message: byId.db?.detail },
      collector: {
        status: byId.collector?.status,
        runs: runsFromChecks(byId.collector),
        message: byId.collector?.detail,
        meta: collectorMetaFromChecks(byId.collector),
      },
      upworker: {
        status: byId.upworker?.status,
        runs: runsFromChecks(byId.upworker),
        message: byId.upworker?.detail,
        meta: ageMetricFromIso(latestUpdatedAtFromChecks(byId.upworker)),
      },
    };
  };

  const normalizeStatus = (source) => {
    const pick = (key) => {
      const base = defaultData[key] ?? {};
      const raw = source[key] && typeof source[key] === 'object' ? source[key] : {};
      return {
        status: asStatus(raw.status ?? base.status ?? 'unknown'),
        latency: asCount(raw.latency ?? base.latency ?? 0),
        runs: asCount(raw.runs ?? base.runs ?? 0),
        message: asText(raw.message, base.message ?? ''),
        meta: asText(raw.meta, base.meta ?? ''),
      };
    };

    return {
      web: pick('web'),
      api: pick('api'),
      dragonfly: pick('dragonfly'),
      collector: pick('collector'),
      upworker: pick('upworker'),
    };
  };

  const metricFor = (key, node) => {
    if (key === 'collector') return collectorMetric(asText(node?.meta, ''));
    if (key === 'upworker') {
      const freshness = asText(node?.meta, 'N/A');
      if (freshness !== 'N/A') return freshness;
      const runs = asCount(node?.runs);
      return runs > 0 ? `${runs} run${runs === 1 ? '' : 's'}` : 'N/A';
    }
    const latency = asCount(node?.latency);
    return latency > 0 ? `${latency}ms` : 'N/A';
  };

  const metricClass = (value) =>
    /\d/.test(String(value ?? ''))
      ? 'mb-1 min-h-[2.25rem] flex items-end text-3xl font-mono font-medium text-neutral-900'
      : 'mb-1 min-h-[2.25rem] flex items-end text-xl font-mono font-medium uppercase tracking-wide text-neutral-300';

  const labelFor = (key) => {
    if (key === 'collector' || key === 'upworker') return 'RECENCY';
    return 'LATENCY';
  };

  const detailFor = (key, node) => {
    if (key === 'upworker') return /active/i.test(asText(node?.message, '')) ? 'Jobs stream active' : '';
    return '';
  };

  const formatCheckedValue = (iso) => {
    if (!iso) return '--:--:--';
    const date = new Date(iso);
    if (Number.isNaN(date.getTime())) return '--:--:--';
    return new Intl.DateTimeFormat('en-GB', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false,
    }).format(date);
  };

  const setCheckedAt = (iso) => {
    const el = root.querySelector('[data-last-check]');
    if (!el) return;
    el.textContent = `${checkedPrefix}: ${formatCheckedValue(iso)}`;
  };

  const setServiceState = (key, node) => {
    const row = root.querySelector(`[data-service-row="${key}"]`);
    if (!row) return;

    const dot = row.querySelector('[data-service-dot]');
    if (dot) dot.className = `h-2 w-2 rounded-full ${dotClass(asStatus(node?.status))}`;

    const metric = row.querySelector('[data-service-metric]');
    if (metric) {
      const metricValue = metricFor(key, node ?? {});
      metric.textContent = metricValue;
      metric.className = metricClass(metricValue);
    }

    const label = row.querySelector('[data-service-label]');
    if (label) label.textContent = labelFor(key);

    const detail = row.querySelector('[data-service-detail]');
    if (detail) {
      const detailValue = detailFor(key, node ?? {});
      detail.textContent = detailValue;
      detail.classList.toggle('hidden', detailValue.length === 0);
    }
  };

  const applyPayload = (payload) => {
    const source = sourceFromPayload(payload);
    const data = normalizeStatus(source);
    for (const key of ['web', 'api', 'dragonfly', 'collector', 'upworker']) {
      setServiceState(key, data[key]);
    }
    const nextCheckedAt = parseCheckedAt(payload);
    if (nextCheckedAt) lastCheckedAt = nextCheckedAt;
    setCheckedAt(lastCheckedAt);
  };

  const refresh = async () => {
    try {
      const response = await fetch(endpoint, {
        method: 'GET',
        cache: 'no-store',
        headers: { accept: 'application/json' },
      });
      if (!response.ok) throw new Error(String(response.status));
      const payload = await response.json();
      applyPayload(payload);
    } catch {
      setCheckedAt(lastCheckedAt);
    }
  };

  const pollMs = 30000;
  if (!lastCheckedAt) refresh();
  window.setInterval(refresh, pollMs);
</script>
