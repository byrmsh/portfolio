---
interface Props {
	eyebrow?: string
	title?: string
	subtitle?: string
}

const {
	eyebrow = 'Portfolio',
	title = 'Bayram Şahin',
	subtitle = 'A living portfolio that runs the work it presents.',
}: Props = Astro.props
---

<header class="flex flex-col gap-4">
	<p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-500">{eyebrow}</p>
	<h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">{title}</h1>
	<p class="max-w-2xl text-base text-neutral-600 sm:text-lg">{subtitle}</p>
</header>
