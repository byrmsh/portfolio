---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props extends astroHTML.JSX.HTMLAttributes {
  src: ImageMetadata;
  alt: string;
  loading?: 'lazy' | 'eager';
  widths?: number[];
  sizes?: string;
}

const { src, alt, class: className, loading = 'lazy', widths, sizes, ...attrs } = Astro.props;

const placeholder = await getImage({ src, width: 32, quality: 20, format: 'webp' });
---

<div class:list={[className]} data-blur-image {...attrs}>
  <img src={placeholder.src} alt="" aria-hidden="true" class="blur-image-placeholder" />
  <Image
    src={src}
    alt={alt}
    loading={loading}
    widths={widths ?? [400, 800, 1200]}
    sizes={sizes ?? '(max-width: 1024px) 100vw, 560px'}
    class="blur-image-full"
    data-blur-full
  />
</div>

<style>
  .blur-image-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(20px);
    transform: scale(1.1);
    z-index: 1;
    transition: opacity 0.4s ease;
  }

  [data-blur-image] :global(.blur-image-full) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  [data-blur-image].is-loaded :global(.blur-image-full) {
    opacity: 1;
  }

  [data-blur-image].is-loaded .blur-image-placeholder {
    opacity: 0;
  }
</style>

<script>
  function initBlurImages() {
    const wraps = document.querySelectorAll<HTMLElement>('[data-blur-image]');
    for (const wrap of wraps) {
      if (wrap.classList.contains('is-loaded')) continue;
      const img = wrap.querySelector<HTMLImageElement>('[data-blur-full]');
      if (!img) continue;
      if (img.complete && img.naturalWidth > 0) {
        wrap.classList.add('is-loaded');
      } else {
        img.addEventListener('load', () => wrap.classList.add('is-loaded'), { once: true });
      }
    }
  }
  initBlurImages();
  document.addEventListener('astro:page-load', initBlurImages);
</script>
