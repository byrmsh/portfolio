---
interface Props {
  title?: string;
}

const { title = 'System Notes' }: Props = Astro.props;
---

<div class="rounded-xl border border-neutral-200 bg-white p-6">
  <h2 class="text-lg font-semibold">{title}</h2>
  <p class="mt-2 text-sm text-neutral-600">
    This dashboard is wired to the same services it documents. Every metric is a contract, every
    deployment a log entry. When the API is live, this panel becomes a live feed.
  </p>
  <div class="mt-4 grid gap-2 text-xs uppercase tracking-[0.25em] text-neutral-500">
    <span>Latency budget: 250ms</span>
    <span>Build target: static + islands</span>
    <span>Telemetry: /api/status</span>
  </div>
</div>
