---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import ky from 'ky';
import { localizedPath, type SupportedLocale } from '../i18n';
import WidgetHeader from './WidgetHeader.astro';

type SavedLyricNote = {
  id: string;
  title: string;
  artist: string;
  noteUrl: string;
  albumArtUrl?: string | null;
  savedAt: string;
};

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
  locale: SupportedLocale;
}

const { t, locale } = Astro.props;
const localeMap: Record<SupportedLocale, string> = {
  eng: 'en-US',
  dev: 'en-US',
};
const displayLocale = localeMap[locale];

const apiOrigin =
  process.env.API_ORIGIN ??
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

let saved: SavedLyricNote | null = null;
let lyricistLastSuccessAt: string | null = null;
try {
  const json = await ky
    .get(`${apiOrigin}/api/ytmusic/saved/latest`, {
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: SavedLyricNote | null }>();
  if (json?.data) saved = json.data;
} catch {
  saved = null;
}

try {
  const status = await ky
    .get(`${apiOrigin}/api/status`, {
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{
      data?: {
        lyricist?: {
          lastSuccessAt?: string | null;
        };
      };
    }>();
  lyricistLastSuccessAt = status?.data?.lyricist?.lastSuccessAt ?? null;
} catch {
  lyricistLastSuccessAt = null;
}

function formatSyncedAt(value: string | null): string {
  if (!value) return '--';
  const ts = Date.parse(value);
  if (Number.isNaN(ts)) return '--';

  const syncedAt = new Date(ts);
  const now = new Date();
  const isToday =
    syncedAt.getFullYear() === now.getFullYear() &&
    syncedAt.getMonth() === now.getMonth() &&
    syncedAt.getDate() === now.getDate();

  if (isToday) {
    return new Intl.DateTimeFormat(displayLocale, {
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    }).format(syncedAt);
  }

  return new Intl.DateTimeFormat(displayLocale, {
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  }).format(syncedAt);
}

const noteHref = saved?.id
  ? localizedPath(locale, `/playlist/${encodeURIComponent(saved.id)}`)
  : null;
const syncedValue = formatSyncedAt(lyricistLastSuccessAt);
---

<section
  data-saved-lyrics
  data-synced-at={lyricistLastSuccessAt ?? ''}
  data-synced-template={t('playlist.synced_at', { value: '{value}' })}
  data-display-locale={displayLocale}
  class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6 flex flex-col relative overflow-hidden group"
>
  <div class="relative z-10">
    <WidgetHeader title={t('playlist.title')} class="mb-6">
      <span
        data-synced-value
        class="text-xxs font-mono text-[var(--text-muted)] whitespace-nowrap"
        aria-label={t('playlist.synced_at', { value: '' })}
      >
        {t('playlist.synced_at', { value: syncedValue })}
      </span>
    </WidgetHeader>
    <div class="flex gap-4">
      <div
        class="w-16 h-16 bg-[var(--surface-inverse)] rounded-md shadow-sm flex items-center justify-center shrink-0"
      >
        {
          saved?.albumArtUrl ? (
            <img
              src={saved.albumArtUrl}
              alt=""
              class="w-16 h-16 rounded-md object-cover"
              loading="lazy"
            />
          ) : (
            <div class="w-6 h-6 rounded-full border-2 border-[var(--border-inverse)]" />
          )
        }
      </div>
      <div class="min-w-0 flex flex-1 flex-col justify-center">
        <div class="truncate text-sm font-semibold text-[var(--text-primary)]">
          {saved?.title ?? t('playlist.no_tracks')}
        </div>
        <div class="mt-1 truncate text-xs text-[var(--text-subtle)]">{saved?.artist ?? ''}</div>
        {
          noteHref ? (
            <a
              href={noteHref}
              class="group/cta mt-2 inline-flex items-center gap-1 text-xxs font-mono uppercase tracking-[0.1em] text-[var(--text-subtle)] transition-colors hover:text-[var(--text-primary)] focus-visible:text-[var(--text-primary)]"
            >
              <span>{t('playlist.lyrics_details')}</span>
              <ArrowRight class="w-3 h-3 transition-transform group-hover/cta:translate-x-0.5 group-focus-visible/cta:translate-x-0.5" />
            </a>
          ) : null
        }
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-saved-lyrics]');
  if (root) {
    const syncedEl = root.querySelector<HTMLElement>('[data-synced-value]');
    const value = root.dataset.syncedAt ?? '';
    const syncedTemplate = root.dataset.syncedTemplate ?? 'SYNCED: {value}';
    const locale = root.dataset.displayLocale ?? 'en-US';

    const formatSyncedLocal = (raw: string): string => {
      if (!raw) return '--';
      const ts = Date.parse(raw);
      if (Number.isNaN(ts)) return '--';
      const syncedAt = new Date(ts);
      const now = new Date();
      const isToday =
        syncedAt.getFullYear() === now.getFullYear() &&
        syncedAt.getMonth() === now.getMonth() &&
        syncedAt.getDate() === now.getDate();

      const time = new Intl.DateTimeFormat(locale, {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
      }).format(syncedAt);
      const datePrefix = isToday
        ? ''
        : `${new Intl.DateTimeFormat(locale, { month: 'short', day: 'numeric' }).format(syncedAt)} `;

      return `${datePrefix}${time}`;
    };

    if (syncedEl)
      syncedEl.textContent = syncedTemplate.replace('{value}', formatSyncedLocal(value));
  }
</script>
