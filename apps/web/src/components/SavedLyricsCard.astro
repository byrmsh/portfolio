---
import Disc from '@lucide/astro/icons/disc';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import ky from 'ky';
import { localizedPath, type SupportedLocale } from '../i18n';
import WidgetHeader from './WidgetHeader.astro';

type SavedLyricNote = {
  id: string;
  title: string;
  artist: string;
  noteUrl: string;
  albumArtUrl?: string | null;
  savedAt: string;
};

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
  locale: SupportedLocale;
}

const { t, locale } = Astro.props;

const apiOrigin =
  process.env.API_ORIGIN ??
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

let saved: SavedLyricNote | null = null;
try {
  const json = await ky
    .get(`${apiOrigin}/api/ytmusic/saved/latest`, {
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: SavedLyricNote | null }>();
  if (json?.data) saved = json.data;
} catch {
  saved = null;
}

const noteHref = saved?.id
  ? localizedPath(locale, `/lyrics/${encodeURIComponent(saved.id)}`)
  : null;
---

<section
  class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-neutral-200 bg-white p-6 flex flex-col relative overflow-hidden group"
>
  <div class="relative z-10">
    <WidgetHeader title={t('savedLyrics.title')} class="mb-6 items-start">
      <Disc class="w-4 h-4 text-neutral-400" />
    </WidgetHeader>
    <div class="flex gap-4">
      <div
        class="w-16 h-16 bg-neutral-900 rounded-md shadow-sm flex items-center justify-center shrink-0"
      >
        {
          saved?.albumArtUrl ? (
            <img
              src={saved.albumArtUrl}
              alt=""
              class="w-16 h-16 rounded-md object-cover"
              loading="lazy"
            />
          ) : (
            <div class="w-6 h-6 rounded-full border-2 border-neutral-700" />
          )
        }
      </div>
      <div class="flex flex-col justify-center">
        <div class="text-sm font-semibold text-neutral-900 line-clamp-1">
          {saved?.title ?? t('savedLyrics.noTracks')}
        </div>
        <div class="text-xs text-neutral-500 mt-1">{saved?.artist ?? ''}</div>
        {
          noteHref ? (
            <a
              href={noteHref}
              class="mt-2 text-xxs font-mono text-accent hover:text-accent/80 flex items-center gap-1"
            >
              {t('savedLyrics.readLyricNote')} <ArrowRight class="w-3 h-3" />
            </a>
          ) : null
        }
      </div>
    </div>
  </div>
</section>
