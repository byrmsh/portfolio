---
import Disc from '@lucide/astro/icons/disc';
import ArrowRight from '@lucide/astro/icons/arrow-right';
---

<section
  class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-neutral-200 bg-white p-6 flex flex-col relative overflow-hidden group"
>
  <div class="relative z-10">
    <div class="flex justify-between items-start mb-6">
      <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">Saved Lyrics</h2>
      <Disc class="w-4 h-4 text-neutral-400" />
    </div>
    <div class="flex gap-4">
      <div
        class="w-16 h-16 bg-neutral-900 rounded-md shadow-sm flex items-center justify-center shrink-0"
      >
        <div class="w-6 h-6 rounded-full border-2 border-neutral-700"></div>
      </div>
      <div class="flex flex-col justify-center">
        <div class="text-sm font-semibold text-neutral-900 line-clamp-1">
          Everything In Its Right Place
        </div>
        <div class="text-xs text-neutral-500 mt-1">Radiohead</div>
        <a
          href="#"
          class="mt-2 text-xxs font-mono text-accent hover:text-accent/80 flex items-center gap-1"
        >
          READ LYRIC NOTE <ArrowRight class="w-3 h-3" />
        </a>
      </div>
    </div>
  </div>
</section>
