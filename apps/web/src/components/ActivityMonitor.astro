---
import Code from '@lucide/astro/icons/code';
import BrainCircuit from '@lucide/astro/icons/brain-circuit';
import Info from '@lucide/astro/icons/info';
import ky from 'ky';
import type { ActivityMonitorData } from '@portfolio/schema/dashboard';
import type { SupportedLocale } from '../i18n';
import {
  activityLevelClass,
  computeCurrentAnkiDay,
  findActivityRange,
  last7Cells,
  normalizeActivityMonitorData,
  padTo7,
  parseIsoDateUTC,
} from '../lib/activity-monitor';
import WidgetHeader from './WidgetHeader.astro';

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
  locale: SupportedLocale;
}

const { t, locale } = Astro.props;

const apiOrigin =
  process.env.API_ORIGIN ??
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';
const activityEndpoint = '/api/activity-monitor';
const activityLabels = {
  github: t('activity.github'),
  anki: t('activity.anki'),
} as const;

let activity = normalizeActivityMonitorData(null, activityLabels);
try {
  const json = await ky
    .get(`${apiOrigin}${activityEndpoint}`, {
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: ActivityMonitorData }>();
  activity = normalizeActivityMonitorData(json?.data, activityLabels);
} catch {
  activity = normalizeActivityMonitorData(null, activityLabels);
}

const fmtDay = new Intl.DateTimeFormat(locale, { weekday: 'short' });
const fmtRange = new Intl.DateTimeFormat(locale, { month: 'short', day: 'numeric' });
const githubCells = padTo7(last7Cells(activity.github));
const ankiCells = padTo7(last7Cells(activity.anki));
const { start: rangeStart, end: rangeEnd } = findActivityRange(githubCells, ankiCells);

const rangeLabel =
  rangeStart && rangeEnd
    ? t('activity.range', {
        start: fmtRange.format(parseIsoDateUTC(rangeStart)),
        end: fmtRange.format(parseIsoDateUTC(rangeEnd)),
      })
    : t('activity.last7_days');

const lastAnkiCell = ankiCells[ankiCells.length - 1];
const ankiTz = activity.anki.timezone ?? 'UTC';
const ankiRolloverHour = activity.anki.rolloverHour ?? 4;
const currentAnkiDay = computeCurrentAnkiDay(ankiTz, ankiRolloverHour);

const hasReviewToday = lastAnkiCell?.date === currentAnkiDay && lastAnkiCell.count > 0;
const ankiStreak = typeof activity.anki.streak === 'number' ? activity.anki.streak : 0;
---

<section
  data-activity-monitor
  data-locale={locale}
  data-endpoint={activityEndpoint}
  data-github-label={activityLabels.github}
  data-anki-label={activityLabels.anki}
  data-range-template={t('activity.range', { start: '{start}', end: '{end}' })}
  data-streak-template={t('activity.streak_days', { count: '{count}' })}
  data-tooltip-with-date={t('activity.tooltip_with_date')}
  data-tooltip-without-date={t('activity.tooltip_without_date')}
  class="col-span-1 md:col-span-6 lg:col-span-8 min-w-0 rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6"
>
  <WidgetHeader title={t('activity.title')} class="mb-4">
    <div class="text-xxs font-mono text-[var(--text-muted)] whitespace-nowrap" data-range>
      {rangeLabel}
    </div>
  </WidgetHeader>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_1px_1fr] gap-6 lg:gap-x-8 lg:gap-y-0 min-w-0">
    <div class="min-w-0">
      <div class="flex items-center gap-2 mb-3">
        <Code class="w-4 h-4 text-[var(--text-primary)]" />
        <span class="text-sm font-semibold truncate">{t('activity.github')}</span>
      </div>

      <div class="activity-tags" data-tags="github" aria-label={t('activity.github_aria')}>
        {
          githubCells.map((cell, i) => {
            const d = cell.date ? parseIsoDateUTC(cell.date) : null;
            const dow = d ? fmtDay.format(d) : '---';
            return (
              <button
                type="button"
                class:list={[
                  'activity-tag rounded-lg border flex flex-col items-center justify-center leading-none select-none transition hover:ring-2 hover:ring-[var(--ring-subtle)] focus:outline-none focus:ring-2 focus:ring-[var(--ring-subtle)]',
                  activityLevelClass('github', cell.level),
                ]}
                aria-label={t('activity.github_day_aria', { day: i + 1 })}
                data-source="github"
                data-source-label={t('activity.github')}
                data-date={cell.date}
                data-count={String(cell.count)}
                data-level={String(cell.level)}
              >
                <span class="tag-dow text-[10px] font-mono opacity-90">{dow}</span>
                <span class="tag-count text-xs font-semibold">{cell.count}</span>
              </button>
            );
          })
        }
      </div>
    </div>

    <div class="hidden lg:block w-px bg-[var(--surface-3)] rounded-full" aria-hidden="true"></div>

    <div class="min-w-0">
      <div class="flex items-center gap-2 mb-3">
        <BrainCircuit class="w-4 h-4 text-[var(--text-primary)] shrink-0" />
        <span class="text-sm font-semibold truncate">{t('activity.anki')}</span>
        <span
          class="flex items-center gap-1 ml-auto whitespace-nowrap shrink-0"
          data-streak-label="anki"
        >
          <span
            class="text-xxs font-mono text-[var(--text-muted)]"
            set:html={t('activity.streak_days', {
              count: `<span data-streak-count>${typeof ankiStreak === 'number' ? ankiStreak : 0}</span>`,
            })}
          />
          <button
            type="button"
            class:list={[
              'relative focus:outline-none rounded-sm focus:ring-2 focus:ring-[var(--ring-subtle)]',
              { hidden: hasReviewToday },
            ]}
            data-streak-info
            data-info-tooltip={t('activity.no_review_today')}
            aria-label={t('activity.no_review_today')}
          >
            <Info class="w-3 h-3 text-[var(--text-muted)] cursor-help" />
          </button>
        </span>
      </div>

      <div class="activity-tags" data-tags="anki" aria-label={t('activity.anki_aria')}>
        {
          ankiCells.map((cell, i) => {
            const d = cell.date ? parseIsoDateUTC(cell.date) : null;
            const dow = d ? fmtDay.format(d) : '---';
            return (
              <button
                type="button"
                class:list={[
                  'activity-tag rounded-lg border flex flex-col items-center justify-center leading-none select-none transition hover:ring-2 hover:ring-[var(--ring-subtle)] focus:outline-none focus:ring-2 focus:ring-[var(--ring-subtle)]',
                  activityLevelClass('anki', cell.level),
                ]}
                aria-label={t('activity.anki_day_aria', { day: i + 1 })}
                data-source="anki"
                data-source-label={t('activity.anki')}
                data-date={cell.date}
                data-count={String(cell.count)}
                data-level={String(cell.level)}
              >
                <span class="tag-dow text-[10px] font-mono opacity-90">{dow}</span>
                <span class="tag-count text-xs font-semibold">{cell.count}</span>
              </button>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<script>
  import type {
    ActivityCell,
    ActivityMonitorData,
    ActivitySeries,
  } from '@portfolio/schema/dashboard';
  import {
    activityColorRamps,
    clampInt,
    computeCurrentAnkiDay,
    findActivityRange,
    last7Cells,
    normalizeActivityMonitorData,
    padTo7,
    parseIsoDateUTC,
  } from '../lib/activity-monitor';

  const root = document.querySelector<HTMLElement>('[data-activity-monitor]');

  if (root) {
    const endpoint = root.dataset.endpoint ?? '/api/activity-monitor';
    const locale = root.dataset.locale ?? 'en';
    const labels = {
      github: root.dataset.githubLabel ?? 'GitHub',
      anki: root.dataset.ankiLabel ?? 'Anki',
    } as const;
    const rangeEl = root.querySelector<HTMLElement>('[data-range]');
    const streakEl = root.querySelector<HTMLElement>('[data-streak-label="anki"]');
    const rangeTemplate = root.dataset.rangeTemplate ?? '{start} to {end}';
    const streakTemplate = root.dataset.streakTemplate ?? 'Streak: {count}';
    const tooltipWithDateTpl = root.dataset.tooltipWithDate ?? '{label}: {date} ({count})';
    const tooltipWithoutDateTpl = root.dataset.tooltipWithoutDate ?? '{label}: ({count})';
    const fmtDay = new Intl.DateTimeFormat(locale, { weekday: 'short' });
    const fmtRange = new Intl.DateTimeFormat(locale, { month: 'short', day: 'numeric' });
    const fmtTip = new Intl.DateTimeFormat(locale, {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
    const baseBtn =
      'activity-tag rounded-lg border flex flex-col items-center justify-center leading-none select-none transition hover:ring-2 hover:ring-[var(--ring-subtle)] focus:outline-none focus:ring-2 focus:ring-[var(--ring-subtle)]';

    const formatTpl = (tpl: string, vars: Record<string, string | number>) =>
      tpl.replace(/\{(\w+)\}/g, (_, key) => String(vars[key] ?? `{${key}}`));

    const setRangeLabel = (githubCells: ActivityCell[], ankiCells: ActivityCell[]) => {
      if (!rangeEl) return;
      const { start, end } = findActivityRange(githubCells, ankiCells);
      if (!start || !end) return;
      rangeEl.textContent = rangeTemplate
        .replaceAll('{start}', fmtRange.format(parseIsoDateUTC(start)))
        .replaceAll('{end}', fmtRange.format(parseIsoDateUTC(end)));
    };

    const applySeries = (source: keyof typeof activityColorRamps, series: ActivitySeries) => {
      const container = root.querySelector<HTMLElement>(`[data-tags="${source}"]`);
      if (!container) return padTo7([]);

      const buttons = Array.from(
        container.querySelectorAll<HTMLButtonElement>('button.activity-tag'),
      );
      const cells = padTo7(last7Cells(series));

      buttons.forEach((btn, i) => {
        const cell = cells[i] ?? { date: '', count: 0, level: 0 };
        const level = clampInt(Number(cell.level || 0), 0, 4);
        const date = cell.date ? parseIsoDateUTC(cell.date) : null;

        btn.className = `${baseBtn} ${activityColorRamps[source][level]}`;
        btn.dataset.date = String(cell.date || '');
        btn.dataset.count = String(cell.count || 0);
        btn.dataset.level = String(level);

        const dowEl = btn.querySelector<HTMLElement>('.tag-dow');
        const countEl = btn.querySelector<HTMLElement>('.tag-count');
        if (dowEl) dowEl.textContent = date ? fmtDay.format(date) : '---';
        if (countEl) countEl.textContent = String(cell.count || 0);
      });

      return cells;
    };

    const bindTooltip = () => {
      const tip = document.createElement('div');
      tip.setAttribute('data-tooltip', 'activity');
      tip.className =
        'pointer-events-none fixed z-50 hidden whitespace-nowrap rounded-md border border-[var(--border-subtle)] bg-[var(--surface)] px-2 py-1 text-[11px] text-[var(--text-primary)] shadow-lg';
      tip.style.transform = 'translate3d(0, 0, 0)';
      document.body.appendChild(tip);

      let lastPointerX = 0;
      let lastPointerY = 0;
      let tipWidth = 0;
      let tipHeight = 0;
      let rafId = 0;

      const measureTip = () => {
        const rect = tip.getBoundingClientRect();
        tipWidth = rect.width;
        tipHeight = rect.height;
      };

      const positionTip = () => {
        rafId = 0;
        if (tip.classList.contains('hidden')) return;
        const gap = 12;
        const pad = 8;
        let left = lastPointerX + gap;
        let top = lastPointerY + gap;

        if (left + tipWidth + pad > window.innerWidth) left = lastPointerX - tipWidth - gap;
        if (top + tipHeight + pad > window.innerHeight) top = lastPointerY - tipHeight - gap;
        if (left < pad) left = pad;
        if (top < pad) top = pad;

        tip.style.left = `${left}px`;
        tip.style.top = `${top}px`;
      };

      const schedulePosition = () => {
        if (rafId) return;
        rafId = window.requestAnimationFrame(positionTip);
      };

      const show = (el: HTMLButtonElement, x: number, y: number) => {
        const sourceLabel = el.dataset.sourceLabel ?? el.dataset.source ?? '';
        const source = el.dataset.source ?? '';
        const date = el.dataset.date ?? '';
        const count = Number(el.dataset.count ?? 0);
        const unit = source === 'anki' ? 'reviews' : 'contributions';
        const dateStr = date ? fmtTip.format(parseIsoDateUTC(date)) : '';

        tip.textContent = dateStr
          ? formatTpl(tooltipWithDateTpl, { label: sourceLabel, date: dateStr, count, unit })
          : formatTpl(tooltipWithoutDateTpl, { label: sourceLabel, count, unit });

        tip.classList.remove('hidden');
        tip.style.visibility = 'visible';
        lastPointerX = x;
        lastPointerY = y;
        measureTip();
        schedulePosition();
      };

      const hide = () => {
        tip.classList.add('hidden');
        tip.style.visibility = 'hidden';
        if (rafId) {
          window.cancelAnimationFrame(rafId);
          rafId = 0;
        }
      };

      const move = (x: number, y: number) => {
        lastPointerX = x;
        lastPointerY = y;
        schedulePosition();
      };

      for (const el of root.querySelectorAll<HTMLButtonElement>(
        '[data-tags] button[data-source]',
      )) {
        el.addEventListener('mouseenter', (e) => show(el, e.clientX, e.clientY));
        el.addEventListener('mousemove', (e) => move(e.clientX, e.clientY));
        el.addEventListener('mouseleave', hide);
        el.addEventListener('focus', () => {
          const rect = el.getBoundingClientRect();
          show(el, rect.left + rect.width / 2, rect.top + rect.height / 2);
        });
        el.addEventListener('blur', hide);
      }

      for (const el of root.querySelectorAll<HTMLElement>('[data-info-tooltip]')) {
        const showInfo = (x: number, y: number) => {
          tip.textContent = el.dataset.infoTooltip ?? '';
          tip.classList.remove('hidden');
          tip.style.visibility = 'visible';
          lastPointerX = x;
          lastPointerY = y;
          measureTip();
          schedulePosition();
        };
        el.addEventListener('mouseenter', (e) => showInfo(e.clientX, e.clientY));
        el.addEventListener('mousemove', (e) => move(e.clientX, e.clientY));
        el.addEventListener('mouseleave', hide);
        el.addEventListener('focus', () => {
          const rect = el.getBoundingClientRect();
          showInfo(rect.left + rect.width / 2, rect.top + rect.height / 2);
        });
        el.addEventListener('blur', hide);
      }
    };

    const refresh = async () => {
      const response = await fetch(endpoint, { headers: { accept: 'application/json' } });
      if (!response.ok) return;

      const json = (await response.json()) as { data?: ActivityMonitorData };
      const data = normalizeActivityMonitorData(json.data, labels);
      const githubCells = applySeries('github', data.github);
      const ankiCells = applySeries('anki', data.anki);

      const ankiTz = data.anki.timezone ?? 'UTC';
      const ankiRolloverHour = data.anki.rolloverHour ?? 4;
      const currentAnkiDay = computeCurrentAnkiDay(ankiTz, ankiRolloverHour);

      const lastAnkiCell = ankiCells[ankiCells.length - 1];
      const hasReviewToday = lastAnkiCell?.date === currentAnkiDay && lastAnkiCell.count > 0;
      const ankiStreak = typeof data.anki.streak === 'number' ? data.anki.streak : 0;

      setRangeLabel(githubCells, ankiCells);
      if (streakEl) {
        const countSpan = streakEl.querySelector<HTMLElement>('[data-streak-count]');
        if (countSpan) {
          countSpan.textContent = String(ankiStreak);
        }
        const infoSpan = streakEl.querySelector<HTMLElement>('[data-streak-info]');
        if (infoSpan) {
          infoSpan.classList.toggle('hidden', hasReviewToday);
        }
      }
    };

    bindTooltip();
    refresh().catch(() => {});
  }
</script>

<style is:global>
  @supports (container-type: inline-size) {
    [data-activity-monitor] {
      container-type: inline-size;
    }
  }

  [data-activity-monitor] .activity-tags {
    --tag-gap: clamp(0.1875rem, 1cqw, 0.625rem);
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: var(--tag-gap);
    min-width: 0;
    container-type: inline-size;
  }

  [data-activity-monitor] .activity-tag {
    width: 100%;
    aspect-ratio: 1 / 1;
    min-width: 0;
  }

  [data-activity-monitor] .activity-tag[data-source='anki'] .tag-count {
    font-size: 0.65rem;
    line-height: 1;
    font-weight: 600;
    opacity: 0.85;
    font-variant-numeric: tabular-nums;
  }

  @container (max-width: 360px) {
    [data-activity-monitor] .activity-tag .tag-dow {
      display: none;
    }
    [data-activity-monitor] .activity-tag .tag-count {
      font-size: 0.9rem;
      line-height: 1;
    }
    [data-activity-monitor] .activity-tag[data-source='anki'] .tag-count {
      font-size: 0.7rem;
    }
  }
</style>
