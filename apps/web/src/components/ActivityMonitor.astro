---
import GitHub from '@lucide/astro/icons/github';
import BrainCircuit from '@lucide/astro/icons/brain-circuit';

type Cell = { date: string };
const apiOrigin = import.meta.env.PUBLIC_API_ORIGIN ?? '';

function isoDateUTC(d: Date): string {
  const yyyy = d.getUTCFullYear();
  const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
  const dd = String(d.getUTCDate()).padStart(2, '0');
  return `${yyyy}-${mm}-${dd}`;
}

function lastSaturdayUtc(today: Date): Date {
  const day = today.getUTCDay(); // 0=Sun..6=Sat
  const daysSinceSaturday = (day - 6 + 7) % 7;
  const d = new Date(Date.UTC(today.getUTCFullYear(), today.getUTCMonth(), today.getUTCDate()));
  d.setUTCDate(d.getUTCDate() - daysSinceSaturday);
  return d;
}

function buildWindowCells(): Cell[] {
  const today = new Date();
  const end = lastSaturdayUtc(today);
  const start = new Date(end);
  start.setUTCDate(end.getUTCDate() - (16 * 7 - 1));

  const out: Cell[] = [];
  const cur = new Date(start);
  while (cur <= end) {
    out.push({ date: isoDateUTC(cur) });
    cur.setUTCDate(cur.getUTCDate() + 1);
  }
  return out;
}

const windowCells = buildWindowCells();
---

<section
  data-activity-monitor
  data-api-origin={apiOrigin}
  class="col-span-1 md:col-span-6 lg:col-span-8 rounded-xl border border-neutral-200 bg-white p-6 flex flex-col justify-between"
>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">Activity Monitor</h2>
    <div class="flex gap-2 text-xxs font-mono text-neutral-400">
      <span>Less</span>
      <div class="flex gap-0.5">
        <span class="w-2 h-2 bg-neutral-100 rounded-[1px]"></span>
        <span class="w-2 h-2 bg-neutral-300 rounded-[1px]"></span>
        <span class="w-2 h-2 bg-neutral-500 rounded-[1px]"></span>
        <span class="w-2 h-2 bg-neutral-800 rounded-[1px]"></span>
        <span class="w-2 h-2 bg-neutral-950 rounded-[1px]"></span>
      </div>
      <span>More</span>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
    <div>
      <div class="flex items-center gap-2 mb-3">
        <GitHub class="w-4 h-4 text-neutral-800" />
        <span class="text-sm font-semibold">GitHub</span>
        <span class="text-xs text-neutral-400 ml-auto">Last 16 weeks</span>
      </div>
      <div class="grid grid-flow-col grid-rows-7 gap-1.5 w-max" data-grid="github">
        {
          windowCells.map((cell, idx) => (
            <div
              class="w-3 h-3 bg-neutral-100 rounded-[2px]"
              data-source="github"
              data-idx={idx}
              data-date={cell.date}
              title={cell.date}
            />
          ))
        }
      </div>
    </div>

    <div class="relative pl-0 sm:pl-8 sm:border-l border-neutral-100">
      <div class="flex items-center gap-2 mb-3">
        <BrainCircuit class="w-4 h-4 text-neutral-800" />
        <span class="text-sm font-semibold">Anki</span>
        <span class="text-xs text-neutral-400 ml-auto">
          Streak: <span data-streak="anki">-</span>
        </span>
      </div>
      <div class="grid grid-flow-col grid-rows-7 gap-1.5 w-max" data-grid="anki">
        {
          windowCells.map((cell, idx) => (
            <div
              class="w-3 h-3 bg-neutral-100 rounded-[2px]"
              data-source="anki"
              data-idx={idx}
              data-date={cell.date}
              title={cell.date}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline type="module">
  const root = document.querySelector('[data-activity-monitor]');
  const origin = root?.getAttribute('data-api-origin') ?? '';
  const url = origin ? `${origin}/api/activity-monitor` : '/api/activity-monitor';

  const levelClass = (level) => {
    // keep in sync with legend in markup
    switch (level) {
      case 0:
        return 'bg-neutral-100';
      case 1:
        return 'bg-neutral-300';
      case 2:
        return 'bg-neutral-500';
      case 3:
        return 'bg-neutral-800';
      case 4:
        return 'bg-neutral-950';
      default:
        return 'bg-neutral-100';
    }
  };

  const setCellClass = (el, level) => {
    el.classList.remove(
      'bg-neutral-100',
      'bg-neutral-300',
      'bg-neutral-500',
      'bg-neutral-800',
      'bg-neutral-950',
    );
    el.classList.add(levelClass(level));
  };

  const applySeries = (source, series) => {
    const cells = Array.isArray(series?.cells) ? series.cells : [];
    for (const cell of cells) {
      const el = document.querySelector(`[data-source="${source}"][data-date="${cell.date}"]`);
      if (!el) continue;
      setCellClass(el, cell.level ?? 0);
      if (typeof cell.count === 'number') {
        el.title = `${cell.date}: ${cell.count}`;
      }
    }

    const streakEl = document.querySelector(`[data-streak="${source}"]`);
    if (streakEl) {
      streakEl.textContent =
        series?.streak === null || typeof series?.streak === 'undefined'
          ? '-'
          : String(series.streak);
    }
  };

  (async () => {
    try {
      const res = await fetch(url, { headers: { accept: 'application/json' } });
      if (!res.ok) return;
      const json = await res.json();
      applySeries('github', json?.data?.github);
      applySeries('anki', json?.data?.anki);
    } catch {
      // ignore: placeholders stay
    }
  })();
</script>
