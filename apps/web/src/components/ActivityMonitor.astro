---
import GitHub from '@lucide/astro/icons/github';
import BrainCircuit from '@lucide/astro/icons/brain-circuit';

type Cell = { date: string };
const apiOrigin = import.meta.env.PUBLIC_API_ORIGIN ?? '';

function isoDateUTC(d: Date): string {
  const yyyy = d.getUTCFullYear();
  const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
  const dd = String(d.getUTCDate()).padStart(2, '0');
  return `${yyyy}-${mm}-${dd}`;
}

function lastSaturdayUtc(today: Date): Date {
  const day = today.getUTCDay(); // 0=Sun..6=Sat
  const daysSinceSaturday = (day - 6 + 7) % 7;
  const d = new Date(Date.UTC(today.getUTCFullYear(), today.getUTCMonth(), today.getUTCDate()));
  d.setUTCDate(d.getUTCDate() - daysSinceSaturday);
  return d;
}

function buildWindowCells(): { cells: Cell[]; start: Date; end: Date } {
  const today = new Date();
  const end = lastSaturdayUtc(today);
  const start = new Date(end);
  start.setUTCDate(end.getUTCDate() - (16 * 7 - 1));

  const cells: Cell[] = [];
  const cur = new Date(start);
  while (cur <= end) {
    cells.push({ date: isoDateUTC(cur) });
    cur.setUTCDate(cur.getUTCDate() + 1);
  }
  return { cells, start, end };
}

const windowWindow = buildWindowCells();
const windowCells = windowWindow.cells;

type WeekMeta = { idx: number; label: string | null; isMonthStart: boolean };
function buildWeeks(start: Date): WeekMeta[] {
  const monthFmt = new Intl.DateTimeFormat('en-US', { month: 'short' });
  const weeks: WeekMeta[] = [];

  for (let w = 0; w < 16; w++) {
    const weekStart = new Date(start);
    weekStart.setUTCDate(start.getUTCDate() + w * 7);

    let label: string | null = null;
    let isMonthStart = false;

    // GitHub-style: label when the week contains day=1, plus always label first column.
    for (let i = 0; i < 7; i++) {
      const d = new Date(weekStart);
      d.setUTCDate(weekStart.getUTCDate() + i);
      if (d.getUTCDate() === 1) {
        label = monthFmt.format(d);
        isMonthStart = true;
        break;
      }
    }
    if (w === 0) label = monthFmt.format(weekStart);

    weeks.push({ idx: w, label, isMonthStart });
  }

  return weeks;
}

const weeks = buildWeeks(windowWindow.start);
const rangeFmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' });
const rangeLabel = `${rangeFmt.format(windowWindow.start)} to ${rangeFmt.format(windowWindow.end)}`;
---

<section
  data-activity-monitor
  data-api-origin={apiOrigin}
  class="col-span-1 md:col-span-6 lg:col-span-8 min-w-0 overflow-hidden rounded-xl border border-neutral-200 bg-white p-6 flex flex-col justify-between [--cell:0.75rem] [--gap:0.375rem]"
>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">Activity Monitor</h2>
    <div class="text-xxs font-mono text-neutral-400">{rangeLabel}</div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 min-w-0">
    <div class="min-w-0">
      <div class="flex items-center gap-2 mb-3">
        <GitHub class="w-4 h-4 text-neutral-800" />
        <span class="text-sm font-semibold">GitHub</span>
        <span class="text-xs text-neutral-400 ml-auto">Last 16 weeks</span>
      </div>
      <div class="flex items-start gap-3 min-w-0">
        <div class="pt-4 grid grid-rows-7 gap-[var(--gap)] text-[10px] leading-none text-neutral-400 select-none">
          <span></span>
          <span class="h-3 flex items-center">Mon</span>
          <span></span>
          <span class="h-3 flex items-center">Wed</span>
          <span></span>
          <span class="h-3 flex items-center">Fri</span>
          <span></span>
        </div>

        <div class="flex flex-col gap-1 min-w-0">
          <div
            class="inline-grid gap-[var(--gap)] overflow-visible"
            style="grid-template-columns: repeat(16, var(--cell));"
            aria-hidden="true"
          >
            {
              weeks.map((w) => (
                <div class="h-3 overflow-visible">
                  {w.label ? (
                    <span class="block text-[10px] leading-none text-neutral-400 select-none">
                      {w.label}
                    </span>
                  ) : null}
                </div>
              ))
            }
          </div>

          <div class="relative">
            <div class="grid grid-flow-col grid-rows-7 gap-[var(--gap)] w-max" data-grid="github">
              {
                windowCells.map((cell, idx) => {
                  const weekIdx = Math.floor(idx / 7);
                  const isMonthStart = weeks[weekIdx]?.isMonthStart && weekIdx !== 0;
                  return (
                    <button
                      type="button"
                      class:list={[
                        "w-[var(--cell)] h-[var(--cell)] rounded-[2px] bg-neutral-100 transition",
                        "hover:ring-2 hover:ring-neutral-300 focus:outline-none focus:ring-2 focus:ring-neutral-400",
                        isMonthStart ? "border-l border-neutral-200" : "",
                      ]}
                      data-source="github"
                      data-idx={idx}
                      data-week={weekIdx}
                      data-date={cell.date}
                      data-count="0"
                      data-level="0"
                      aria-label={`GitHub ${cell.date}`}
                    />
                  );
                })
              }
            </div>
          </div>

          <div class="flex items-center justify-between text-xxs font-mono text-neutral-400">
            <div class="flex items-center gap-1">
              <span>Less</span>
              <span class="w-2 h-2 rounded-[1px] bg-emerald-100"></span>
              <span class="w-2 h-2 rounded-[1px] bg-emerald-300"></span>
              <span class="w-2 h-2 rounded-[1px] bg-emerald-500"></span>
              <span class="w-2 h-2 rounded-[1px] bg-emerald-700"></span>
              <span class="w-2 h-2 rounded-[1px] bg-emerald-900"></span>
              <span>More</span>
            </div>
            <span>
              Streak: <span data-streak="github">-</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="relative min-w-0 pl-0 lg:pl-8 lg:border-l border-neutral-100">
      <div class="flex items-center gap-2 mb-3">
        <BrainCircuit class="w-4 h-4 text-neutral-800" />
        <span class="text-sm font-semibold">Anki</span>
        <span class="text-xs text-neutral-400 ml-auto">
          Streak: <span data-streak="anki">-</span>
        </span>
      </div>
      <div class="flex items-start gap-3 min-w-0">
        <div class="pt-4 grid grid-rows-7 gap-[var(--gap)] text-[10px] leading-none text-neutral-400 select-none">
          <span></span>
          <span class="h-3 flex items-center">Mon</span>
          <span></span>
          <span class="h-3 flex items-center">Wed</span>
          <span></span>
          <span class="h-3 flex items-center">Fri</span>
          <span></span>
        </div>

        <div class="flex flex-col gap-1 min-w-0">
          <div
            class="inline-grid gap-[var(--gap)] overflow-visible"
            style="grid-template-columns: repeat(16, var(--cell));"
            aria-hidden="true"
          >
            {
              weeks.map((w) => (
                <div class="h-3 overflow-visible">
                  {w.label ? (
                    <span class="block text-[10px] leading-none text-neutral-400 select-none">
                      {w.label}
                    </span>
                  ) : null}
                </div>
              ))
            }
          </div>

          <div class="relative">
            <div class="grid grid-flow-col grid-rows-7 gap-[var(--gap)] w-max" data-grid="anki">
              {
                windowCells.map((cell, idx) => {
                  const weekIdx = Math.floor(idx / 7);
                  const isMonthStart = weeks[weekIdx]?.isMonthStart && weekIdx !== 0;
                  return (
                    <button
                      type="button"
                      class:list={[
                        "w-[var(--cell)] h-[var(--cell)] rounded-[2px] bg-neutral-100 transition",
                        "hover:ring-2 hover:ring-neutral-300 focus:outline-none focus:ring-2 focus:ring-neutral-400",
                        isMonthStart ? "border-l border-neutral-200" : "",
                      ]}
                      data-source="anki"
                      data-idx={idx}
                      data-week={weekIdx}
                      data-date={cell.date}
                      data-count="0"
                      data-level="0"
                      aria-label={`Anki ${cell.date}`}
                    />
                  );
                })
              }
            </div>
          </div>

          <div class="flex items-center justify-between text-xxs font-mono text-neutral-400">
            <div class="flex items-center gap-1">
              <span>Less</span>
              <span class="w-2 h-2 rounded-[1px] bg-sky-100"></span>
              <span class="w-2 h-2 rounded-[1px] bg-sky-300"></span>
              <span class="w-2 h-2 rounded-[1px] bg-sky-500"></span>
              <span class="w-2 h-2 rounded-[1px] bg-sky-700"></span>
              <span class="w-2 h-2 rounded-[1px] bg-sky-900"></span>
              <span>More</span>
            </div>
            <span class="text-neutral-300">collector pending</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Make the heatmap shrink to fit its card (no clipping, no horizontal scroll). */
  @supports (container-type: inline-size) {
    [data-activity-monitor] {
      container-type: inline-size;
    }

    @container (max-width: 760px) {
      [data-activity-monitor] {
        --cell: 0.6875rem; /* 11px */
        --gap: 0.3125rem; /* 5px */
      }
    }

    @container (max-width: 680px) {
      [data-activity-monitor] {
        --cell: 0.625rem; /* 10px */
        --gap: 0.25rem; /* 4px */
      }
    }

    @container (max-width: 600px) {
      [data-activity-monitor] {
        --cell: 0.5625rem; /* 9px */
        --gap: 0.25rem; /* 4px */
      }
    }
  }
</style>

<script is:inline type="module">
  const root = document.querySelector('[data-activity-monitor]');
  const origin = root?.getAttribute('data-api-origin') ?? '';
  const url = origin ? `${origin}/api/activity-monitor` : '/api/activity-monitor';

  const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  const parseIsoDate = (s) => {
    // treat as UTC date to avoid local TZ shifting
    const [y, m, d] = String(s).split('-').map((v) => Number(v));
    return new Date(Date.UTC(y, m - 1, d));
  };

  const levelClass = (source, level) => {
    const l = Number(level ?? 0);
    const ramps = {
      github: ['bg-neutral-100', 'bg-emerald-100', 'bg-emerald-300', 'bg-emerald-500', 'bg-emerald-900'],
      anki: ['bg-neutral-100', 'bg-sky-100', 'bg-sky-300', 'bg-sky-500', 'bg-sky-900'],
    };
    const ramp = ramps[source] ?? ramps.github;
    return ramp[Math.max(0, Math.min(4, l))];
  };

  const setCellClass = (el, source, level) => {
    el.classList.remove(
      'bg-neutral-100',
      'bg-neutral-300',
      'bg-neutral-500',
      'bg-neutral-800',
      'bg-neutral-950',
      'bg-emerald-100',
      'bg-emerald-300',
      'bg-emerald-500',
      'bg-emerald-700',
      'bg-emerald-900',
      'bg-sky-100',
      'bg-sky-300',
      'bg-sky-500',
      'bg-sky-700',
      'bg-sky-900',
    );
    el.classList.add(levelClass(source, level));
  };

  const applySeries = (source, series) => {
    const cells = Array.isArray(series?.cells) ? series.cells : [];
    for (const cell of cells) {
      const el = document.querySelector(`[data-source="${source}"][data-date="${cell.date}"]`);
      if (!el) continue;
      const count = typeof cell.count === 'number' ? cell.count : 0;
      const level = typeof cell.level === 'number' ? cell.level : 0;
      el.dataset.count = String(count);
      el.dataset.level = String(level);
      setCellClass(el, source, level);
      el.setAttribute('aria-label', `${source === 'github' ? 'GitHub' : 'Anki'} ${cell.date}: ${count}`);
    }

    const streakEl = document.querySelector(`[data-streak="${source}"]`);
    if (streakEl) {
      streakEl.textContent =
        series?.streak === null || typeof series?.streak === 'undefined'
          ? '-'
          : String(series.streak);
    }
  };

  // Tooltip: single floating element for both grids.
  const tip = document.createElement('div');
  tip.setAttribute('data-tooltip', 'activity');
  tip.className =
    'pointer-events-none fixed z-50 hidden rounded-md border border-neutral-200 bg-white px-2 py-1 text-[11px] text-neutral-800 shadow-lg';
  document.body.appendChild(tip);

  const showTip = (el, x, y) => {
    const source = el.dataset.source ?? '';
    const date = el.dataset.date ?? '';
    const count = Number(el.dataset.count ?? 0);
    const label = source === 'github' ? 'GitHub' : source === 'anki' ? 'Anki' : source;
    const dateStr = date ? fmt.format(parseIsoDate(date)) : '';

    tip.textContent = `${label}: ${dateStr}${dateStr ? ' ' : ''}(${count})`;
    tip.style.left = `${Math.min(window.innerWidth - 10, x + 12)}px`;
    tip.style.top = `${Math.min(window.innerHeight - 10, y + 12)}px`;
    tip.classList.remove('hidden');
  };
  const hideTip = () => tip.classList.add('hidden');

  const bindCells = () => {
    const cells = document.querySelectorAll('[data-source][data-date]');
    for (const el of cells) {
      // Initialize palette for placeholders.
      setCellClass(el, el.dataset.source, 0);

      el.addEventListener('mouseenter', (e) => showTip(el, e.clientX, e.clientY));
      el.addEventListener('mousemove', (e) => showTip(el, e.clientX, e.clientY));
      el.addEventListener('mouseleave', hideTip);

      el.addEventListener('focus', () => {
        const r = el.getBoundingClientRect();
        showTip(el, r.left + r.width / 2, r.top + r.height / 2);
      });
      el.addEventListener('blur', hideTip);
    }
  };
  bindCells();

  (async () => {
    try {
      const res = await fetch(url, { headers: { accept: 'application/json' } });
      if (!res.ok) return;
      const json = await res.json();
      applySeries('github', json?.data?.github);
      applySeries('anki', json?.data?.anki);
    } catch {
      // ignore: placeholders stay
    }
  })();
</script>
