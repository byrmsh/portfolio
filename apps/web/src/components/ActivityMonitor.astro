---
import GitHub from '@lucide/astro/icons/github';
import BrainCircuit from '@lucide/astro/icons/brain-circuit';

const apiOrigin = import.meta.env.PUBLIC_API_ORIGIN ?? '';
---

<section
  data-activity-monitor
  data-api-origin={apiOrigin}
  class="col-span-1 md:col-span-6 lg:col-span-8 min-w-0 rounded-xl border border-neutral-200 bg-white p-6"
>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">Activity Monitor</h2>
    <div class="text-xxs font-mono text-neutral-400" data-range>Last 7 days</div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 min-w-0">
    <div class="min-w-0">
      <div class="flex items-center gap-2 mb-3">
        <GitHub class="w-4 h-4 text-neutral-800" />
        <span class="text-sm font-semibold">GitHub</span>
      </div>

      <div class="flex flex-wrap gap-2" data-tags="github" aria-label="GitHub activity, last 7 days">
        {Array.from({ length: 7 }).map((_, i) => (
          <button
            type="button"
            class="h-11 w-11 rounded-lg border border-neutral-200 bg-neutral-100 text-neutral-400 flex flex-col items-center justify-center leading-none select-none"
            aria-label={`GitHub day ${i + 1}`}
            data-source="github"
            data-date=""
            data-count="0"
            data-level="0"
          >
            <span class="text-[10px] font-mono">---</span>
            <span class="text-xs font-semibold">0</span>
          </button>
        ))}
      </div>
    </div>

    <div class="min-w-0 pl-0 lg:pl-8 lg:border-l border-neutral-100">
      <div class="flex items-center gap-2 mb-3">
        <BrainCircuit class="w-4 h-4 text-neutral-800" />
        <span class="text-sm font-semibold">Anki</span>
        <span class="text-xs text-neutral-400 ml-auto">
          Streak: <span data-streak="anki">-</span>
        </span>
      </div>

      <div class="flex flex-wrap gap-2" data-tags="anki" aria-label="Anki activity, last 7 days">
        {Array.from({ length: 7 }).map((_, i) => (
          <button
            type="button"
            class="h-11 w-11 rounded-lg border border-neutral-200 bg-neutral-100 text-neutral-400 flex flex-col items-center justify-center leading-none select-none"
            aria-label={`Anki day ${i + 1}`}
            data-source="anki"
            data-date=""
            data-count="0"
            data-level="0"
          >
            <span class="text-[10px] font-mono">---</span>
            <span class="text-xs font-semibold">0</span>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline type="module">
  const root = document.querySelector('[data-activity-monitor]');
  const origin = root?.getAttribute('data-api-origin') ?? '';
  const url = origin ? `${origin}/api/activity-monitor` : '/api/activity-monitor';

  const fmtDay = new Intl.DateTimeFormat('en-US', { weekday: 'short' });
  const fmtRange = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' });
  const fmtTip = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

  const parseIsoDate = (s) => {
    // Treat YYYY-MM-DD as a UTC date to avoid local TZ shifting.
    const [y, m, d] = String(s).split('-').map((v) => Number(v));
    return new Date(Date.UTC(y, m - 1, d));
  };

  const levelStyle = (source, level) => {
    const l = Math.max(0, Math.min(4, Number(level ?? 0)));
    const ramps = {
      github: [
        'bg-neutral-100 text-neutral-400 border-neutral-200',
        'bg-emerald-100 text-emerald-950 border-emerald-200',
        'bg-emerald-200 text-emerald-950 border-emerald-300',
        'bg-emerald-400 text-white border-emerald-400',
        'bg-emerald-700 text-white border-emerald-700',
      ],
      anki: [
        'bg-neutral-100 text-neutral-400 border-neutral-200',
        'bg-sky-100 text-sky-950 border-sky-200',
        'bg-sky-200 text-sky-950 border-sky-300',
        'bg-sky-400 text-white border-sky-400',
        'bg-sky-700 text-white border-sky-700',
      ],
    };
    return (ramps[source] ?? ramps.github)[l];
  };

  const setBtnStyle = (el, source, level) => {
    el.classList.remove(
      'bg-neutral-100',
      'bg-emerald-100',
      'bg-emerald-200',
      'bg-emerald-400',
      'bg-emerald-700',
      'bg-sky-100',
      'bg-sky-200',
      'bg-sky-400',
      'bg-sky-700',
      'text-neutral-400',
      'text-emerald-950',
      'text-sky-950',
      'text-white',
      'border-neutral-200',
      'border-emerald-200',
      'border-emerald-300',
      'border-emerald-400',
      'border-emerald-700',
      'border-sky-200',
      'border-sky-300',
      'border-sky-400',
      'border-sky-700',
    );
    for (const cls of levelStyle(source, level).split(' ')) el.classList.add(cls);
  };

  const last7Cells = (series) => {
    const cells = Array.isArray(series?.cells) ? series.cells.slice() : [];
    cells.sort((a, b) => String(a.date).localeCompare(String(b.date)));
    return cells.slice(Math.max(0, cells.length - 7));
  };

  const renderTags = (source, series) => {
    const host = document.querySelector(`[data-tags="${source}"]`);
    if (!host) return { start: null, end: null };
    host.innerHTML = '';

    const cells = last7Cells(series);
    let start = null;
    let end = null;

    for (const cell of cells) {
      const date = String(cell.date ?? '');
      const count = Number(cell.count ?? 0);
      const level = Number(cell.level ?? 0);
      const d = date ? parseIsoDate(date) : null;
      if (d && !start) start = d;
      if (d) end = d;

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className =
        'h-11 w-11 rounded-lg border flex flex-col items-center justify-center leading-none select-none transition hover:ring-2 hover:ring-neutral-300 focus:outline-none focus:ring-2 focus:ring-neutral-400';
      btn.dataset.source = source;
      btn.dataset.date = date;
      btn.dataset.count = String(count);
      btn.dataset.level = String(level);
      btn.setAttribute('aria-label', `${source === 'github' ? 'GitHub' : 'Anki'} ${date}: ${count}`);

      setBtnStyle(btn, source, level);

      const dow = document.createElement('span');
      dow.className = 'text-[10px] font-mono opacity-90';
      dow.textContent = d ? fmtDay.format(d) : '---';

      const num = document.createElement('span');
      num.className = 'text-xs font-semibold';
      num.textContent = String(count);

      btn.appendChild(dow);
      btn.appendChild(num);
      host.appendChild(btn);
    }

    // Always keep exactly 7 nodes (in case collector returned fewer days).
    while (host.children.length < 7) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className =
        'h-11 w-11 rounded-lg border border-neutral-200 bg-neutral-100 text-neutral-400 flex flex-col items-center justify-center leading-none select-none';
      btn.dataset.source = source;
      btn.dataset.date = '';
      btn.dataset.count = '0';
      btn.dataset.level = '0';
      btn.setAttribute('aria-label', `${source === 'github' ? 'GitHub' : 'Anki'} day`);
      btn.innerHTML = '<span class="text-[10px] font-mono">---</span><span class="text-xs font-semibold">0</span>';
      host.appendChild(btn);
    }

    return { start, end };
  };

  const bindTooltip = () => {
    const tip = document.createElement('div');
    tip.setAttribute('data-tooltip', 'activity');
    tip.className =
      'pointer-events-none fixed z-50 hidden rounded-md border border-neutral-200 bg-white px-2 py-1 text-[11px] text-neutral-800 shadow-lg';
    document.body.appendChild(tip);

    const show = (el, x, y) => {
      const source = el.dataset.source ?? '';
      const date = el.dataset.date ?? '';
      const count = Number(el.dataset.count ?? 0);
      const label = source === 'github' ? 'GitHub' : source === 'anki' ? 'Anki' : source;
      const dateStr = date ? fmtTip.format(parseIsoDate(date)) : '';

      tip.textContent = dateStr ? `${label}: ${dateStr} (${count})` : `${label}: (${count})`;
      tip.style.left = `${Math.min(window.innerWidth - 10, x + 12)}px`;
      tip.style.top = `${Math.min(window.innerHeight - 10, y + 12)}px`;
      tip.classList.remove('hidden');
    };
    const hide = () => tip.classList.add('hidden');

    const bind = () => {
      const nodes = document.querySelectorAll('[data-tags] button[data-source]');
      for (const el of nodes) {
        el.addEventListener('mouseenter', (e) => show(el, e.clientX, e.clientY));
        el.addEventListener('mousemove', (e) => show(el, e.clientX, e.clientY));
        el.addEventListener('mouseleave', hide);

        el.addEventListener('focus', () => {
          const r = el.getBoundingClientRect();
          show(el, r.left + r.width / 2, r.top + r.height / 2);
        });
        el.addEventListener('blur', hide);
      }
    };

    bind();
    return bind;
  };

  const rebind = bindTooltip();

  (async () => {
    try {
      const res = await fetch(url, { headers: { accept: 'application/json' } });
      if (!res.ok) return;
      const json = await res.json();
      const github = json?.data?.github;
      const anki = json?.data?.anki;

      const { start, end } = renderTags('github', github);
      renderTags('anki', anki);

      const streakEl = document.querySelector('[data-streak="anki"]');
      if (streakEl) {
        streakEl.textContent =
          anki?.streak === null || typeof anki?.streak === 'undefined' ? '-' : String(anki.streak);
      }

      const rangeEl = document.querySelector('[data-range]');
      if (rangeEl && start && end) {
        rangeEl.textContent = `${fmtRange.format(start)} to ${fmtRange.format(end)}`;
      }

      // Rebind tooltip listeners since we re-rendered the nodes.
      rebind();
    } catch {
      // ignore: placeholders stay
    }
  })();
</script>

