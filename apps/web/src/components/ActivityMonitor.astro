---
import GitHub from '@lucide/astro/icons/github';
import BrainCircuit from '@lucide/astro/icons/brain-circuit';
import ky from 'ky';

type ActivityCell = { date: string; count: number; level: number };
type ActivitySeries = { source: 'github' | 'anki'; label: string; cells: ActivityCell[]; streak?: number };
type ActivityMonitorData = { github: ActivitySeries; anki: ActivitySeries };

function clampInt(n: number, min: number, max: number): number {
  return Math.max(min, Math.min(max, Math.trunc(n)));
}

function levelClass(source: 'github' | 'anki', level: number): string {
  const l = clampInt(level ?? 0, 0, 4);
  const ramps: Record<'github' | 'anki', string[]> = {
    github: [
      'bg-neutral-100 text-neutral-400 border-neutral-200',
      'bg-emerald-100 text-emerald-950 border-emerald-200',
      'bg-emerald-200 text-emerald-950 border-emerald-300',
      'bg-emerald-400 text-white border-emerald-400',
      'bg-emerald-700 text-white border-emerald-700',
    ],
    anki: [
      'bg-neutral-100 text-neutral-400 border-neutral-200',
      'bg-sky-100 text-sky-950 border-sky-200',
      'bg-sky-200 text-sky-950 border-sky-300',
      'bg-sky-400 text-white border-sky-400',
      'bg-sky-700 text-white border-sky-700',
    ],
  };
  return ramps[source][l];
}

function parseIsoDateUTC(s: string): Date {
  const [y, m, d] = String(s).split('-').map((v) => Number(v));
  return new Date(Date.UTC(y, (m ?? 1) - 1, d ?? 1));
}

function last7Cells(series: ActivitySeries | null | undefined): ActivityCell[] {
  const cells = Array.isArray(series?.cells) ? series!.cells.slice() : [];
  cells.sort((a, b) => String(a.date).localeCompare(String(b.date)));
  return cells.slice(Math.max(0, cells.length - 7));
}

function padTo7(cells: ActivityCell[]): ActivityCell[] {
  const out = cells.slice(0, 7);
  while (out.length < 7) out.push({ date: '', count: 0, level: 0 });
  return out;
}

const apiOrigin =
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

let activity: ActivityMonitorData | null = null;
try {
  const json = await ky
    .get(`${apiOrigin}/api/activity-monitor`, {
    headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: ActivityMonitorData }>();

  if (json?.data?.github && json?.data?.anki) activity = json.data;
} catch {
  // Build-time/API-time failures should not break the homepage build.
  activity = null;
}

const fmtDay = new Intl.DateTimeFormat('en-US', { weekday: 'short' });
const fmtRange = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' });
const githubCells = padTo7(last7Cells(activity?.github));
const ankiCells = padTo7(last7Cells(activity?.anki));

const rangeStart = githubCells.find((c) => c.date)?.date || ankiCells.find((c) => c.date)?.date || '';
const rangeEnd = [...githubCells].reverse().find((c) => c.date)?.date || [...ankiCells].reverse().find((c) => c.date)?.date || '';

const rangeLabel =
  rangeStart && rangeEnd
    ? `${fmtRange.format(parseIsoDateUTC(rangeStart))} to ${fmtRange.format(parseIsoDateUTC(rangeEnd))}`
    : 'Last 7 days';
---

<section
  data-activity-monitor
  class="col-span-1 md:col-span-6 lg:col-span-8 min-w-0 rounded-xl border border-neutral-200 bg-white p-6"
>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">Activity Monitor</h2>
    <div class="text-xxs font-mono text-neutral-400" data-range>{rangeLabel}</div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_1px_1fr] gap-6 lg:gap-x-8 lg:gap-y-0 min-w-0">
    <div class="min-w-0">
      <div class="flex items-center gap-2 mb-3">
        <GitHub class="w-4 h-4 text-neutral-800" />
        <span class="text-sm font-semibold">GitHub</span>
      </div>

      <div class="activity-tags" data-tags="github" aria-label="GitHub activity, last 7 days">
        {githubCells.map((cell, i) => {
          const d = cell.date ? parseIsoDateUTC(cell.date) : null;
          const dow = d ? fmtDay.format(d) : '---';
          return (
          <button
            type="button"
            class:list={[
              'activity-tag rounded-lg border flex flex-col items-center justify-center leading-none select-none transition hover:ring-2 hover:ring-neutral-300 focus:outline-none focus:ring-2 focus:ring-neutral-400',
              levelClass('github', cell.level),
            ]}
            aria-label={`GitHub day ${i + 1}`}
            data-source="github"
            data-date={cell.date}
            data-count={String(cell.count)}
            data-level={String(cell.level)}
          >
            <span class="tag-dow text-[10px] font-mono opacity-90">{dow}</span>
            <span class="tag-count text-xs font-semibold">{cell.count}</span>
          </button>
          );
        })}
      </div>
    </div>

    <div class="hidden lg:block w-px bg-neutral-100 rounded-full" aria-hidden="true"></div>

    <div class="min-w-0">
      <div class="flex items-center gap-2 mb-3">
        <BrainCircuit class="w-4 h-4 text-neutral-800" />
        <span class="text-sm font-semibold">Anki</span>
        <span class="text-xs text-neutral-400 ml-auto">
          Streak: <span data-streak="anki">{typeof activity?.anki?.streak === 'number' ? activity.anki.streak : 0}</span>
        </span>
      </div>

      <div class="activity-tags" data-tags="anki" aria-label="Anki activity, last 7 days">
        {ankiCells.map((cell, i) => {
          const d = cell.date ? parseIsoDateUTC(cell.date) : null;
          const dow = d ? fmtDay.format(d) : '---';
          return (
          <button
            type="button"
            class:list={[
              'activity-tag rounded-lg border flex flex-col items-center justify-center leading-none select-none transition hover:ring-2 hover:ring-neutral-300 focus:outline-none focus:ring-2 focus:ring-neutral-400',
              levelClass('anki', cell.level),
            ]}
            aria-label={`Anki day ${i + 1}`}
            data-source="anki"
            data-date={cell.date}
            data-count={String(cell.count)}
            data-level={String(cell.level)}
          >
            <span class="tag-dow text-[10px] font-mono opacity-90">{dow}</span>
            <span class="tag-count text-xs font-semibold">{cell.count}</span>
          </button>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Fit 7 nodes into the available width without wrapping or overflow. */
  @supports (container-type: inline-size) {
    [data-activity-monitor] {
      container-type: inline-size;
    }
  }

  [data-activity-monitor] .activity-tags {
    /* Slightly tighter by default to maximize node size. */
    --tag-gap: clamp(0.1875rem, 1cqw, 0.625rem);
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: var(--tag-gap);
    min-width: 0;
    container-type: inline-size;
  }

  [data-activity-monitor] .activity-tag {
    width: 100%;
    aspect-ratio: 1 / 1;
    min-width: 0;
  }

  /* Anki counts are much larger than GitHub contributions; keep them subtle. */
  [data-activity-monitor] .activity-tag[data-source='anki'] .tag-count {
    font-size: 0.65rem;
    line-height: 1;
    font-weight: 600;
    opacity: 0.85;
    font-variant-numeric: tabular-nums;
  }

  /* When a panel gets tight, drop the weekday line so the count stays readable. */
  @container (max-width: 360px) {
    [data-activity-monitor] .activity-tag .tag-dow {
      display: none;
    }
    [data-activity-monitor] .activity-tag .tag-count {
      font-size: 0.9rem;
      line-height: 1;
    }
    /* Keep Anki smaller even in cramped layouts. */
    [data-activity-monitor] .activity-tag[data-source='anki'] .tag-count {
      font-size: 0.7rem;
    }
  }
</style>

<script is:inline type="module">
  const fmtTip = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

  const parseIsoDate = (s) => {
    // Treat YYYY-MM-DD as a UTC date to avoid local TZ shifting.
    const [y, m, d] = String(s).split('-').map((v) => Number(v));
    return new Date(Date.UTC(y, m - 1, d));
  };

  const bindTooltip = () => {
    const tip = document.createElement('div');
    tip.setAttribute('data-tooltip', 'activity');
    tip.className =
      'pointer-events-none fixed z-50 hidden rounded-md border border-neutral-200 bg-white px-2 py-1 text-[11px] text-neutral-800 shadow-lg';
    document.body.appendChild(tip);

    const show = (el, x, y) => {
      const source = el.dataset.source ?? '';
      const date = el.dataset.date ?? '';
      const count = Number(el.dataset.count ?? 0);
      const label = source === 'github' ? 'GitHub' : source === 'anki' ? 'Anki' : source;
      const dateStr = date ? fmtTip.format(parseIsoDate(date)) : '';

      tip.textContent = dateStr ? `${label}: ${dateStr} (${count})` : `${label}: (${count})`;
      tip.style.left = `${Math.min(window.innerWidth - 10, x + 12)}px`;
      tip.style.top = `${Math.min(window.innerHeight - 10, y + 12)}px`;
      tip.classList.remove('hidden');
    };
    const hide = () => tip.classList.add('hidden');

    const bind = () => {
      const nodes = document.querySelectorAll('[data-tags] button[data-source]');
      for (const el of nodes) {
        el.addEventListener('mouseenter', (e) => show(el, e.clientX, e.clientY));
        el.addEventListener('mousemove', (e) => show(el, e.clientX, e.clientY));
        el.addEventListener('mouseleave', hide);

        el.addEventListener('focus', () => {
          const r = el.getBoundingClientRect();
          show(el, r.left + r.width / 2, r.top + r.height / 2);
        });
        el.addEventListener('blur', hide);
      }
    };

    bind();
    return bind;
  };

  bindTooltip();
</script>
