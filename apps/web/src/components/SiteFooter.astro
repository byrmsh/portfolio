---
import { readFileSync } from 'node:fs';
import { SITE } from '../config/site';
import { DEFAULT_LOCALE, SUPPORTED_LOCALES, type SupportedLocale } from '../i18n';
import { localizedPath } from '../i18n';

interface Props {
  locale: SupportedLocale;
  t: (path: string, vars?: Record<string, string | number>) => string;
}

const { t, locale } = Astro.props;
const GIT_METADATA_FILE = process.env.GIT_METADATA_FILE ?? './apps/web/dist/git-meta.json';

function getRepoUrlFromMetadata(): string | null {
  try {
    const raw = readFileSync(GIT_METADATA_FILE, 'utf8');
    const parsed = JSON.parse(raw) as { repoUrl?: unknown };
    return typeof parsed.repoUrl === 'string' ? parsed.repoUrl : null;
  } catch {
    return null;
  }
}

const sourceUrl = getRepoUrlFromMetadata() ?? '#';
---

<footer class="border-t border-[var(--border-subtle)] py-8 mt-4">
  <div
    class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-[var(--text-subtle)]"
  >
    <div class="font-mono">
      {
        t('footer.copyright', {
          year: new Date().getFullYear(),
          name: SITE.name,
        })
      }
    </div>
    <div class="flex items-center gap-2" data-footer-locale-control>
      <label class="text-xxs font-mono text-[var(--text-subtle)]" for="footer-lang-select"
        >{t('footer.language')}</label
      >
      <select
        id="footer-lang-select"
        class="text-xs border border-[var(--border-subtle)] rounded-md px-2 py-1 bg-[var(--surface)]"
        aria-label={t('footer.language')}
        data-footer-locale-select
      >
        {
          SUPPORTED_LOCALES.map((optionLocale) => (
            <option value={optionLocale} selected={optionLocale === locale}>
              {optionLocale.toUpperCase()}
            </option>
          ))
        }
      </select>
    </div>
    <div class="flex items-center gap-6">
      <a
        href={sourceUrl}
        target="_blank"
        class="hover:text-[var(--text-primary)] transition-colors"
      >
        {t('footer.source')}
      </a>
      <a
        href={localizedPath(locale, '/rss.xml')}
        class="hover:text-[var(--text-primary)] transition-colors"
      >
        {t('footer.rss')}
      </a>
    </div>
  </div>
</footer>

<script is:inline define:vars={{ SUPPORTED_LOCALES, DEFAULT_LOCALE }}>
  const SUPPORTED = SUPPORTED_LOCALES;
  const DEFAULT = DEFAULT_LOCALE;
  const select = document.querySelector('[data-footer-locale-select]');
  if (select instanceof HTMLSelectElement) {
    select.addEventListener('change', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLSelectElement)) return;
      const nextLocale = target.value;
      const current = new URL(window.location.href);
      const parts = current.pathname.split('/').filter(Boolean);
      if (parts.length && SUPPORTED.includes(parts[0])) parts.shift();
      const rest = `/${parts.join('/')}`;
      current.pathname =
        nextLocale === DEFAULT ? rest : `/${nextLocale}${rest === '/' ? '' : rest}`;
      window.location.href = `${current.pathname}${current.search}${current.hash}`;
    });
  }
</script>

<noscript>
  <style>
    [data-footer-locale-control] {
      display: none;
    }
  </style>
</noscript>
