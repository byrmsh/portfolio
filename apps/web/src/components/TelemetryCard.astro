---
interface Props {
  title?: string;
  status?: string;
  description?: string;
  nextSync?: string;
  source?: string;
}

const {
  title = 'Telemetry',
  status = 'Scraper queue idle',
  description = 'Waiting on job sources and GitHub GraphQL ingest.',
  nextSync = 'Next sync: manual trigger',
  source = 'Source: Upwork RSS + GitHub',
}: Props = Astro.props;
---

<div class="rounded-xl border border-neutral-200 bg-white p-5">
  <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">{title}</p>
  <p class="mt-3 text-2xl font-semibold">{status}</p>
  <p class="mt-2 text-sm text-neutral-500">{description}</p>
  <div class="mt-4 grid gap-2 text-xs uppercase tracking-[0.25em] text-neutral-500">
    <span>{nextSync}</span>
    <span>{source}</span>
  </div>
</div>
