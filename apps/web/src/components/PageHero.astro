---
import { SITE } from '../config/site';

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
}

const { t } = Astro.props;
---

<header class="flex flex-col gap-6">
  <div>
    <h1 class="text-4xl font-semibold tracking-tight mb-3">{SITE.name}</h1>
    <p class="max-w-2xl text-[var(--text-body)] text-lg">
      {t('hero.subtitle')}
      <br />
      {t('hero.description')}
    </p>
  </div>
</header>
