---
import ArrowUpRight from '@lucide/astro/icons/arrow-up-right';
import { execFileSync } from 'node:child_process';
import { readFileSync } from 'node:fs';
import type { SupportedLocale } from '../i18n';

interface Props {
  t: (path: string, vars?: Record<string, string | number>) => string;
  locale: SupportedLocale;
}

type Commit = {
  hash: string;
  shortHash: string;
  author: string;
  authoredAt: string;
  subject: string;
};

type ParsedCommit = {
  type: string;
  scope: string | null;
  description: string;
  breaking: boolean;
};

type GitMetadata = {
  commits: Commit[];
  totalChanges: number;
  repoUrl: string | null;
};

const { t, locale } = Astro.props;
const RECENT_LIMIT = 3;
const GIT_METADATA_FILE = process.env.GIT_METADATA_FILE ?? './apps/web/dist/git-meta.json';

function runGit(args: string[]): string {
  return execFileSync('git', args, { encoding: 'utf8' }).trim();
}

function getRecentCommits(limit = RECENT_LIMIT): Commit[] {
  try {
    const output = runGit([
      'log',
      '-n',
      String(limit),
      '--date=iso-strict',
      '--pretty=format:%H%x1f%h%x1f%aN%x1f%aI%x1f%s',
    ]);

    if (!output) return [];

    return output
      .split('\n')
      .map((line) => {
        const [hash, shortHash, author, authoredAt, subject] = line.split('\x1f');
        if (!hash || !shortHash || !author || !authoredAt || !subject) return null;
        return { hash, shortHash, author, authoredAt, subject } satisfies Commit;
      })
      .filter((commit): commit is Commit => Boolean(commit));
  } catch {
    return [];
  }
}

function getTotalCommitCount(): number {
  try {
    const raw = runGit(['rev-list', '--count', 'HEAD']);
    const value = Number(raw);
    return Number.isFinite(value) && value >= 0 ? value : 0;
  } catch {
    return 0;
  }
}

function getGitMetadataFromFile(): GitMetadata | null {
  try {
    const raw = readFileSync(GIT_METADATA_FILE, 'utf8');
    const parsed = JSON.parse(raw) as Partial<GitMetadata>;
    const commits = Array.isArray(parsed.commits) ? parsed.commits : [];
    const totalChanges =
      typeof parsed.totalChanges === 'number' && parsed.totalChanges >= 0
        ? parsed.totalChanges
        : 0;
    const repoUrl = typeof parsed.repoUrl === 'string' ? parsed.repoUrl : null;
    return { commits, totalChanges, repoUrl };
  } catch {
    return null;
  }
}

function normalizeGitHubRepoUrl(remote: string): string | null {
  const trimmed = remote.trim().replace(/\.git$/, '');
  if (!trimmed) return null;

  if (trimmed.startsWith('https://github.com/')) return trimmed;

  if (trimmed.startsWith('git@github.com:')) {
    const path = trimmed.slice('git@github.com:'.length);
    return path ? `https://github.com/${path}` : null;
  }

  if (trimmed.startsWith('ssh://git@github.com/')) {
    const path = trimmed.slice('ssh://git@github.com/'.length);
    return path ? `https://github.com/${path}` : null;
  }

  return null;
}

function getRepoUrlFromOrigin(): string | null {
  try {
    const remote = runGit(['config', '--get', 'remote.origin.url']);
    return normalizeGitHubRepoUrl(remote);
  } catch {
    return null;
  }
}

function parseConventionalSubject(subject: string): ParsedCommit {
  const match = /^([a-z]+)(\(([^)]+)\))?(!)?:\s*(.+)$/i.exec(subject.trim());
  if (!match) {
    return {
      type: 'update',
      scope: null,
      description: capitalizeMessage(subject.trim()),
      breaking: false,
    };
  }

  const [, rawType, , scope, bang, rawDescription] = match;
  return {
    type: String(rawType).toLowerCase(),
    scope: scope ?? null,
    description: capitalizeMessage(String(rawDescription).trim()),
    breaking: bang === '!',
  };
}

function capitalizeMessage(value: string): string {
  if (!value) return value;
  return value.charAt(0).toUpperCase() + value.slice(1);
}

function commitTypeClass(type: string): string {
  const map: Record<string, string> = {
    feat: 'bg-emerald-100 text-emerald-800 border-emerald-300',
    fix: 'bg-amber-100 text-amber-800 border-amber-300',
    docs: 'bg-sky-100 text-sky-800 border-sky-300',
    chore: 'bg-zinc-100 text-zinc-800 border-zinc-300',
    refactor: 'bg-cyan-100 text-cyan-800 border-cyan-300',
    perf: 'bg-lime-100 text-lime-800 border-lime-300',
    test: 'bg-orange-100 text-orange-800 border-orange-300',
    ci: 'bg-indigo-100 text-indigo-800 border-indigo-300',
    build: 'bg-teal-100 text-teal-800 border-teal-300',
    style: 'bg-neutral-100 text-neutral-700 border-neutral-300',
  };

  return map[type] ?? 'bg-neutral-100 text-neutral-700 border-neutral-300';
}

function labelForType(type: string): string {
  const labels: Record<string, string> = {
    feat: 'FEATURE',
    fix: 'FIX',
    docs: 'DOCUMENTATION',
    chore: 'MAINTENANCE',
    refactor: 'REFACTOR',
    test: 'TEST',
  };
  return labels[type] ?? type.toUpperCase();
}

const metadata = getGitMetadataFromFile();
const commits = metadata?.commits.length ? metadata.commits : getRecentCommits();
const totalChanges = metadata ? metadata.totalChanges : getTotalCommitCount();
const repoUrl = metadata?.repoUrl ?? getRepoUrlFromOrigin();
const dateFormatter = new Intl.DateTimeFormat(locale, {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<section
  class="col-span-1 md:col-span-6 lg:col-span-12 rounded-xl border border-neutral-200 bg-white p-6"
>
  <div class="flex items-center justify-between gap-3 mb-5">
    <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400 whitespace-nowrap">
      {t('gitCommits.title')}
    </h2>
    <span class="text-xxs font-mono text-neutral-400 whitespace-nowrap">
      {t('gitCommits.totalChanges', { value: totalChanges })}
    </span>
  </div>

  {
    commits.length > 0 ? (
      <div class="space-y-6 md:space-y-1.5">
        {commits.map((commit) => {
          const parsed = parseConventionalSubject(commit.subject);
          return (
            <article class="border-b border-neutral-100 px-2 pb-4 pt-1.5 transition-colors hover:bg-neutral-50 last:border-b-0 md:border-b-0 md:py-1.5">
              <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                <div class="min-w-0 flex-1">
                  <p class="mb-2 text-sm font-semibold font-sans text-neutral-900 leading-snug break-words md:mb-0">
                    {parsed.description}
                  </p>
                  <div class="md:hidden">
                    <div class="mb-3 flex flex-wrap gap-2">
                      <span
                        class:list={[
                          'inline-flex shrink-0 items-center rounded-md border px-1.5 py-0.5 text-[10px] font-bold tracking-wide whitespace-nowrap',
                          commitTypeClass(parsed.type),
                        ]}
                      >
                        {labelForType(parsed.type)}
                      </span>
                      {parsed.scope ? (
                        <span class="inline-flex shrink-0 items-center rounded-md border border-neutral-300 bg-white px-1.5 py-0.5 text-[10px] font-mono text-neutral-600 whitespace-nowrap">
                          {parsed.scope}
                        </span>
                      ) : null}
                      {parsed.breaking ? (
                        <span class="inline-flex shrink-0 items-center rounded-md border border-rose-300 bg-rose-100 px-1.5 py-0.5 text-[10px] font-bold text-rose-800 whitespace-nowrap">
                          BREAKING
                        </span>
                      ) : null}
                    </div>
                    <div class="grid grid-cols-[min-content_1fr] gap-x-3 gap-y-1 text-xs">
                      <span class="text-right font-mono text-[11px] uppercase tracking-wide text-neutral-400">
                        HASH:
                      </span>
                      <span class="inline-flex min-w-0 items-center gap-1.5 font-mono text-[11px] text-neutral-800">
                        <code title={commit.hash}>{commit.shortHash}</code>
                        {repoUrl ? (
                          <a
                            href={`${repoUrl}/commit/${commit.hash}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex shrink-0 text-neutral-400 transition-colors hover:text-neutral-700"
                            aria-label={t('gitCommits.openCommit', { hash: commit.shortHash })}
                            title={t('gitCommits.openCommit', { hash: commit.shortHash })}
                          >
                            <ArrowUpRight class="w-3.5 h-3.5" />
                          </a>
                        ) : null}
                      </span>

                      <span class="text-right font-mono text-[11px] uppercase tracking-wide text-neutral-400">
                        DATE:
                      </span>
                      <time class="font-mono text-[11px] text-neutral-800" datetime={commit.authoredAt}>
                        {dateFormatter.format(new Date(commit.authoredAt))}
                      </time>

                      <span class="text-right font-mono text-[11px] uppercase tracking-wide text-neutral-400">
                        AUTH:
                      </span>
                      <span class="font-mono text-[11px] text-neutral-800 break-words">{commit.author}</span>
                    </div>
                  </div>
                  <div class="mt-1 hidden flex-wrap items-center gap-x-4 gap-y-1 text-xs md:flex">
                    <span class="inline-flex items-center gap-1.5">
                      <span class="font-mono text-[11px] uppercase tracking-wide text-neutral-400">HASH:</span>
                      <code class="font-mono text-[11px] text-neutral-600" title={commit.hash}>
                        {commit.shortHash}
                      </code>
                      {repoUrl ? (
                        <a
                          href={`${repoUrl}/commit/${commit.hash}`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex text-neutral-400 hover:text-neutral-700 transition-colors"
                          aria-label={t('gitCommits.openCommit', { hash: commit.shortHash })}
                          title={t('gitCommits.openCommit', { hash: commit.shortHash })}
                        >
                          <ArrowUpRight class="w-3.5 h-3.5" />
                        </a>
                      ) : null}
                    </span>
                    <span class="inline-flex items-center gap-1.5">
                      <span class="font-mono text-[11px] uppercase tracking-wide text-neutral-400">AUTHOR:</span>
                      <span class="text-neutral-700">{commit.author}</span>
                    </span>
                    <span class="inline-flex items-center gap-1.5">
                      <span class="font-mono text-[11px] uppercase tracking-wide text-neutral-400">DATE:</span>
                      <time class="text-neutral-700" datetime={commit.authoredAt}>
                        {dateFormatter.format(new Date(commit.authoredAt))}
                      </time>
                    </span>
                  </div>
                </div>

                <div class="hidden shrink-0 flex-wrap items-center justify-end gap-1.5 md:flex">
                  <span
                    class:list={[
                      'inline-flex shrink-0 items-center rounded-md border px-1.5 py-0.5 text-[10px] font-bold tracking-wide whitespace-nowrap',
                      commitTypeClass(parsed.type),
                    ]}
                  >
                    {labelForType(parsed.type)}
                  </span>
                  {parsed.scope ? (
                    <span class="inline-flex shrink-0 items-center rounded-md border border-neutral-300 bg-white px-1.5 py-0.5 text-[10px] font-mono text-neutral-600 whitespace-nowrap">
                      {parsed.scope}
                    </span>
                  ) : null}
                  {parsed.breaking ? (
                    <span class="inline-flex shrink-0 items-center rounded-md border border-rose-300 bg-rose-100 px-1.5 py-0.5 text-[10px] font-bold text-rose-800 whitespace-nowrap">
                      BREAKING
                    </span>
                  ) : null}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      <p class="text-sm text-neutral-500">{t('gitCommits.empty')}</p>
    )
  }
</section>
