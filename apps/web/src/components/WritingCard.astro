---
import ChevronRight from '@lucide/astro/icons/chevron-right';

interface Post {
  title: string;
  description: string;
  href: string;
}

interface Props {
  posts: Post[];
  t: (path: string, vars?: Record<string, string | number>) => string;
}

const { posts, t } = Astro.props;
---

<section
  class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-neutral-200 bg-white p-6"
>
  <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-5">
    {t('writing.title')}
  </h2>
  <ul class="space-y-4">
    {
      posts.map((post) => (
        <li class="group">
          <a href={post.href} class="block">
            <h3 class="text-sm font-semibold text-neutral-800 group-hover:text-accent transition-colors">
              {post.title}
            </h3>
            <p class="text-xs text-neutral-500 mt-1 line-clamp-1">{post.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
  <div class="mt-6 pt-4 border-t border-neutral-100">
    <a
      href="#"
      class="text-xs font-medium text-neutral-500 hover:text-neutral-900 flex items-center gap-1"
    >
      {t('writing.allPosts')}
      <ChevronRight class="w-3 h-3" />
    </a>
  </div>
</section>
