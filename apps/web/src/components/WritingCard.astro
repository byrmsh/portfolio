---
import ChevronRight from '@lucide/astro/icons/chevron-right';
import WidgetHeader from './WidgetHeader.astro';

interface Post {
  title: string;
  description: string;
  href: string;
}

interface Props {
  posts: Post[];
  allHref: string;
  t: (path: string, vars?: Record<string, string | number>) => string;
}

const { posts, t, allHref } = Astro.props;
---

<section
  class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6"
>
  <WidgetHeader title={t('writing.title')} class="mb-5" />
  <ul class="space-y-4">
    {
      posts.map((post) => (
        <li class="group">
          <a href={post.href} class="block">
            <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-accent transition-colors">
              {post.title}
            </h3>
            <p class="text-xs text-[var(--text-subtle)] mt-1 line-clamp-1">{post.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
  <div class="mt-6 pt-4 border-t border-[var(--border-muted)]">
    <a
      href={allHref}
      class="text-xs font-medium text-[var(--text-subtle)] hover:text-[var(--text-primary)] flex items-center gap-1"
    >
      {t('writing.all_posts')}
      <ChevronRight class="w-3 h-3" />
    </a>
  </div>
</section>
