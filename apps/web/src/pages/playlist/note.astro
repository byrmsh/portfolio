---
export const prerender = false;

import { normalizeLocale, localizedPath } from '../../i18n';

const id = Astro.url.searchParams.get('id');
const lang = Astro.url.searchParams.get('lang');
const locale = lang ? normalizeLocale(lang) : normalizeLocale(null);
if (!id) {
  const response = Astro.redirect(localizedPath(locale, '/playlist'));
  void response;
  return response;
}

const response = Astro.redirect(localizedPath(locale, `/playlist/${encodeURIComponent(id)}`));
void response;
return response;
---
