---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import PageHero from '../components/PageHero.astro';
import ActivityMonitor from '../components/ActivityMonitor.astro';
import SonicArchivesCard from '../components/SonicArchivesCard.astro';
import WritingCard from '../components/WritingCard.astro';
import KnowledgeGraphCard from '../components/KnowledgeGraphCard.astro';
import JobScoutCard from '../components/JobScoutCard.astro';
import SystemHealthCard from '../components/SystemHealthCard.astro';
import SiteFooter from '../components/SiteFooter.astro';

const writingPosts = [
  {
    title: 'Zero Trust K3s with Pulumi',
    description: 'Hardening the homelab with Cilium & mTLS.',
    href: '#',
  },
  {
    title: 'Welcome to the Monorepo',
    description: 'Why I treat my portfolio as a product.',
    href: '#',
  },
];
---

<Layout title="Bayram Şahin | Systems Console">
  <SiteNav />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto flex flex-col gap-10">
      <PageHero />

      <div class="grid grid-cols-1 md:grid-cols-6 lg:grid-cols-12 gap-5">
        <ActivityMonitor />
        <SonicArchivesCard />
        <WritingCard posts={writingPosts} />
        <KnowledgeGraphCard />
        <JobScoutCard />
        <SystemHealthCard />
      </div>

      <SiteFooter />
    </div>
  </main>
</Layout>
