---
import Layout from '../layouts/Layout.astro';
import Menu from '@lucide/astro/icons/menu';
import Github from '@lucide/astro/icons/github';
import BrainCircuit from '@lucide/astro/icons/brain-circuit';
import Disc from '@lucide/astro/icons/disc';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import ChevronRight from '@lucide/astro/icons/chevron-right';
---

<Layout title="Bayram Şahin | Systems Console">
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-neutral-200 glass-header">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a
        href="/"
        class="font-mono text-sm font-semibold tracking-tight hover:opacity-70 transition-opacity"
      >
        bayram.sh
      </a>
      <div class="hidden sm:flex items-center gap-6 text-sm font-medium text-neutral-600">
        <a href="#" class="text-neutral-900">Home</a>
        <a href="#" class="hover:text-neutral-900 transition-colors">Blog</a>
        <a href="#" class="hover:text-neutral-900 transition-colors">Lyrics</a>
        <a href="#" class="hover:text-neutral-900 transition-colors">Jobs</a>
        <a href="#" class="hover:text-neutral-900 transition-colors">Contact</a>
      </div>
      <button class="sm:hidden p-1">
        <Menu class="w-5 h-5 text-neutral-600" />
      </button>
    </div>
  </nav>

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto flex flex-col gap-10">
      <header class="flex flex-col gap-6">
        <div>
          <h1 class="text-4xl font-semibold tracking-tight mb-3">Bayram Şahin</h1>
          <p class="max-w-2xl text-neutral-600 text-lg">
            Full-Stack Engineer & DevOps Practitioner. <br />
            Building functional systems and documenting the process.
          </p>
        </div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-6 lg:grid-cols-12 gap-5">
        <div
          class="col-span-1 md:col-span-6 lg:col-span-8 rounded-xl border border-neutral-200 bg-white p-6 flex flex-col justify-between"
        >
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">
              Activity Monitor
            </h2>
            <div class="flex gap-2 text-xxs font-mono text-neutral-400">
              <span>Less</span>
              <div class="flex gap-0.5">
                <span class="w-2 h-2 bg-neutral-100 rounded-[1px]"></span>
                <span class="w-2 h-2 bg-neutral-300 rounded-[1px]"></span>
                <span class="w-2 h-2 bg-neutral-500 rounded-[1px]"></span>
                <span class="w-2 h-2 bg-neutral-800 rounded-[1px]"></span>
              </div>
              <span>More</span>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <div class="flex items-center gap-2 mb-3">
                <Github class="w-4 h-4 text-neutral-800" />
                <span class="text-sm font-semibold">GitHub</span>
                <span class="text-xs text-neutral-400 ml-auto">Last 30 days</span>
              </div>
              <div class="grid grid-cols-7 gap-1.5 w-max">
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-300 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-500 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-300 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-500 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-300 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-300 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-300 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-500 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-accent rounded-[2px] animate-pulse"></div>
              </div>
            </div>

            <div class="relative pl-0 sm:pl-8 sm:border-l border-neutral-100">
              <div class="flex items-center gap-2 mb-3">
                <BrainCircuit class="w-4 h-4 text-neutral-800" />
                <span class="text-sm font-semibold">Anki</span>
                <span class="text-xs text-neutral-400 ml-auto">Streak: 42</span>
              </div>
              <div class="grid grid-cols-7 gap-1.5 w-max">
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-500 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-500 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-500 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-300 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-500 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-800 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-300 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-accent rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
                <div class="w-3 h-3 bg-neutral-100 rounded-[2px]"></div>
              </div>
            </div>
          </div>
        </div>

        <div
          class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-neutral-200 bg-white p-6 flex flex-col relative overflow-hidden group"
        >
          <div class="relative z-10">
            <div class="flex justify-between items-start mb-6">
              <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">
                Sonic Archives
              </h2>
              <Disc class="w-4 h-4 text-neutral-400" />
            </div>
            <div class="flex gap-4">
              <div
                class="w-16 h-16 bg-neutral-900 rounded-md shadow-sm flex items-center justify-center shrink-0"
              >
                <div class="w-6 h-6 rounded-full border-2 border-neutral-700"></div>
              </div>
              <div class="flex flex-col justify-center">
                <div class="text-sm font-semibold text-neutral-900 line-clamp-1">
                  Everything In Its Right Place
                </div>
                <div class="text-xs text-neutral-500 mt-1">Radiohead</div>
                <a
                  href="#"
                  class="mt-2 text-xxs font-mono text-accent hover:text-accent/80 flex items-center gap-1"
                >
                  READ LYRIC NOTE <ArrowRight class="w-3 h-3" />
                </a>
              </div>
            </div>
          </div>
        </div>

        <div
          class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-neutral-200 bg-white p-6"
        >
          <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-5">Writing</h2>
          <ul class="space-y-4">
            <li class="group">
              <a href="#" class="block">
                <h3
                  class="text-sm font-semibold text-neutral-800 group-hover:text-accent transition-colors"
                >
                  Zero Trust K3s with Pulumi
                </h3>
                <p class="text-xs text-neutral-500 mt-1 line-clamp-1">
                  Hardening the homelab with Cilium & mTLS.
                </p>
              </a>
            </li>
            <li class="group">
              <a href="#" class="block">
                <h3
                  class="text-sm font-semibold text-neutral-800 group-hover:text-accent transition-colors"
                >
                  Welcome to the Monorepo
                </h3>
                <p class="text-xs text-neutral-500 mt-1 line-clamp-1">
                  Why I treat my portfolio as a product.
                </p>
              </a>
            </li>
          </ul>
          <div class="mt-6 pt-4 border-t border-neutral-100">
            <a
              href="#"
              class="text-xs font-medium text-neutral-500 hover:text-neutral-900 flex items-center gap-1"
            >
              All Posts <ChevronRight class="w-3 h-3" />
            </a>
          </div>
        </div>

        <div
          class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-neutral-200 bg-neutral-900 text-white p-6 relative overflow-hidden"
        >
          <div class="relative z-10 flex flex-col h-full justify-between">
            <div class="flex justify-between items-start">
              <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-500">
                Knowledge Graph
              </h2>
              <span
                class="text-xxs font-mono text-neutral-500 border border-neutral-700 px-1.5 py-0.5 rounded"
                >OBSIDIAN</span
              >
            </div>
            <div class="mt-4">
              <div class="text-2xl font-light">142 Nodes</div>
              <p class="text-xs text-neutral-400 mt-1">
                Interlinked notes on DevOps, Philosophy, and Music.
              </p>
            </div>
          </div>

          <div class="absolute inset-0 opacity-20 pointer-events-none">
            <svg width="100%" height="100%">
              <circle cx="80%" cy="20%" r="3" fill="white"></circle>
              <circle cx="20%" cy="80%" r="3" fill="white"></circle>
              <circle cx="50%" cy="50%" r="2" fill="white"></circle>
              <line x1="20%" y1="80%" x2="50%" y2="50%" stroke="white" stroke-width="0.5"></line>
              <line x1="80%" y1="20%" x2="50%" y2="50%" stroke="white" stroke-width="0.5"></line>
            </svg>
          </div>
        </div>

        <div
          class="col-span-1 md:col-span-6 lg:col-span-4 rounded-xl border border-neutral-200 bg-white p-6 flex flex-col"
        >
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">Job Scout</h2>
            <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
          </div>

          <div class="flex-grow flex flex-col justify-center">
            <div class="p-3 bg-neutral-50 rounded-lg border border-neutral-100">
              <div class="flex justify-between items-start mb-2">
                <span class="text-xs font-bold text-neutral-700">Upwork</span>
                <span class="text-xxs font-mono text-neutral-400">2m ago</span>
              </div>
              <p class="text-sm font-medium text-neutral-900 line-clamp-2">
                Kubernetes Specialist needed for migrating legacy Express apps to K3s
              </p>
              <div class="mt-2 flex gap-2">
                <span
                  class="text-xxs border border-neutral-200 px-1 py-0.5 rounded text-neutral-500"
                  >DevOps</span
                >
                <span
                  class="text-xxs border border-neutral-200 px-1 py-0.5 rounded text-neutral-500"
                  >Node.js</span
                >
              </div>
            </div>
          </div>

          <div class="mt-4 text-center">
            <a href="#" class="text-xs text-neutral-400 hover:text-neutral-900 transition-colors"
              >View all captured leads</a
            >
          </div>
        </div>

        <div
          class="col-span-1 md:col-span-6 lg:col-span-12 rounded-xl border border-neutral-200 bg-white p-6"
        >
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
            <div class="flex items-center gap-3">
              <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">
                System Health
              </h2>
              <span class="text-xxs font-mono text-neutral-400 bg-neutral-100 px-2 py-0.5 rounded"
                >k8s/portfolio-ns</span
              >
            </div>
            <div class="text-xxs font-mono text-neutral-400">UPTIME: 99.9%</div>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                <span class="text-sm font-semibold text-neutral-800">apps/web</span>
              </div>
              <span class="text-xs text-neutral-500 pl-3.5">Astro SSR</span>
            </div>

            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                <span class="text-sm font-semibold text-neutral-800">apps/api</span>
              </div>
              <span class="text-xs text-neutral-500 pl-3.5">Hono / Node</span>
            </div>

            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                <span class="text-sm font-semibold text-neutral-800">apps/collector</span>
              </div>
              <span class="text-xs text-neutral-500 pl-3.5">Python Worker</span>
            </div>

            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                <span class="text-sm font-semibold text-neutral-800">apps/upworker</span>
              </div>
              <span class="text-xs text-neutral-500 pl-3.5">Scraper Active</span>
            </div>

            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                <span class="text-sm font-semibold text-neutral-800">dragonfly</span>
              </div>
              <span class="text-xs text-neutral-500 pl-3.5">Redis-compatible</span>
            </div>
          </div>
        </div>
      </div>

      <footer class="border-t border-neutral-200 py-8 mt-4">
        <div
          class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-neutral-500"
        >
          <div class="font-mono">© 2026 Bayram Şahin</div>
          <div class="flex items-center gap-6">
            <a href="#" class="hover:text-neutral-900 transition-colors">Source</a>
            <a href="#" class="hover:text-neutral-900 transition-colors">RSS</a>
          </div>
        </div>
      </footer>
    </div>
  </main>
</Layout>
