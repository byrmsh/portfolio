---
export const prerender = false;

import BlogPostPage from '../../../views/BlogPostPage.astro';
import { DEFAULT_LOCALE, getLocaleFromUrl, isSupportedLocale, localizedPath } from '../../../i18n';

const { lang, slug } = Astro.params;
if (!lang || !isSupportedLocale(lang)) return new Response(null, { status: 404 });
if (lang === DEFAULT_LOCALE) return Astro.redirect(slug ? `/blog/${slug}` : '/blog');

const locale = getLocaleFromUrl(Astro.url);
if (!slug) {
  const response = Astro.redirect(localizedPath(locale, '/blog'));
  void response;
  return response;
}
---

<BlogPostPage slug={slug} url={Astro.url} />
