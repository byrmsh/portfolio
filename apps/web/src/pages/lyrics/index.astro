---
import ky from 'ky';
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { SITE } from '../../config/site';

const apiOrigin =
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

type SavedLyricNote = {
  id: string;
  title: string;
  artist: string;
  noteUrl: string;
  albumArtUrl?: string | null;
  savedAt: string;
};

let latest: SavedLyricNote | null = null;
let list: SavedLyricNote[] = [];
let total = 0;
const offset = Math.max(0, Number.parseInt(Astro.url.searchParams.get('offset') ?? '0', 10) || 0);
const limit = Math.min(200, Math.max(1, Number.parseInt(Astro.url.searchParams.get('limit') ?? '50', 10) || 50));

try {
  const json = await ky
    .get(`${apiOrigin}/api/ytmusic/saved/latest`, {
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: SavedLyricNote | null }>();
  if (json?.data) latest = json.data;
} catch {
  latest = null;
}

try {
  const json = await ky
    .get(`${apiOrigin}/api/ytmusic/saved`, {
      searchParams: { offset: String(offset), limit: String(limit) },
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: { items?: SavedLyricNote[]; total?: number } }>();
  list = json?.data?.items ?? [];
  total = json?.data?.total ?? 0;
} catch {
  list = [];
  total = 0;
}

const latestHref = latest?.id ? `/lyrics/${encodeURIComponent(latest.id)}` : null;
const prevOffset = Math.max(0, offset - limit);
const nextOffset = offset + limit;
---

<Layout title={`${SITE.name} | Lyrics`}>
  <SiteNav />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <div class="text-xs font-bold uppercase tracking-widest text-neutral-400">Lyrics</div>
        <h1 class="mt-2 text-2xl font-semibold text-neutral-900">Lyric Notes</h1>
        <p class="mt-2 text-sm text-neutral-700">
          Background analysis and vocabulary notes. Full lyrics are hosted on external sites.
        </p>
      </header>

      <section class="rounded-xl border border-neutral-200 bg-white p-6">
        <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">Latest</h2>
        {latest && latestHref ? (
          <a href={latestHref} class="mt-4 flex items-center gap-4 hover:opacity-90">
            <div class="w-14 h-14 rounded-lg bg-neutral-900 overflow-hidden shrink-0">
              {latest.albumArtUrl ? (
                <img src={latest.albumArtUrl} alt="" class="w-14 h-14 object-cover" loading="lazy" />
              ) : null}
            </div>
            <div class="min-w-0">
              <div class="text-sm font-semibold text-neutral-900 line-clamp-1">{latest.title}</div>
              <div class="text-xs text-neutral-600 mt-1 line-clamp-1">{latest.artist}</div>
              <div class="text-xxs font-mono text-neutral-400 mt-2">
                Saved {new Date(latest.savedAt).toLocaleString('en-US')}
              </div>
            </div>
          </a>
        ) : (
          <p class="mt-3 text-sm text-neutral-700">No tracks processed yet.</p>
        )}
      </section>

      <section class="rounded-xl border border-neutral-200 bg-white p-6">
        <div class="flex items-baseline justify-between gap-6">
          <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">
            All ({total || list.length})
          </h2>
          <div class="flex items-center gap-2 text-xxs font-mono text-neutral-500">
            <span>
              {Math.min(total, offset + 1)}-{Math.min(total, offset + Math.max(0, list.length))} / {total}
            </span>
          </div>
        </div>

        {list.length ? (
          <div class="mt-4 grid gap-3">
            {list.map((t) => {
              const href = `/lyrics/${encodeURIComponent(t.id)}`;
              return (
                <a href={href} class="flex items-center gap-4 rounded-lg border border-neutral-200 p-3 hover:bg-neutral-50">
                  <div class="w-12 h-12 rounded-lg bg-neutral-900 overflow-hidden shrink-0">
                    {t.albumArtUrl ? (
                      <img src={t.albumArtUrl} alt="" class="w-12 h-12 object-cover" loading="lazy" />
                    ) : null}
                  </div>
                  <div class="min-w-0">
                    <div class="text-sm font-semibold text-neutral-900 line-clamp-1">{t.title}</div>
                    <div class="text-xs text-neutral-600 mt-1 line-clamp-1">{t.artist}</div>
                    <div class="text-xxs font-mono text-neutral-400 mt-2">
                      Saved {new Date(t.savedAt).toLocaleString('en-US')}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <p class="mt-3 text-sm text-neutral-700">No tracks processed yet.</p>
        )}

        <div class="mt-5 flex items-center justify-between">
          {offset > 0 ? (
            <a
              class="text-xxs font-mono rounded-full border border-neutral-200 px-3 py-1 hover:bg-neutral-50"
              href={`/lyrics?offset=${encodeURIComponent(String(prevOffset))}&limit=${encodeURIComponent(String(limit))}`}
            >
              PREV
            </a>
          ) : (
            <span />
          )}
          {total > nextOffset ? (
            <a
              class="text-xxs font-mono rounded-full border border-neutral-200 px-3 py-1 hover:bg-neutral-50"
              href={`/lyrics?offset=${encodeURIComponent(String(nextOffset))}&limit=${encodeURIComponent(String(limit))}`}
            >
              NEXT
            </a>
          ) : (
            <span />
          )}
        </div>
      </section>

      <SiteFooter />
    </div>
  </main>
</Layout>
