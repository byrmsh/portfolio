---
export const prerender = false;

import { getLocaleFromUrl, localizedPath } from '../../i18n';
import LyricNotePage from '../../views/LyricNotePage.astro';

const { id } = Astro.params;
const locale = getLocaleFromUrl(Astro.url);
if (!id) {
  const response = Astro.redirect(localizedPath(locale, '/lyrics'));
  void response;
  return response;
}
---

<LyricNotePage id={id} url={Astro.url} />
