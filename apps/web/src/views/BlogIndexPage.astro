---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';
import { getCollection } from 'astro:content';

interface Props {
  url: URL;
}

const { url } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'medium' });
---

<Layout title={`${SITE.name} | ${t('meta.blog')}`} locale={locale}>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <div class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">
          {t('blog.eyebrow')}
        </div>
        <h1 class="mt-2 text-2xl font-semibold text-[var(--text-primary)]">{t('blog.title')}</h1>
        <p class="mt-2 text-sm text-[var(--text-body)]">{t('blog.description')}</p>
      </header>

      <section class="rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6">
        <ul class="space-y-5">
          {
            posts.map((post) => (
              <li>
                <a
                  href={localizedPath(locale, `/blog/${post.slug}`)}
                  class="block hover:opacity-90"
                >
                  <div class="text-xxs font-mono text-[var(--text-muted)]">
                    {dateFmt.format(post.data.pubDate)}
                  </div>
                  <div class="mt-1 text-base font-semibold text-[var(--text-primary)]">
                    {post.data.title}
                  </div>
                  <div class="mt-1 text-sm text-[var(--text-body)]">{post.data.description}</div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
