---
import ky from 'ky';
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LyricNoteView from '../components/LyricNoteView.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';
import type { YtMusicAnalysis } from '@portfolio/schema/dashboard';

interface Props {
  id: string;
  url: URL;
}

const { id, url } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const apiOrigin =
  process.env.API_ORIGIN ??
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

let analysis: YtMusicAnalysis | null = null;
let error: string | null = null;

try {
  const base = apiOrigin.replace(/\/$/, '');
  const res = await ky.get(`${base}/api/ytmusic/${encodeURIComponent(id)}/analysis`, {
    headers: { accept: 'application/json' },
    throwHttpErrors: false,
    timeout: 8000,
  });

  if (res.status === 404) {
    error = t('lyrics.not_found');
  } else if (!res.ok) {
    error = t('common.http_error', { status: res.status });
  } else {
    const json = (await res.json()) as { data?: YtMusicAnalysis };
    if (!json?.data?.id) error = t('lyrics.invalid_response');
    else analysis = json.data;
  }
} catch (e) {
  error = e instanceof Error ? e.message : t('lyrics.failed_to_load');
}
const seoDescription = analysis
  ? `${analysis.title} by ${analysis.artist}. ${analysis.background.tldr}`
  : t('lyrics.description');
---

<Layout
  title={`${SITE.name} | ${analysis?.title ?? t('meta.lyric_note')}`}
  locale={locale}
  description={seoDescription}
  canonicalPath={localizedPath(locale, `/playlist/${encodeURIComponent(id)}`)}
>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6 overflow-x-hidden [overflow-x:clip]">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <a
        href={localizedPath(locale, '/playlist')}
        class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)] hover:text-[var(--text-body)]"
      >
        {t('lyrics.back_to_all')}
      </a>
      <LyricNoteView
        analysis={analysis}
        error={error}
        locale={locale}
        labels={{
          couldNotLoadNote: t('lyrics.could_not_load_note'),
          openTrack: t('lyrics.open_track'),
          readLyrics: t('lyrics.read_lyrics'),
          updatedAt: t('lyrics.updated_at', { date: '{date}' }),
          background: t('lyrics.background'),
          flashcards: t('lyrics.flashcards'),
          flipHint: t('lyrics.flashcards_flip_hint'),
          tapHint: t('lyrics.flashcards_tap_hint'),
          rateHint: t('lyrics.flashcards_rate_hint'),
          knownHint: t('lyrics.flashcards_known_hint'),
          reviewHint: t('lyrics.flashcards_review_hint'),
          round: t('lyrics.flashcards_round', { round: '{round}' }),
          completed: t('lyrics.flashcards_completed'),
          completedSub: t('lyrics.flashcards_completed_sub'),
          remaining: t('lyrics.flashcards_remaining', { count: '{count}' }),
          reset: t('lyrics.flashcards_reset'),
          noScript: t('lyrics.flashcards_no_script'),
        }}
      />
      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
