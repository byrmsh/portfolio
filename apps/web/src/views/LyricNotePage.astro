---
import ky from 'ky';
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LyricNoteView from '../components/LyricNoteView.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';
import type { YtMusicAnalysis } from '@portfolio/schema/dashboard';

interface Props {
  id: string;
  url: URL;
}

const { id, url } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const apiOrigin =
  process.env.API_ORIGIN ??
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

let analysis: YtMusicAnalysis | null = null;
let error: string | null = null;

try {
  const base = apiOrigin.replace(/\/$/, '');
  const res = await ky.get(`${base}/api/ytmusic/${encodeURIComponent(id)}/analysis`, {
    headers: { accept: 'application/json' },
    throwHttpErrors: false,
    timeout: 8000,
  });

  if (res.status === 404) {
    error = t('lyrics.notFound');
  } else if (!res.ok) {
    error = t('common.httpError', { status: res.status });
  } else {
    const json = (await res.json()) as { data?: YtMusicAnalysis };
    if (!json?.data?.id) error = t('lyrics.invalidResponse');
    else analysis = json.data;
  }
} catch (e) {
  error = e instanceof Error ? e.message : t('lyrics.failedToLoad');
}
const seoDescription = analysis
  ? `${analysis.title} by ${analysis.artist}. ${analysis.background.tldr}`
  : t('lyrics.description');
---

<Layout
  title={`${SITE.name} | ${analysis?.title ?? t('meta.lyricNote')}`}
  locale={locale}
  description={seoDescription}
  canonicalPath={localizedPath(locale, `/lyrics/${encodeURIComponent(id)}`)}
>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6 overflow-x-hidden [overflow-x:clip]">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <a
        href={localizedPath(locale, '/lyrics')}
        class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)] hover:text-[var(--text-body)]"
      >
        {t('lyrics.backToAll')}
      </a>
      <LyricNoteView
        analysis={analysis}
        error={error}
        locale={locale}
        labels={{
          couldNotLoadNote: t('lyrics.couldNotLoadNote'),
          noteLabel: t('lyrics.noteLabel'),
          openTrack: t('lyrics.openTrack'),
          readLyrics: t('lyrics.readLyrics'),
          updatedAt: t('lyrics.updatedAt', { date: '{date}' }),
          background: t('lyrics.background'),
          flashcards: t('lyrics.flashcards'),
          flipHint: t('lyrics.flashcardsFlipHint'),
          tapHint: t('lyrics.flashcardsTapHint'),
          rateHint: t('lyrics.flashcardsRateHint'),
          knownHint: t('lyrics.flashcardsKnownHint'),
          reviewHint: t('lyrics.flashcardsReviewHint'),
          round: t('lyrics.flashcardsRound', { round: '{round}' }),
          completed: t('lyrics.flashcardsCompleted'),
          completedSub: t('lyrics.flashcardsCompletedSub'),
          remaining: t('lyrics.flashcardsRemaining', { count: '{count}' }),
          reset: t('lyrics.flashcardsReset'),
        }}
      />
      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
