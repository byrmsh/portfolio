---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LatestUpdatesCard from '../components/LatestUpdatesCard.astro';
import ProjectGallery from '../components/ProjectGallery.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';
import { getEntry } from 'astro:content';

interface Props {
  url: URL;
  slug: string;
}

const { url, slug } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const project = await getEntry('projects', slug);
if (!project || project.data.draft) return new Response(null, { status: 404 });

const { Content } = await project.render();
const projectCommitPathFilters = Array.from(
  new Set([
    `apps/web/src/content/projects/${project.id}`,
    `apps/web/src/content/projects/${project.slug}.md`,
    `apps/web/src/content/projects/${project.slug}.mdx`,
  ]),
);
const gallery = [project.data.heroImage, ...(project.data.galleryImages ?? [])].filter(
  (v, i, arr) => typeof v === 'string' && arr.indexOf(v) === i,
);
---

<Layout
  title={`${SITE.name} | ${project.data.title}`}
  locale={locale}
  description={project.data.description}
  canonicalPath={localizedPath(locale, `/projects/${project.slug}`)}
  ogType="article"
>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <a
          href={localizedPath(locale, '/projects')}
          class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)] hover:text-[var(--text-body)]"
        >
          {t('projects.back_to_all')}
        </a>

        <h1 class="mt-3 text-2xl font-semibold text-[var(--text-primary)]">{project.data.title}</h1>
        <p class="mt-2 text-sm text-[var(--text-body)]">{project.data.description}</p>
        <p class="mt-2 text-xs font-mono text-[var(--text-muted)]">{project.data.year}</p>

        <div class="mt-3 flex flex-wrap items-center gap-2">
          {
            project.data.stack.map((item) => (
              <span class="inline-flex items-center rounded-full border border-[var(--border-subtle)] bg-[var(--surface-2)] px-2.5 py-1 text-xs font-sans text-[var(--text-body)]">
                {item}
              </span>
            ))
          }
        </div>
      </header>

      <section
        class="-mx-4 rounded-t-xl rounded-b-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6 sm:mx-0 sm:rounded-xl"
      >
        <ProjectGallery
          images={gallery}
          title={project.data.title}
          labels={{
            prev: t('projects.gallery_prev'),
            next: t('projects.gallery_next'),
            maximize: t('projects.gallery_maximize'),
            close: t('common.close_dialog'),
            imageAlt: t('projects.gallery_image_alt', { index: '{index}', title: '{title}' }),
            noScript: t('projects.gallery_no_script'),
          }}
        />

        <article class="mt-5 blog-prose project-prose">
          <Content />
        </article>
      </section>

      <LatestUpdatesCard
        t={t}
        locale={locale}
        title={t('git_commits.post_updates_title')}
        pathFilters={projectCommitPathFilters}
      />

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>

<style>
  .project-prose :global(h2) {
    margin-top: 1.5rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .project-prose :global(h3) {
    margin-top: 1.25rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .project-prose :global(p),
  .project-prose :global(li) {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.7rem;
    color: var(--text-body);
  }
  .project-prose :global(ul) {
    margin-top: 0.75rem;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .project-prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
