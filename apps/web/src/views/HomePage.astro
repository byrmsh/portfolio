---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import PageHero from '../components/PageHero.astro';
import ActivityMonitor from '../components/ActivityMonitor.astro';
import SavedLyricsCard from '../components/SavedLyricsCard.astro';
import WritingCard from '../components/WritingCard.astro';
import KnowledgeGraphCard from '../components/KnowledgeGraphCard.astro';
import JobScoutCard from '../components/JobScoutCard.astro';
import LiveInfrastructureCard from '../components/LiveInfrastructureCard.astro';
import LatestUpdatesCard from '../components/LatestUpdatesCard.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';
import { getCollection } from 'astro:content';

interface Props {
  url: URL;
}

const { url } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const writingPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2)
  .map((p) => ({
    title: p.data.title,
    description: p.data.description,
    href: localizedPath(locale, `/blog/${p.slug}`),
  }));
---

<Layout title={`${SITE.name} | ${t('meta.systemsConsole')}`} locale={locale}>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto flex flex-col gap-10">
      <PageHero t={t} />

      <div class="grid grid-cols-1 md:grid-cols-6 lg:grid-cols-12 gap-5">
        <ActivityMonitor locale={locale} t={t} />
        <SavedLyricsCard locale={locale} t={t} />
        <WritingCard posts={writingPosts} allHref={localizedPath(locale, '/blog')} t={t} />
        <KnowledgeGraphCard t={t} />
        <JobScoutCard t={t} />
        <LiveInfrastructureCard t={t} />
        <LatestUpdatesCard t={t} locale={locale} />
      </div>

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
