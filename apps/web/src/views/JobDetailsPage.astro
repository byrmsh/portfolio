---
import ky from 'ky';
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import JobFacts from '../components/JobFacts.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';

interface Props {
  url: URL;
  id: string;
}

type JobRecord = {
  id: string;
  source: 'public';
  title: string;
  summary: string;
  description: string;
  tags: string[];
  publishedAt: string;
  capturedAt: string;
  href?: string;
  companyName?: string;
  location?: string;
  remote?: boolean;
  jobTypes?: string[];
};

const { url, id } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const apiOrigin =
  process.env.API_ORIGIN ??
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

let job: JobRecord | null = null;
try {
  const cursor = url.searchParams.get('cursor');
  const json = await ky
    .get(`${apiOrigin}/api/jobs/${encodeURIComponent(id)}`, {
      searchParams: cursor ? { cursor } : undefined,
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: JobRecord }>();
  if (json?.data) job = json.data;
} catch {
  job = null;
}

const backHref = localizedPath(locale, '/jobs');
const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'medium', timeStyle: 'short' });
const seoDescription = job?.summary || t('jobs.description');
---

<Layout
  title={`${SITE.name} | ${job?.title ?? t('meta.jobs')}`}
  locale={locale}
  description={seoDescription}
  canonicalPath={localizedPath(locale, `/jobs/${encodeURIComponent(id)}`)}
>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <a
          href={backHref}
          class="text-xs font-mono text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors"
        >
          {t('jobs.backToAll')}
        </a>
        <h1 class="mt-4 text-2xl font-semibold text-[var(--text-primary)]">
          {job?.title ?? t('jobs.notFound')}
        </h1>
        {
          job ? (
            <div class="mt-3 flex flex-wrap gap-2">
              {(Array.isArray(job.tags) ? job.tags : []).slice(0, 10).map((tag) => (
                <span class="text-xxs border border-[var(--border-subtle)] px-1 py-0.5 rounded text-[var(--text-subtle)]">
                  {tag}
                </span>
              ))}
            </div>
          ) : null
        }
        {
          job ? (
            <div class="mt-4 flex flex-wrap items-center gap-3 text-xxs font-mono text-[var(--text-muted)]">
              <span>
                {t('jobs.published', { date: dateFmt.format(new Date(job.publishedAt)) })}
              </span>
              <span>•</span>
              <span>{t('jobs.captured', { date: dateFmt.format(new Date(job.capturedAt)) })}</span>
              {job.href ? (
                <>
                  <span>•</span>
                  <a
                    href={job.href}
                    class="text-accent hover:text-accent/80 transition-colors"
                    target="_blank"
                    rel="noreferrer"
                  >
                    {t('jobs.openListing')}
                  </a>
                </>
              ) : null}
            </div>
          ) : null
        }
      </header>

      <section class="rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6">
        {
          job ? (
            <>
              <JobFacts job={job} locale={locale} t={t} />

              <p class="text-sm text-[var(--text-body)] whitespace-pre-wrap">{job.description}</p>
            </>
          ) : (
            <p class="text-sm text-[var(--text-body)]">{t('jobs.notFound')}</p>
          )
        }
      </section>

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
