---
import ky from 'ky';
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';

interface Props {
  url: URL;
  id: string;
}

type JobRecord = {
  id: string;
  source: 'upwork';
  title: string;
  summary: string;
  description: string;
  tags: string[];
  publishedAt: string;
  capturedAt: string;
  href?: string;
  jobType?: 'FIXED' | 'HOURLY';
  hourlyBudgetMin?: number | null;
  hourlyBudgetMax?: number | null;
  weeklyRetainerBudget?: number | null;
  fixedPriceAmount?: { isoCurrencyCode?: string | null; amount: string } | null;
  contractorTier?: string;
  enterpriseJob?: boolean;
  premium?: boolean;
  personsToHire?: number;
  totalApplicants?: number | null;
  client?: {
    country?: string | null;
    paymentVerificationStatus?: string | null;
    totalReviews?: number;
    totalFeedback?: number;
    totalSpent?: { isoCurrencyCode?: string | null; amount: string } | null;
  };
};

const { url, id } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const apiOrigin =
  process.env.API_ORIGIN ??
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

let job: JobRecord | null = null;
try {
  const json = await ky
    .get(`${apiOrigin}/api/jobs/${encodeURIComponent(id)}`, {
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: JobRecord }>();
  if (json?.data) job = json.data;
} catch {
  job = null;
}

const backHref = localizedPath(locale, '/jobs');
const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'medium', timeStyle: 'short' });
const moneyFmt = new Intl.NumberFormat(locale, { maximumFractionDigits: 0 });

function formatMoney(amount: number | null | undefined, currency: string | null | undefined): string | null {
  if (typeof amount !== 'number' || !Number.isFinite(amount)) return null;
  const cur = typeof currency === 'string' && currency.trim().length ? currency.trim() : null;
  return cur ? `${cur} ${moneyFmt.format(amount)}` : moneyFmt.format(amount);
}

function parseAmountString(raw: string | null | undefined): number | null {
  if (!raw) return null;
  const n = Number(String(raw).trim());
  return Number.isFinite(n) ? n : null;
}
---

<Layout title={`${SITE.name} | ${t('meta.jobs')}`} locale={locale}>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <a href={backHref} class="text-xs font-mono text-neutral-400 hover:text-neutral-900 transition-colors">
          {t('jobs.backToAll')}
        </a>
        <h1 class="mt-4 text-2xl font-semibold text-neutral-900">
          {job?.title ?? t('jobs.notFound')}
        </h1>
        {job ? (
          <div class="mt-3 flex flex-wrap gap-2">
            {(Array.isArray(job.tags) ? job.tags : []).slice(0, 10).map((tag) => (
              <span class="text-xxs border border-neutral-200 px-1 py-0.5 rounded text-neutral-500">
                {tag}
              </span>
            ))}
          </div>
        ) : null}
        {job ? (
          <div class="mt-4 flex flex-wrap items-center gap-3 text-xxs font-mono text-neutral-400">
            <span>{t('jobs.published', { date: dateFmt.format(new Date(job.publishedAt)) })}</span>
            <span>•</span>
            <span>{t('jobs.captured', { date: dateFmt.format(new Date(job.capturedAt)) })}</span>
            {job.href ? (
              <>
                <span>•</span>
                <a
                  href={job.href}
                  class="text-accent hover:text-accent/80 transition-colors"
                  target="_blank"
                  rel="noreferrer"
                >
                  {t('jobs.openUpwork')}
                </a>
              </>
            ) : null}
          </div>
        ) : null}
      </header>

      <section class="rounded-xl border border-neutral-200 bg-white p-6">
        {job ? (
          <>
            <div class="mb-6 rounded-lg border border-neutral-200 bg-neutral-50 p-4">
              <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">{t('jobs.facts')}</h2>
              <div class="mt-3 grid grid-cols-1 gap-2 text-xs text-neutral-700 sm:grid-cols-2">
                <div class="flex items-center justify-between gap-3">
                  <span class="font-mono text-neutral-500">{t('jobs.factType')}</span>
                  <span class="truncate">{job.jobType ?? '--'}</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <span class="font-mono text-neutral-500">{t('jobs.factTier')}</span>
                  <span class="truncate">{job.contractorTier ?? '--'}</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <span class="font-mono text-neutral-500">{t('jobs.factApplicants')}</span>
                  <span class="truncate">{typeof job.totalApplicants === 'number' ? String(job.totalApplicants) : '--'}</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <span class="font-mono text-neutral-500">{t('jobs.factCountry')}</span>
                  <span class="truncate">{job.client?.country ?? '--'}</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <span class="font-mono text-neutral-500">{t('jobs.factPayment')}</span>
                  <span class="truncate">{job.client?.paymentVerificationStatus ?? '--'}</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <span class="font-mono text-neutral-500">{t('jobs.factSpent')}</span>
                  <span class="truncate">
                    {job.client?.totalSpent?.amount
                      ? (() => {
                          const amt = parseAmountString(job.client?.totalSpent?.amount);
                          const cur = job.client?.totalSpent?.isoCurrencyCode ?? null;
                          return amt !== null ? formatMoney(amt, cur) ?? job.client!.totalSpent!.amount : job.client!.totalSpent!.amount;
                        })()
                      : '--'}
                  </span>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <span class="font-mono text-neutral-500">{t('jobs.factBudget')}</span>
                  <span class="truncate">
                    {job.jobType === 'HOURLY'
                      ? [
                          formatMoney(job.hourlyBudgetMin ?? null, null),
                          formatMoney(job.hourlyBudgetMax ?? null, null),
                        ].filter(Boolean).join(' - ') || '--'
                      : job.fixedPriceAmount?.amount
                        ? (() => {
                            const amt = parseAmountString(job.fixedPriceAmount?.amount);
                            const cur = job.fixedPriceAmount?.isoCurrencyCode ?? null;
                            return amt !== null ? formatMoney(amt, cur) ?? job.fixedPriceAmount!.amount : job.fixedPriceAmount!.amount;
                          })()
                        : '--'}
                  </span>
                </div>
              </div>
            </div>

            <p class="text-sm text-neutral-700 whitespace-pre-wrap">
              {job.description}
            </p>
          </>
        ) : (
          <p class="text-sm text-neutral-700">{t('jobs.notFound')}</p>
        )}
      </section>

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
