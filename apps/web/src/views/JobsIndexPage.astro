---
import ky from 'ky';
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';

interface Props {
  url: URL;
}

type JobLead = {
  id: string;
  source: 'upwork';
  title: string;
  summary: string;
  tags: string[];
  publishedAt: string;
  capturedAt: string;
  href?: string;
};

type JobsPage = {
  items: JobLead[];
  nextCursor: string | null;
};

const { url } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const apiOrigin =
  process.env.API_ORIGIN ??
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

function ageMetricFromIso(value: string | null | undefined): string | null {
  if (!value) return null;
  const ts = Date.parse(value);
  if (Number.isNaN(ts)) return null;
  const ageMs = Math.max(0, Date.now() - ts);
  const minutes = Math.floor(ageMs / 60000);
  if (minutes < 60) return `${Math.max(1, minutes)}m`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h`;
  return `${Math.floor(hours / 24)}d`;
}

const before = url.searchParams.get('before');
const limit = 25;

let page: JobsPage = { items: [], nextCursor: null };
try {
  const json = await ky
    .get(`${apiOrigin}/api/jobs`, {
      searchParams: { limit: String(limit), ...(before ? { before } : {}) },
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: JobsPage | null }>();
  if (json?.data?.items) page = json.data;
} catch {
  page = { items: [], nextCursor: null };
}

const newestHref = localizedPath(locale, '/jobs');
const nextHref = (() => {
  if (!page.nextCursor || !Array.isArray(page.items) || page.items.length === 0) return null;
  const u = new URL(newestHref, url);
  u.searchParams.set('before', page.nextCursor);
  return `${u.pathname}${u.search}`;
})();
const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'medium' });
---

<Layout title={`${SITE.name} | ${t('meta.jobs')}`} locale={locale}>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <div class="text-xs font-bold uppercase tracking-widest text-neutral-400">
          {t('jobs.eyebrow')}
        </div>
        <h1 class="mt-2 text-2xl font-semibold text-neutral-900">{t('jobs.title')}</h1>
        <p class="mt-2 text-sm text-neutral-700">
          {t('jobs.description')}
        </p>
      </header>

      <section class="rounded-xl border border-neutral-200 bg-white p-6">
        {
          page.items.length ? (
            <div class="flex flex-col gap-3">
              {page.items.map((job) => {
                const detailHref = localizedPath(locale, `/jobs/${encodeURIComponent(job.id)}`);
                const captured = ageMetricFromIso(job.capturedAt);
                const publishedLabel = job.publishedAt
                  ? dateFmt.format(new Date(job.publishedAt))
                  : '';
                return (
                  <article class="rounded-lg border border-neutral-200 p-4 hover:bg-neutral-50 transition-colors">
                    <a href={detailHref} class="block">
                      <div class="flex items-start gap-3">
                        <div class="min-w-0 flex-1">
                          <h2 class="text-sm font-semibold text-neutral-900 line-clamp-2">
                            {job.title}
                          </h2>
                          <p class="mt-2 text-xs text-neutral-700 line-clamp-3">{job.summary}</p>
                          <div class="mt-3 flex flex-wrap gap-2">
                            {(Array.isArray(job.tags) ? job.tags.slice(0, 6) : []).map((tag) => (
                              <span class="text-xxs border border-neutral-200 px-1 py-0.5 rounded text-neutral-500">
                                {tag}
                              </span>
                            ))}
                          </div>
                          <div class="mt-3 flex items-center gap-3 text-xxs font-mono text-neutral-400">
                            <span>{job.source.toUpperCase()}</span>
                            <span>•</span>
                            <span>{captured ?? '--'}</span>
                            <span>•</span>
                            <span>{publishedLabel}</span>
                          </div>
                        </div>
                      </div>
                    </a>
                  </article>
                );
              })}
            </div>
          ) : (
            <p class="text-sm text-neutral-700">{t('jobs.empty')}</p>
          )
        }

        <div class="mt-6 flex items-center gap-3">
          {
            before ? (
              <a
                href={newestHref}
                class="text-xs font-mono text-neutral-400 hover:text-neutral-900 transition-colors"
              >
                {t('jobs.newest')}
              </a>
            ) : null
          }
          {
            nextHref ? (
              <a
                href={nextHref}
                class="ml-auto text-xs font-mono text-neutral-400 hover:text-neutral-900 transition-colors"
              >
                {t('jobs.next')}
              </a>
            ) : null
          }
        </div>
      </section>

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
