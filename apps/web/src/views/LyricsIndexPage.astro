---
import ky from 'ky';
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LyricNotesList from '../components/LyricNotesList.svelte';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';

interface Props {
  url: URL;
}

const { url } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const apiOrigin =
  process.env.API_ORIGIN ??
  import.meta.env.API_ORIGIN ??
  import.meta.env.PUBLIC_API_ORIGIN ??
  'http://localhost:3000';

type SavedLyricNote = {
  id: string;
  title: string;
  artist: string;
  noteUrl: string;
  albumArtUrl?: string | null;
  savedAt: string;
};

let latest: SavedLyricNote | null = null;
const page = Math.max(1, Number.parseInt(url.searchParams.get('page') ?? '1', 10) || 1);

type SavedLyricNotesPage = {
  items: SavedLyricNote[];
  page: number;
  pageSize: number;
  total: number;
  totalPages: number;
};

let savedPage: SavedLyricNotesPage = {
  items: [],
  page,
  pageSize: 50,
  total: 0,
  totalPages: 0,
};

try {
  const json = await ky
    .get(`${apiOrigin}/api/ytmusic/saved/latest`, {
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: SavedLyricNote | null }>();
  if (json?.data) latest = json.data;
} catch {
  latest = null;
}

try {
  const json = await ky
    .get(`${apiOrigin}/api/ytmusic/saved`, {
      searchParams: { page: String(page) },
      headers: { accept: 'application/json' },
      throwHttpErrors: false,
    })
    .json<{ data?: SavedLyricNotesPage }>();
  if (json?.data) savedPage = json.data;
} catch {
  savedPage = {
    items: [],
    page,
    pageSize: 50,
    total: 0,
    totalPages: 0,
  };
}

const latestHref = latest?.id
  ? localizedPath(locale, `/lyrics/${encodeURIComponent(latest.id)}`)
  : null;
const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'medium', timeStyle: 'short' });
---

<Layout title={`${SITE.name} | ${t('meta.lyrics')}`} locale={locale}>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <div class="text-xs font-bold uppercase tracking-widest text-neutral-400">
          {t('lyrics.eyebrow')}
        </div>
        <h1 class="mt-2 text-2xl font-semibold text-neutral-900">{t('lyrics.title')}</h1>
        <p class="mt-2 text-sm text-neutral-700">
          {t('lyrics.description')}
        </p>
      </header>

      <section class="rounded-xl border border-neutral-200 bg-white p-6">
        <h2 class="text-xs font-bold uppercase tracking-widest text-neutral-400">
          {t('lyrics.latest')}
        </h2>
        {
          latest && latestHref ? (
            <a href={latestHref} class="mt-4 flex items-center gap-4 hover:opacity-90">
              <div class="w-14 h-14 rounded-lg bg-neutral-900 overflow-hidden shrink-0">
                {latest.albumArtUrl ? (
                  <img
                    src={latest.albumArtUrl}
                    alt=""
                    class="w-14 h-14 object-cover"
                    loading="lazy"
                  />
                ) : null}
              </div>
              <div class="min-w-0">
                <div class="text-sm font-semibold text-neutral-900 line-clamp-1">
                  {latest.title}
                </div>
                <div class="text-xs text-neutral-600 mt-1 line-clamp-1">{latest.artist}</div>
                <div class="text-xxs font-mono text-neutral-400 mt-2">
                  {t('lyrics.savedAt', { date: dateFmt.format(new Date(latest.savedAt)) })}
                </div>
              </div>
            </a>
          ) : (
            <p class="mt-3 text-sm text-neutral-700">{t('lyrics.noTracks')}</p>
          )
        }
      </section>

      <LyricNotesList
        initial={savedPage}
        locale={locale}
        basePath={localizedPath(locale, '/lyrics')}
        labels={{
          all: t('lyrics.all', { count: '{count}' }),
          page: t('lyrics.page', { page: '{page}', totalPages: '{totalPages}' }),
          perPage: t('lyrics.perPage', { count: '{count}' }),
          couldNotLoadPage: t('lyrics.couldNotLoadPage', { error: '{error}' }),
          noTracks: t('lyrics.noTracks'),
          savedAt: t('lyrics.savedAt', { date: '{date}' }),
          prev: t('lyrics.prev'),
          next: t('lyrics.next'),
          loading: t('lyrics.loading'),
          invalidResponse: t('lyrics.invalidResponse'),
          failedToLoad: t('lyrics.failedToLoad'),
        }}
      />

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
