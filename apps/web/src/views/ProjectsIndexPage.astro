---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';
import { getCollection } from 'astro:content';

interface Props {
  url: URL;
}

const { url } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title={`${SITE.name} | ${t('meta.projects')}`}
  locale={locale}
  description={t('projects.description')}
  canonicalPath={localizedPath(locale, '/projects')}
>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto flex flex-col gap-8">
      <header>
        <div class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">
          {t('projects.eyebrow')}
        </div>
        <h1 class="mt-2 text-2xl font-semibold text-[var(--text-primary)]">
          {t('projects.title')}
        </h1>
        <p class="mt-2 text-sm text-[var(--text-body)]">{t('projects.description')}</p>
      </header>

      <section class="grid grid-cols-1 lg:grid-cols-2 gap-5">
        {
          projects.map((project) => {
            const detailHref = localizedPath(locale, `/projects/${project.slug}`);
            return (
              <article class="group rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-4">
                <a href={detailHref} class="block">
                  <div class="relative h-44 rounded-lg overflow-hidden border border-[var(--border-muted)]">
                    <img
                      src={project.data.heroImage}
                      alt=""
                      loading="lazy"
                      class="absolute inset-0 w-full h-full object-cover"
                    />
                    <div class="absolute inset-0 bg-gradient-to-r from-black/35 to-black/10" />
                  </div>

                  <h2 class="mt-3 text-base font-semibold text-[var(--text-primary)] group-hover:text-accent transition-colors">
                    {project.data.title}
                  </h2>
                  <p class="mt-2 text-sm text-[var(--text-body)] line-clamp-2">
                    {project.data.summary}
                  </p>

                  <div class="mt-3 flex flex-wrap gap-2">
                    {project.data.stack.map((item) => (
                      <span class="text-xxs border border-[var(--border-subtle)] px-1.5 py-0.5 rounded text-[var(--text-subtle)]">
                        {item}
                      </span>
                    ))}
                  </div>
                </a>
              </article>
            );
          })
        }
      </section>

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
