---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';

interface Props {
  url: URL;
}

const { url } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const email = `contact@${SITE.domain}`;

const GPG_PUBLIC_KEY = `-----BEGIN PGP PUBLIC KEY BLOCK-----

mDMEaMxrrhYJKwYBBAHaRw8BAQdAKEeNz62mwdN8ObTagJlSmlwYQkGrKp/y8SFL
qe7Rv6S0HEJheXJhbSDFnmFoaW4gPG1lQGJheXJhbS5zaD6IkwQTFgoAOwIbAwUL
CQgHAgYVCgkICwIEFgIDAQIeAQIXgBYhBLrYs+ZlF0FVGSYhNyu2UCYQA23eBQJp
Ano6AhkBAAoJECu2UCYQA23eZIgBANmr/blqPXSy+a1MToaziLJl3cxiXo3yfJr2
0XpUkr1BAP9RaTvq27+q8OSezHw7RH4FlZEtZ2Ju47fPsgZVKSk7Brg4BGjMa64S
CisGAQQBl1UBBQEBB0APUZdF6jaSnJve024+lZc6ErCPmoB+CWcpxE5oLJWwLQMB
CAeIeAQYFgoAIBYhBLrYs+ZlF0FVGSYhNyu2UCYQA23eBQJozGuuAhsMAAoJECu2
UCYQA23evZoBAJglZzdsCtL08A3VljcQQ3qyN9PmQdAhJ9Sgzx+iMWPWAQCU9ibS
lXz5kk4pd+Ykgyreki1Kq7oNxpppB0ms5k6yDg==
=nlqX
-----END PGP PUBLIC KEY BLOCK-----`;
---

<Layout
  title={`${SITE.name} | ${t('meta.contact')}`}
  locale={locale}
  description={t('contact.description')}
  canonicalPath={localizedPath(locale, '/contact')}
>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <div class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">
          {t('contact.eyebrow')}
        </div>
        <h1 class="mt-2 text-2xl font-semibold text-[var(--text-primary)]">{t('contact.title')}</h1>
        <p class="mt-2 text-sm text-[var(--text-body)]">{t('contact.description')}</p>
      </header>

      <section class="rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6">
        <div class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">
          {t('contact.email_label')}
        </div>
        <a
          class="mt-2 block font-mono text-sm text-[var(--text-primary)] hover:opacity-80 transition-opacity"
          href={`mailto:${email}`}
        >
          {email}
        </a>
      </section>

      <section class="rounded-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6">
        <div class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">
          {t('contact.gpg_label')}
        </div>
        <pre
          class="mt-3 overflow-x-auto rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-2)] p-4 text-xs leading-relaxed text-[var(--text-primary)]"><code>{GPG_PUBLIC_KEY}</code></pre>
      </section>

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
