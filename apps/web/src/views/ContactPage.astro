=nlqX
-----END PGP PUBLIC KEY BLOCK-----`;
---

<Layout title={`${SITE.name} | ${t('meta.contact')}`} locale={locale}>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <div class="text-xs font-bold uppercase tracking-widest text-neutral-400">
          {t('contact.eyebrow')}
        </div>
        <h1 class="mt-2 text-2xl font-semibold text-neutral-900">{t('contact.title')}</h1>
        <p class="mt-2 text-sm text-neutral-700">{t('contact.description')}</p>
      </header>

      <section class="rounded-xl border border-neutral-200 bg-white p-6">
        <div class="text-xs font-bold uppercase tracking-widest text-neutral-400">
          {t('contact.emailLabel')}
        </div>
        <a
          class="mt-2 block font-mono text-sm text-neutral-900 hover:opacity-80 transition-opacity"
          href={`mailto:${email}`}
        >
          {email}
        </a>
      </section>

      <section class="rounded-xl border border-neutral-200 bg-white p-6">
        <div class="text-xs font-bold uppercase tracking-widest text-neutral-400">
          {t('contact.gpgLabel')}
        </div>
        <pre
          class="mt-3 overflow-x-auto rounded-lg border border-neutral-200 bg-neutral-50 p-4 text-xs leading-relaxed text-neutral-900"><code>{GPG_PUBLIC_KEY}</code></pre>
      </section>

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>
