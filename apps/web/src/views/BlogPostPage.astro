---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LatestUpdatesCard from '../components/LatestUpdatesCard.astro';
import { SITE } from '../config/site';
import { getLocaleFromUrl, getTranslator, localizedPath } from '../i18n';
import { getEntry } from 'astro:content';

interface Props {
  url: URL;
  slug: string;
}

const { url, slug } = Astro.props;
const locale = getLocaleFromUrl(url);
const t = getTranslator(locale);

const post = await getEntry('blog', slug);
if (!post || post.data.draft) return new Response(null, { status: 404 });

const { Content } = await post.render();
const dateFmt = new Intl.DateTimeFormat(locale, { dateStyle: 'medium' });
// Keep pathspecs valid, otherwise `git log -- <paths>` fails and the widget renders empty.
const postCommitPathFilters = Array.from(
  new Set([
    `apps/web/src/content/blog/${post.id}`,
    `apps/web/src/content/blog/${post.slug}.md`,
    `apps/web/src/content/blog/${post.slug}.mdx`,
  ]),
);
---

<Layout
  title={`${SITE.name} | ${post.data.title}`}
  locale={locale}
  description={post.data.description}
  canonicalPath={localizedPath(locale, `/blog/${post.slug}`)}
  ogType="article"
>
  <SiteNav locale={locale} t={t} />

  <main class="pt-28 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto flex flex-col gap-8">
      <header>
        <a
          href={localizedPath(locale, '/blog')}
          class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)] hover:text-[var(--text-body)]"
        >
          {t('blog.backToAll')}
        </a>
        <h1 class="mt-3 text-2xl font-semibold text-[var(--text-primary)]">{post.data.title}</h1>
        <div class="mt-2 text-xxs font-mono text-[var(--text-muted)]">
          {t('blog.published', { date: dateFmt.format(post.data.pubDate) })}
          {
            post.data.updatedDate
              ? ` · ${t('blog.updated', { date: dateFmt.format(post.data.updatedDate) })}`
              : ''
          }
        </div>
        <p class="mt-3 text-sm text-[var(--text-body)]">{post.data.description}</p>
        {
          post.data.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="inline-flex items-center rounded-full border border-[var(--border-subtle)] bg-[var(--surface-2)] px-2.5 py-1 text-xs font-sans text-[var(--text-body)]">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      <article
        class="-mx-4 rounded-t-xl rounded-b-xl border border-[var(--border-subtle)] bg-[var(--surface)] p-6 blog-prose sm:mx-0 sm:rounded-xl"
      >
        <Content />
      </article>

      <LatestUpdatesCard
        t={t}
        locale={locale}
        title={t('gitCommits.postUpdatesTitle')}
        pathFilters={postCommitPathFilters}
      />

      <SiteFooter t={t} locale={locale} />
    </div>
  </main>
</Layout>

<style>
  .blog-prose :global(h2) {
    margin-top: 1.5rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .blog-prose :global(h3) {
    margin-top: 1.25rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .blog-prose :global(p),
  .blog-prose :global(li) {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.7rem;
    color: var(--text-body);
  }
  .blog-prose :global(ul) {
    margin-top: 0.75rem;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .blog-prose :global(ol) {
    margin-top: 0.75rem;
    padding-left: 1.25rem;
    list-style: decimal;
  }
  .blog-prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--surface-3);
    padding: 0.1em 0.25em;
    border-radius: 0.25rem;
  }
  .blog-prose :global(pre) {
    margin-top: 0.75rem;
    padding: 0.9rem 1rem;
    border-radius: 0.75rem;
    background: var(--surface-3);
    overflow: auto;
  }
  .blog-prose :global(pre code) {
    background: transparent;
    padding: 0;
  }
</style>
