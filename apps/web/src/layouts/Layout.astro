---
import '../styles/global.css';
import { SITE } from '../config/site';
import { DEFAULT_LOCALE, SUPPORTED_LOCALES, localizedPath, type SupportedLocale } from '../i18n';

interface Props {
  title: string;
  locale: SupportedLocale;
  description?: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
  ogImagePath?: string;
}

const { title, locale, description, canonicalPath, ogType = 'website', ogImagePath } = Astro.props;
const canonicalOrigin = `https://${SITE.domain}`;
const forwardedHost = Astro.request.headers.get('x-forwarded-host')?.split(',')[0]?.trim();
const forwardedProto = Astro.request.headers.get('x-forwarded-proto')?.split(',')[0]?.trim();
const requestProtocol =
  forwardedProto ??
  (Astro.url.protocol === 'https:' ? 'https' : Astro.url.protocol === 'http:' ? 'http' : 'https');
const requestHost = forwardedHost ?? Astro.url.host;
const requestOrigin = `${requestProtocol}://${requestHost}`;
const isPreviewOrigin = requestOrigin !== canonicalOrigin;
const robots = isPreviewOrigin ? 'noindex,nofollow' : 'index,follow';
const localeToLangTag: Record<SupportedLocale, string> = {
  eng: 'en',
  dev: 'en-x-dev',
};
const htmlLang = localeToLangTag[locale];
const resolvedDescription =
  description ??
  'Personal site for software projects, writing, lyrics notes, and live system updates.';
const resolvedOgImagePath = ogImagePath ?? '/og-image.jpg';
const canonical = new URL(
  canonicalPath ?? `${Astro.url.pathname}${Astro.url.search}`,
  canonicalOrigin,
).toString();
const ogUrl = new URL(
  canonicalPath ?? `${Astro.url.pathname}${Astro.url.search}`,
  requestOrigin,
).toString();
const ogImage = new URL(resolvedOgImagePath, requestOrigin).toString();
const alternateLinks = SUPPORTED_LOCALES.map((l) => ({
  hreflang: localeToLangTag[l],
  href: new URL(localizedPath(l, Astro.url.pathname), canonicalOrigin).toString(),
}));
const xDefaultHref = new URL(
  localizedPath(DEFAULT_LOCALE, Astro.url.pathname),
  canonicalOrigin,
).toString();
const faviconVersion = '20260217';
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        const applyTheme = () => {
          root.dataset.theme = media.matches ? 'dark' : 'light';
        };

        applyTheme();
        if (typeof media.addEventListener === 'function') {
          media.addEventListener('change', applyTheme);
        } else {
          media.addListener(applyTheme);
        }
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.name} - portfolio preview`} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />
    {alternateLinks.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconVersion}`} />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={`/favicon-32x32.png?v=${faviconVersion}`}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href={`/favicon-16x16.png?v=${faviconVersion}`}
    />
    <link rel="shortcut icon" href={`/favicon.ico?v=${faviconVersion}`} />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`/apple-touch-icon.png?v=${faviconVersion}`}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS"
      href={localizedPath(locale, '/rss.xml')}
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="text-[var(--text-primary)] antialiased min-h-screen pb-6">
    <slot />
  </body>
</html>
