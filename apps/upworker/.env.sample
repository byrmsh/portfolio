# REQUIRED
REDIS_URL="redis://localhost:6379/0"

# RECOMMENDED (avoid automated login flow)
# Paste your own authenticated bearer token here.
UPWORK_BEARER_TOKEN=""

# OPTIONAL
COMMON_HEADERS='{"user-agent":"Mozilla/5.0 (X11; Linux x86_64)"}'
GRAPHQL_HEADERS='{"x-upwork-accept-language":"en-US"}'

# OPTIONAL automated login fields (only if not using UPWORK_BEARER_TOKEN)
# LOGIN_HEADERS='{"x-odesk-csrf-token":"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"}'
# LOGIN_DATA='{"login":{"mode":"password","username":"xxxxxxxx","rememberme":true,"elapsedTime":13000,"forterToken":"xxxxxxxx","deviceType":"desktop","password":"xxxxxxxx"}}'

# OPTIONAL proxy settings (leave empty to use direct connection)
# PROXY_URL="http://localhost:3128"

OPTIMAL_PAGE_SIZE="40"
DEFAULT_FETCH_INTERVAL_SECONDS="600"
UPWORK_TOKEN_REDIS_KEY="upwork_token"
# Or provide a file path with one proxy URL per line.
# Empty lines and lines starting with # are ignored.
# PROXY_LIST_FILE="./proxies.txt"
# Recommended: pre-filter with scripts/check-proxies.sh and point to that output file.
# PROXY_LIST_FILE="./proxies.good.txt"
