# REQUIRED
REDIS_URL="redis://localhost:6379/0"

# RECOMMENDED (avoid automated login flow)
# Paste your own authenticated bearer token here.
UPWORK_BEARER_TOKEN=""

# OPTIONAL
COMMON_HEADERS='{"user-agent":"Mozilla/5.0 (X11; Linux x86_64)"}'
GRAPHQL_HEADERS='{"x-upwork-accept-language":"en-US"}'
# curl_cffi browser impersonation (helps avoid Cloudflare 403 on server-side HTTP clients)
# CURL_CFFI_IMPERSONATE="chrome"

# Health endpoint (for K8s probes)
UPWORK_HEALTH_ENABLED="true"
UPWORK_HEALTH_PORT="3000"
# Optional convenience overrides (avoid escaping giant cookies into JSON):
# UPWORK_COOKIE_HEADER="__cf_bm=...; cf_clearance=...; ..."
# UPWORK_COOKIE_FILE="./upwork-cookie.txt"  # raw Cookie header value only
# UPWORK_API_TENANT_ID="2022041695349957848"

# OPTIONAL automated login fields (only if not using UPWORK_BEARER_TOKEN)
# LOGIN_HEADERS='{"x-odesk-csrf-token":"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"}'
# LOGIN_DATA='{"login":{"mode":"password","username":"xxxxxxxx","rememberme":true,"elapsedTime":13000,"forterToken":"xxxxxxxx","deviceType":"desktop","password":"xxxxxxxx"}}'
# UPWORK_AUTH_STRATEGY="api"  # one of: api, playwright, auto
# UPWORK_PLAYWRIGHT_HEADLESS="false"
# UPWORK_PLAYWRIGHT_TIMEOUT_SECONDS="300"
# UPWORK_PLAYWRIGHT_START_URL="https://www.upwork.com/nx/search/jobs"
# UPWORK_PLAYWRIGHT_STORAGE_STATE_FILE="./playwright-state.json"

# OPTIONAL proxy settings (leave empty to use direct connection)
# PROXY_URL="http://localhost:3128"

OPTIMAL_PAGE_SIZE="40"
DEFAULT_FETCH_INTERVAL_SECONDS="600"
UPWORK_TOKEN_REDIS_KEY="upwork_token"
UPWORK_GRAPHQL_HEADERS_REDIS_KEY="upwork_graphql_headers"
UPWORK_COOKIE_REDIS_KEY="upwork_cookie"
UPWORK_API_TENANT_REDIS_KEY="upwork_api_tenant_id"

# Telegram alerting (optional)
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
# TELEGRAM_ALERT_COOLDOWN_SECONDS="21600"
# TELEGRAM_ALERT_REDIS_KEY="stat:upwork:auth_alert"
# Or provide a file path with one proxy URL per line.
# Empty lines and lines starting with # are ignored.
# PROXY_LIST_FILE="./proxies.txt"
# Recommended: pre-filter with scripts/check-proxies.sh and point to that output file.
# PROXY_LIST_FILE="./proxies.good.txt"
