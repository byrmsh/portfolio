REDIS_URL="redis://localhost:6379/0"
REDIS_EVENTS_STREAM="events"

# AnkiWeb (used only when ANKI_COLLECTION_PATH is not set)
ANKIWEB_EMAIL=""
ANKIWEB_PASSWORD=""

# Anki activity collector reads your local collection db.
# Example macOS: ~/Library/Application Support/Anki2/User 1/collection.anki2
# Example Linux: ~/.local/share/Anki2/User 1/collection.anki2
ANKI_COLLECTION_PATH=""
# Optional: affects which calendar day a review lands on (default UTC).
ANKI_TIMEZONE="UTC"
# Optional: where a disposable synced collection is stored when using AnkiWeb sync.
ANKI_SYNC_DIR="/tmp/anki-sync"
# Optional: override sync endpoint (default is AnkiWeb).
ANKI_SYNC_ENDPOINT=""
