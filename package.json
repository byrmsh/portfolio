{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "format": "prettier --write \"apps/web/**/*\" \"apps/api/**/*\"",
    "format:check": "prettier --check \"apps/web/**/*\" \"apps/api/**/*\"",
    "lint": "pnpm lint:ts && pnpm lint:web && pnpm lint:py",
    "lint:ts": "eslint --no-error-on-unmatched-pattern \"apps/api/src/**/*.ts\" \"packages/**/*.ts\"",
    "lint:web": "pnpm -C apps/web check",
    "lint:py": "XDG_DATA_HOME=/tmp/.xdg XDG_CACHE_HOME=/tmp/.xdg-cache UV_CACHE_DIR=/tmp/.uv-cache uvx ruff check apps/collector apps/ankiworker apps/upworker apps/lyricist packages/schema-py/src",
    "k8s:local:apply": "./scripts/k8s-local-apply.sh",
    "k8s:local:web": "./scripts/k8s-local-web-update.sh",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.46.3"
  }
}
